      "item_fields": {
        "rank": "integer starting at 1",
        "action_id": "string stable action ID",
        "action": "enum primary_action",
        "issue_ids": "list[string]",
        "owner_queue": "enum owner_queue",
        "due_basis": "short string"
      }
    },
    "overall": {
      "type": "object",
      "required_keys": [
        "disclosure_required",
        "blocked_category_ids",
        "policy_gap_category_ids",
        "post_hold_spoliation_issue_ids"
      ],
      "fields": {
        "disclosure_required": "boolean",
        "blocked_category_ids": "list[string]",
        "policy_gap_category_ids": "list[string]",
        "post_hold_spoliation_issue_ids": "list[string]"
