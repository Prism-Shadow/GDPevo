      "post_hold_spoliation",
      "recoverable_archive",
      "uncollected_source",
      "retained_missing"
    ],
    "primary_action": [
      "regulator_notice",
      "supplemental_collection",
      "vendor_retrieval",
      "hold_refresh",
      "no_action_policy_gap"
    ],
    "defect_type": [
      "offsite_vendor_not_on_hold",
      "personal_device_notice_omission"
    ],
    "recovery_status": [
      "available",
      "partial",
      "retained_missing"
    ],
    "owner_queue": [
      "legal",
      "litigation_support",
      "records",
      "e_discovery"
    ]
  },
  "fields": {
