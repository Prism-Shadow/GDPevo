      "format": "YYYY-MM-DD"
    },
    "record_class_findings": {
      "type": "list",
      "required_item_keys": [
        "issue_id",
        "record_classes",
        "category_ids",
        "timing_class",
        "severity",
        "quantity",
        "event_date",
        "source_event_ids",
        "primary_action",
        "notice_required"
      ],
      "item_fields": {
        "issue_id": "string stable issue ID",
        "record_classes": "list[string]",
        "category_ids": "list[string]",
        "timing_class": "enum",
        "severity": "enum",
        "quantity": "integer count; use 0 only when no count is available",
        "event_date": "string YYYY-MM-DD for the key destruction, collection, or missing-source event",
        "source_event_ids": "list[string] from API records",
        "primary_action": "enum",
        "notice_required": "boolean"
      }
    },
    "hold_defects": {
      "type": "list",
      "required_item_keys": [
        "defect_id",
        "defect_type",
        "category_ids",
        "affected_sources",
        "severity",
        "source_event_ids",
        "primary_action",
        "notice_required"
      ],
      "item_fields": {
        "defect_id": "string stable hold defect ID",
        "defect_type": "enum",
        "category_ids": "list[string]",
        "affected_sources": "list[string]",
        "severity": "enum",
        "source_event_ids": "list[string] from API records",
        "primary_action": "enum",
        "notice_required": "boolean"
      }
    },
    "recoverable_sources": {
      "type": "list",
      "required_item_keys": [
        "source_id",
        "source_name",
        "record_class",
        "category_ids",
        "recovery_status",
        "count",
        "source_event_ids",
        "primary_action"
      ],
      "item_fields": {
        "source_id": "string stable source ID",
        "source_name": "string",
        "record_class": "string",
        "category_ids": "list[string]",
        "recovery_status": "enum",
        "count": "integer count; use 0 when unknown",
        "source_event_ids": "list[string]",
        "primary_action": "enum"
