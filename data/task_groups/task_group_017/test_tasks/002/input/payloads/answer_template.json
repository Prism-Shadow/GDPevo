{
  "schema_name": "test_002_bay_retention_hold_remediation",
  "schema_version": "1.0",
  "description": "Return one JSON object matching this contract. Do not include this schema metadata in the response.",
  "required_top_level_keys": [
    "matter_id",
    "hold_date",
    "record_class_findings",
    "hold_defects",
    "recoverable_sources",
    "remediation_plan",
    "overall"
  ],
  "top_level_order": [
    "matter_id",
    "hold_date",
    "record_class_findings",
    "hold_defects",
    "recoverable_sources",
    "remediation_plan",
    "overall"
  ],
  "ordering_rules": {
    "record_class_findings": "Sort by issue_id ascending.",
    "hold_defects": "Sort by defect_id ascending.",
    "recoverable_sources": "Sort by source_id ascending.",
    "remediation_plan": "Sort by rank ascending.",
    "category_ids": "Sort category IDs ascending.",
    "source_event_ids": "Sort IDs ascending by prefix group and numeric suffix.",
    "issue_ids": "Sort IDs ascending unless remediation_plan rank defines the row order."
  },
  "enums": {
