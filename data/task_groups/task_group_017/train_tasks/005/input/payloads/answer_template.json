{
  "template_name": "train_005_collection_readiness_v1",
  "output_contract": {
    "required_top_level_keys": [
      "matter_id",
      "overall_readiness",
      "custodian_statuses",
      "retention_gaps",
      "collection_plan",
      "risk_flags"
    ],
    "matter_id": {
      "type": "string",
      "required_value": "M-PHN-612"
    },
    "overall_readiness": {
      "type": "enum",
      "allowed_values": [
        "ready",
        "ready_with_retention_note",
        "not_ready_supplemental_collection_required",
        "not_ready_post_hold_loss"
      ]
    },
    "custodian_statuses": {
      "type": "list",
      "ordering": "sort by custodian_id ascending",
      "item": {
        "custodian_id": {
          "type": "string"
        },
        "role_status": {
          "type": "enum",
          "allowed_values": [
            "former_compliance_custodian",
            "active_related_custodian",
            "other"
          ]
        },
        "personnel_file_retention": {
          "type": "enum",
          "allowed_values": [
            "retained_through_2027",
            "expired_before_hold",
            "not_requested",
            "unknown"
          ]
        },
        "readiness_status": {
          "type": "enum",
          "allowed_values": [
            "ready",
            "ready_with_retention_note",
            "ready_after_archive_validation",
            "blocked_source_gap",
            "blocked_hold_notice_gap",
            "not_in_scope"
          ]
        },
        "required_action_codes": {
          "type": "list",
          "ordering": "sort alphabetically by action_code",
          "item_type": "enum",
          "allowed_values": [
            "archive_validation",
            "hold_refresh",
            "laptop_pst_forensics",
            "no_action",
            "regulator_notice",
            "supplemental_collection",
            "teams_gap_assessment",
            "vendor_archive_retrieval"
          ]
        }
      }
    },
    "retention_gaps": {
      "type": "list",
      "ordering": "sort by category_id ascending",
      "item": {
        "category_id": {
          "type": "string"
        },
        "source_type": {
          "type": "enum",
          "allowed_values": [
            "personnel_file",
            "email_archive",
            "teams",
            "laptop_pst",
            "personal_cloud_text",
            "other"
          ]
        },
        "timing_classification": {
          "type": "enum",
          "allowed_values": [
            "within_retention_available",
            "recoverable_archive",
            "pre_2022_teams_gap",
            "uncollected_source",
            "hold_notice_defect",
            "post_hold_spoliation",
            "no_material_gap",
            "unknown"
          ]
        },
        "availability_status": {
          "type": "enum",
          "allowed_values": [
            "available",
            "collected",
            "recoverable",
            "partial_gap",
            "missing",
            "not_noticed",
            "unknown"
          ]
        },
        "missing_count": {
          "type": "integer",
          "unit": "records or source units from the collection event"
        },
        "ready_status": {
          "type": "enum",
          "allowed_values": [
            "ready",
            "ready_with_retention_note",
            "ready_after_archive_validation",
            "blocked_source_gap",
            "blocked_hold_notice_gap"
          ]
        },
        "primary_action": {
          "type": "enum",
          "allowed_values": [
            "archive_validation",
            "hold_refresh",
            "laptop_pst_forensics",
            "no_action",
            "supplemental_collection",
            "teams_gap_assessment",
            "vendor_archive_retrieval"
          ]
        }
      }
    },
    "collection_plan": {
      "type": "list",
      "ordering": "sort by priority_rank ascending",
      "item": {
        "priority_rank": {
          "type": "integer",
          "minimum": 1
        },
        "action_code": {
          "type": "enum",
          "allowed_values": [
            "archive_validation",
            "hold_refresh",
            "laptop_pst_forensics",
            "regulator_notice",
            "supplemental_collection",
            "teams_gap_assessment",
            "vendor_archive_retrieval"
          ]
        },
        "target_category_ids": {
          "type": "list",
          "ordering": "sort category IDs ascending",
          "item_type": "string"
        },
        "target_source_types": {
          "type": "list",
          "ordering": "sort source type enums alphabetically",
          "item_type": "enum",
          "allowed_values": [
            "personnel_file",
            "email_archive",
            "teams",
            "laptop_pst",
            "personal_cloud_text",
            "other"
          ]
        },
        "required_before_production": {
          "type": "boolean"
        }
      }
    },
    "risk_flags": {
      "type": "list",
      "ordering": "sort by flag_code ascending",
      "item": {
        "flag_code": {
          "type": "enum",
          "allowed_values": [
            "archive_recoverable_email",
            "former_personnel_retained",
            "hold_notice_omitted_personal_cloud_text",
            "missing_local_pst",
            "post_hold_loss",
            "teams_pre_2022_gap"
          ]
        },
        "severity": {
          "type": "enum",
          "allowed_values": [
            "critical",
            "high",
            "medium",
            "low"
          ]
        },
        "category_ids": {
          "type": "list",
          "ordering": "sort category IDs ascending",
          "item_type": "string"
        },
        "requires_regulator_notice": {
          "type": "boolean"
        }
      }
    }
  }
}
