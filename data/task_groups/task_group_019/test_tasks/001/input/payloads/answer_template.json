{
  "schema_name": "contractor_eligibility_review_v2",
  "required_top_level_keys": [
    "batch_id",
    "review_cutoff_date",
    "application_decisions",
    "deficiency_counts",
    "bulletin_impacts"
  ],
  "top_level_fields": {
    "batch_id": {
      "type": "string",
      "required_value": "HS-2026-Q2A"
    },
    "review_cutoff_date": {
      "type": "string",
      "format": "YYYY-MM-DD",
      "required_value": "2026-06-20"
    },
    "application_decisions": {
      "type": "list",
      "ordering": "ascending by application_id",
      "coverage": "include every application returned for batch HS-2026-Q2A and no other applications",
      "item_fields": {
        "application_id": {
          "type": "string"
        },
        "determination": {
          "type": "enum",
          "allowed_values": [
            "APPROVE",
            "HOLD",
            "DENY"
          ]
        },
        "reason_codes": {
          "type": "list[enum]",
          "ordering": "use the enum order listed here",
          "allowed_values": [
            "NO_DEFICIENCY",
            "BOND_SHORTFALL",
            "BOND_CANCELLED",
            "INSURANCE_VERIFY",
            "UNRESOLVED_PENALTY",
            "FIELD_NOTE_HOLD",
            "DISQUALIFYING_CONDUCT",
            "EXPERIENCE_VERIFY",
            "CORRESPONDENCE_HOLD",
            "ADVERSE_PRIOR_REGISTRATION",
            "EXAM_SCORE_SHORTFALL",
            "FINANCIAL_STATEMENT_MISSING"
          ]
        },
        "primary_bulletin_ids": {
          "type": "list[string]",
          "ordering": "ascending bulletin_id; use an empty list when no bulletin drives the decision"
        },
        "next_action": {
          "type": "enum",
          "allowed_values": [
            "NO_ACTION",
            "REQUEST_BOND_RIDER",
            "REQUEST_REPLACEMENT_BOND",
            "REQUEST_INSURANCE_VERIFICATION",
            "REFER_UNRESOLVED_PENALTY",
            "REQUEST_FIELD_CLEARANCE",
            "REQUEST_EXPERIENCE_DOCUMENTATION",
            "REQUEST_CORRESPONDENCE_REVIEW",
            "REQUEST_PRIOR_REGISTRATION_REVIEW",
            "DENY_APPLICATION",
            "COMBINED_HOLD_REVIEW"
          ]
        }
      }
    },
    "deficiency_counts": {
      "type": "object",
      "required_fields": {
        "applications_reviewed": "integer",
        "determinations": {
          "APPROVE": "integer",
          "HOLD": "integer",
          "DENY": "integer"
        },
        "reason_codes": {
          "NO_DEFICIENCY": "integer",
          "BOND_SHORTFALL": "integer",
          "BOND_CANCELLED": "integer",
          "INSURANCE_VERIFY": "integer",
          "UNRESOLVED_PENALTY": "integer",
          "FIELD_NOTE_HOLD": "integer",
          "DISQUALIFYING_CONDUCT": "integer",
          "EXPERIENCE_VERIFY": "integer",
          "CORRESPONDENCE_HOLD": "integer",
          "ADVERSE_PRIOR_REGISTRATION": "integer",
          "EXAM_SCORE_SHORTFALL": "integer",
          "FINANCIAL_STATEMENT_MISSING": "integer"
        }
      }
    },
    "bulletin_impacts": {
      "type": "object",
      "required_fields": {
        "applicable_bulletin_ids": {
          "type": "list[string]",
          "ordering": "ascending bulletin_id"
        },
        "applications_changed_by_2026_bulletins": {
          "type": "list[string]",
          "ordering": "ascending application_id"
        },
        "deficiency_count_by_rule_type": {
          "EXAM_MINIMUM": "integer",
          "BOND_MINIMUM": "integer",
          "INSURANCE_MINIMUM": "integer",
          "EXPERIENCE_MINIMUM": "integer",
          "BACKGROUND_SCREENING": "integer",
          "CORRESPONDENCE_REVIEW": "integer",
          "FIELD_NOTE_REVIEW": "integer"
        },
        "unchanged_by_bulletins_count": "integer"
      }
    }
  },
  "numeric_precision": {
    "all_counts": "integer"
  }
}
