{
  "description": "Restricted liquor-license staff package output schema for application L-TE3-001. Return one JSON object with exactly these business fields; extra explanatory prose is not required.",
  "required_top_level_keys": [
    "application_id",
    "recommended_posture",
    "same_premises_basis_applies",
    "covered_risk_codes",
    "verification_gap_codes",
    "standard_obligation_codes",
    "location_specific_control_codes",
    "first_90_day_plan",
    "escalation_trigger_codes"
  ],
  "field_definitions": {
    "application_id": {
      "type": "string",
      "required": true,
      "format": "stable application identifier"
    },
    "recommended_posture": {
      "type": "enum",
      "required": true,
      "allowed_values": [
        "issue_restricted",
        "request_follow_up",
        "deny"
      ]
    },
    "same_premises_basis_applies": {
      "type": "boolean",
      "required": true
    },
    "covered_risk_codes": {
      "type": "array",
      "required": true,
      "items": {
        "type": "enum",
        "allowed_values": [
          "AFTER_HOURS",
          "FOOD_SERVICE_GAP",
          "MINOR_SALE",
          "NOISE",
          "PUBLIC_SAFETY",
          "SALE_TO_MINOR",
          "SAME_PREMISES",
          "TAX_HOLD"
        ]
      },
      "ordering": "Sort ascending by code and use each code at most once."
    },
    "verification_gap_codes": {
      "type": "array",
      "required": true,
      "items": {
        "type": "enum",
        "allowed_values": [
          "food_service_evidence_missing",
          "late_night_monitoring_needed",
          "police_memo_conflicting",
          "site_photo_conflicting",
          "site_photo_missing",
          "tax_hold_unresolved"
        ]
      },
      "ordering": "Sort ascending by code and use each code at most once."
    },
    "standard_obligation_codes": {
      "type": "array",
      "required": true,
      "items": {
        "type": "enum",
        "allowed_values": [
          "CCTV",
          "DELIVERY",
          "FOOD_SERVICE",
          "HOURS",
          "ID_CHECK",
          "NOISE",
          "PATIO",
          "SECURITY"
        ]
      },
      "ordering": "Sort ascending by code and include only ordinary standard-required obligations for the license class."
    },
    "location_specific_control_codes": {
      "type": "array",
      "required": true,
      "items": {
        "type": "enum",
        "allowed_values": [
          "CCTV",
          "DELIVERY",
          "FOOD_SERVICE",
          "HOURS",
          "ID_CHECK",
          "NOISE",
          "PATIO",
          "SECURITY"
        ]
      },
      "ordering": "Sort ascending by code and include only active controls tied to this location."
    },
    "first_90_day_plan": {
      "type": "array",
      "required": true,
      "ordering": "Sort ascending by check_code and use each check_code/timing pair at most once.",
      "items": {
        "type": "object",
        "required_keys": [
          "check_code",
          "timing"
        ],
        "fields": {
          "check_code": {
            "type": "enum",
            "allowed_values": [
              "food_service_service_area_check",
              "id_check_observation",
              "late_night_closing_visit",
              "noise_log_review",
              "police_memo_follow_up",
              "site_photo_recheck"
            ]
          },
          "timing": {
            "type": "enum",
            "allowed_values": [
              "first_30_days",
              "days_31_60",
              "days_61_90"
            ]
          }
        }
      }
    },
    "escalation_trigger_codes": {
      "type": "array",
      "required": true,
      "items": {
        "type": "enum",
        "allowed_values": [
          "after_hours_service",
          "food_service_not_available",
          "id_check_failure",
          "noise_complaint_recurrence",
          "police_memo_conflict_unresolved",
          "site_photo_not_verified",
          "tax_hold_reopened"
        ]
      },
      "ordering": "Sort ascending by code and use each code at most once."
    }
  },
  "numeric_precision": "No numeric scored fields are required for this task.",
  "date_format": "YYYY-MM-DD when dates are used inside any optional unscored fields."
}
