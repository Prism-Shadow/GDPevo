{
  "type": "object",
  "schema_name": "restricted_on_premises_alcohol_review",
  "schema_version": "1.0",
  "required_top_level_keys": [
    "task_id",
    "review_month",
    "application_id",
    "premises_id",
    "recommendation",
    "controls_classification",
    "verification_gaps",
    "inspection_priorities",
    "risk_assessment"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "required_value": "test_003"
    },
    "review_month": {
      "type": "string",
      "format": "YYYY-MM",
      "required_value": "2026-05"
    },
    "application_id": {
      "type": "string",
      "required_value": "AA-2026-0036"
    },
    "premises_id": {
      "type": "string",
      "required_value": "PM-2026-036"
    },
    "recommendation": {
      "type": "enum",
      "allowed_values": [
        "ISSUE_STANDARD",
        "ISSUE_RESTRICTED_WITH_MONITORING",
        "REQUEST_RECORDS_BEFORE_ISSUE",
        "DENY"
      ]
    },
    "risk_assessment": {
      "type": "object",
      "required_keys": [
        "same_premises_basis",
        "prior_licensee",
        "prior_incident_level",
        "incident_count",
        "unresolved_incident_count",
        "high_severity_incident_count",
        "unresolved_incident_ids",
        "high_severity_incident_ids",
        "settlement_posture",
        "control_overlap",
        "successor_risk_classification",
        "overall_risk"
      ],
      "properties": {
        "same_premises_basis": {
          "type": "enum",
          "allowed_values": [
            "NONE",
            "PRIOR_SETTLEMENT_AT_ADDRESS",
            "SAME_ADDRESS_OVERLAP"
          ]
        },
        "prior_licensee": {
          "type": "string"
        },
        "prior_incident_level": {
          "type": "enum",
          "allowed_values": [
            "NONE",
            "LOW",
            "MODERATE",
            "HIGH"
          ]
        },
        "incident_count": {
          "type": "integer",
          "units": "incidents"
        },
        "unresolved_incident_count": {
          "type": "integer",
          "units": "incidents with pending or blank disposition"
        },
        "high_severity_incident_count": {
          "type": "integer",
          "units": "incidents"
        },
        "unresolved_incident_ids": {
          "type": "list",
          "item_type": "string",
          "ordering": "ascending source ID"
        },
        "high_severity_incident_ids": {
          "type": "list",
          "item_type": "string",
          "ordering": "ascending source ID"
        },
        "settlement_posture": {
          "type": "enum",
          "allowed_values": [
            "NONE",
            "PRIOR_WARNING_WITH_CONTROLS",
            "PRIOR_RESTRICTED_OR_DENIAL",
            "CURRENT_SETTLEMENT"
          ]
        },
        "control_overlap": {
          "type": "enum",
          "allowed_values": [
            "NONE",
            "STANDARD_ONLY",
            "LOCATION_SPECIFIC_CONTROLS_PRESENT",
            "OVERLAPS_PRIOR_FAILED_CONTROLS"
          ]
        },
        "successor_risk_classification": {
          "type": "enum",
          "allowed_values": [
            "LOW",
            "MODERATE",
            "HIGH"
          ]
        },
        "overall_risk": {
          "type": "enum",
          "allowed_values": [
            "LOW",
            "MODERATE",
            "ELEVATED",
            "SEVERE"
          ]
        }
      }
    },
    "controls_classification": {
      "type": "object",
      "required_keys": [
        "classification_summary",
        "standard_obligations",
        "location_specific_restrictions"
      ],
      "properties": {
        "classification_summary": {
          "type": "object",
          "required_keys": [
            "standard_obligation_count",
            "location_specific_restriction_count",
            "current_controls_overlap_prior_risk",
            "standard_obligations_kept_separate"
          ],
          "properties": {
            "standard_obligation_count": {
              "type": "integer"
            },
            "location_specific_restriction_count": {
              "type": "integer"
            },
            "current_controls_overlap_prior_risk": {
              "type": "boolean"
            },
            "standard_obligations_kept_separate": {
              "type": "boolean"
            }
          }
        },
        "standard_obligations": {
          "type": "list",
          "ordering": "ascending obligation_code",
          "item_schema": {
            "type": "object",
            "required_keys": [
              "obligation_code",
              "source_obligation_id",
              "evidence_required"
            ],
            "properties": {
              "obligation_code": {
                "type": "enum",
                "allowed_values": [
                  "BREW_PRODUCTION",
                  "BREW_SAMPLES",
                  "BREW_TRAINING",
                  "F_COM_FOOD",
                  "F_COM_MINORS",
                  "F_COM_SERVER",
                  "INCIDENT_REPORT",
                  "PUBLIC_RECORDS",
                  "RTL_DISPLAY",
                  "RTL_SALES",
                  "RTL_STAFF",
                  "TAVERN_AGE",
                  "TAVERN_HOURS",
                  "TAVERN_SECURITY"
                ]
              },
              "source_obligation_id": {
                "type": "string"
              },
              "evidence_required": {
                "type": "string"
              }
            }
          }
        },
        "location_specific_restrictions": {
          "type": "list",
          "ordering": "ascending control_code",
          "item_schema": {
            "type": "object",
            "required_keys": [
              "control_code",
              "source_ids",
              "overlap_status",
              "evidence_required",
              "first_90_day_focus"
            ],
            "properties": {
              "control_code": {
                "type": "enum",
                "allowed_values": [
                  "AGE_CHECK",
                  "LATE_NIGHT_DISORDER_MONITORING",
                  "NO_AFTER_MIDNIGHT_SERVICE",
                  "PATIO_LIMIT",
                  "QUARTERLY_INSPECTION_CONDITION",
                  "SECURITY_LOG",
                  "SECURITY_PLAN_LAPSE_REVIEW"
                ]
              },
              "source_ids": {
                "type": "list",
                "item_type": "string",
                "ordering": "ascending source ID"
              },
              "overlap_status": {
                "type": "enum",
                "allowed_values": [
                  "NEW_LOCATION_CONTROL",
                  "OVERLAPS_PRIOR_FAILED_CONTROL",
                  "DERIVED_FROM_INCIDENT_HISTORY"
                ]
              },
              "evidence_required": {
                "type": "string"
              },
              "first_90_day_focus": {
                "type": "enum",
                "allowed_values": [
                  "DEVICE_AUDIT",
                  "PATIO_CLOSURE_LOG_REVIEW",
                  "POLICE_CALL_LOG_REVIEW",
                  "SECURITY_LOG_REVIEW",
                  "SERVICE_LOG_REVIEW",
                  "SITE_INSPECTION"
                ]
              }
            }
          }
        }
      }
    },
    "verification_gaps": {
      "type": "list",
      "ordering": "ascending gap_code",
      "item_schema": {
        "type": "object",
        "required_keys": [
          "gap_code",
          "source_ids",
          "status"
        ],
        "properties": {
          "gap_code": {
            "type": "enum",
            "allowed_values": [
              "CONTROL_EFFECTIVENESS_EVIDENCE_NOT_VERIFIED",
              "PENDING_ASSAULT_CALL_DISPOSITION",
              "PENDING_POLICE_CALL_DISPOSITIONS",
              "PRIOR_RESTRICTED_SETTLEMENT_PACKET",
              "SAME_PREMISES_SUCCESSOR_STATEMENT_MISSING",
              "SECURITY_PLAN_LAPSE_DISPOSITION_MISSING",
              "SETTLEMENT_TERMS_NOT_FOUND",
              "NO_VERIFICATION_GAPS"
            ]
          },
          "source_ids": {
            "type": "list",
            "item_type": "string",
            "ordering": "ascending source ID"
          },
          "status": {
            "type": "enum",
            "allowed_values": [
              "REQUEST_BEFORE_FINAL",
              "VERIFY_BEFORE_RELYING",
              "MONITOR_IN_FIRST_90_DAYS",
              "NOT_APPLICABLE"
            ]
          }
        }
      }
    },
    "inspection_priorities": {
      "type": "list",
      "ordering": "ascending priority_rank",
      "item_schema": {
        "type": "object",
        "required_keys": [
          "priority_rank",
          "priority_code",
          "target_control_code",
          "source_ids",
          "timing"
        ],
        "properties": {
          "priority_rank": {
            "type": "integer"
          },
          "priority_code": {
            "type": "enum",
            "allowed_values": [
              "AFTER_MIDNIGHT_SERVICE_LOG_REVIEW",
              "AGE_DEVICE_AUDIT",
              "F_COM_STANDARD_OBLIGATION_CHECK",
              "FOOD_SERVICE_DOCUMENT_REVIEW",
              "PATIO_CLOSURE_LOG_REVIEW",
              "POLICE_CALL_LOG_REVIEW",
              "QUARTERLY_SITE_INSPECTION",
              "SECURITY_LOG_REVIEW"
            ]
          },
          "target_control_code": {
            "type": "enum",
            "allowed_values": [
              "AGE_CHECK",
              "ASSAULT_CALL_HISTORY",
              "F_COM_STANDARD_OBLIGATIONS",
              "NO_AFTER_MIDNIGHT_SERVICE",
              "PATIO_LIMIT",
              "SECURITY_LOG"
            ]
          },
          "source_ids": {
            "type": "list",
            "item_type": "string",
            "ordering": "ascending source ID"
          },
          "timing": {
            "type": "enum",
            "allowed_values": [
              "FIRST_30_DAYS",
              "FIRST_60_DAYS",
              "FIRST_90_DAYS"
            ]
          }
        }
      }
    }
  },
  "additional_properties_allowed": false
}
