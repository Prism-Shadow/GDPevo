{
  "task_id": "train_002",
  "response_file": "answer.json",
  "description": "Restricted liquor license staff package for one application and location.",
  "required_top_level_keys": [
    "application_id",
    "recommended_posture",
    "same_premises_basis_applies",
    "covered_risk_codes",
    "verification_gap_codes",
    "standard_obligation_codes",
    "location_specific_control_codes",
    "first_90_day_plan",
    "escalation_trigger_codes"
