              "food_service_check",
              "id_check_observation",
              "noise_log_review",
              "patio_boundary_check",
              "police_memo_follow_up",
              "security_cctv_walkthrough",
              "tax_clearance_check"
            ]
          },
          "timing": {
            "type": "enum",
            "allowed_values": [
              "first_30_days",
              "days_31_60",
              "days_61_90"
