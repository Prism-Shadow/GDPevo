        "request_follow_up",
        "deny"
      ]
    },
    "same_premises_basis_applies": {
      "type": "boolean",
      "required": true
    },
    "covered_risk_codes": {
      "type": "array",
      "required": true,
      "items": {
        "type": "enum",
        "allowed_values": [
          "AFTER_HOURS",
          "ASSAULT",
          "FOOD_SERVICE_GAP",
          "MINOR_SALE",
          "NOISE",
          "PUBLIC_SAFETY",
          "SALE_TO_MINOR",
          "SAME_PREMISES",
          "TAX_HOLD"
        ]
      },
      "ordering": "Sort ascending by code and remove duplicates."
    },
    "verification_gap_codes": {
      "type": "array",
      "required": true,
      "items": {
        "type": "enum",
        "allowed_values": [
          "CONTROL_SIGNAGE_CONFLICTING",
          "CONTROL_SIGNAGE_CURRENT_MISSING",
          "FLOOR_PLAN_CONFLICTING",
          "FLOOR_PLAN_STALE",
          "NEIGHBOR_NOTICE_MISSING",
          "OPEN_INCIDENT_FOLLOW_UP",
          "POLICE_MEMO_CONFLICTING",
          "SITE_PHOTO_MISSING",
          "TAX_CLEARANCE_MISSING"
        ]
      },
      "ordering": "Sort ascending by code and remove duplicates."
    },
    "standard_obligation_codes": {
      "type": "array",
      "required": true,
      "items": {
        "type": "enum",
        "allowed_values": [
          "CCTV",
          "DELIVERY",
          "FOOD_SERVICE",
          "HOURS",
          "ID_CHECK",
          "NOISE",
          "PATIO",
          "SECURITY"
        ]
      },
      "ordering": "Sort ascending by code and remove duplicates."
    },
    "location_specific_control_codes": {
      "type": "array",
      "required": true,
      "items": {
        "type": "enum",
        "allowed_values": [
          "CCTV",
          "DELIVERY",
          "FOOD_SERVICE",
          "HOURS",
          "ID_CHECK",
          "NOISE",
          "PATIO",
          "SECURITY"
        ]
      },
      "ordering": "Sort ascending by code and remove duplicates."
    },
    "first_90_day_plan": {
      "type": "array",
      "required": true,
      "ordering": "Sort ascending by check_code and remove duplicate check_code/timing pairs.",
      "items": {
