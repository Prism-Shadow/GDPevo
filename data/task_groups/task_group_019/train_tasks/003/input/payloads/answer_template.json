{
  "description": "Required output schema for train_003 renewal manual-review queue.",
  "top_level_keys": {
    "queue": {
      "type": "list",
      "required": true,
      "length": 10,
      "ordering": "Rank ascending from 1 to 10. Rank is business-significant.",
      "item_required_keys": {
        "rank": {
          "type": "integer",
          "allowed_range": [1, 10]
        },
        "license_id": {
          "type": "string",
          "format": "CLRP renewal license ID"
        },
        "facility_name": {
          "type": "string",
          "format": "Facility name from the current renewal roster"
        },
        "match_confidence": {
          "type": "enum",
          "allowed_values": ["exact", "close", "shared_address_manual"]
        },
        "violation_count_used": {
          "type": "integer",
          "description": "Count of matched violation records used for pre-boundary ranking."
        },
        "most_recent_date_used": {
          "type": "string",
          "format": "YYYY-MM-DD",
          "description": "Most recent matched violation date used for pre-boundary ranking."
        },
        "next_step_label": {
          "type": "enum",
          "allowed_values": [
            "manual fine check",
            "manual ALERT check",
            "board review",
            "additional record check"
          ]
        }
      }
    },
    "method_flags": {
      "type": "object",
      "required": true,
      "required_keys": {
        "release_batch": {
          "type": "string",
          "expected_value": "RV-2026-SPRING"
        },
        "release_boundary": {
          "type": "string",
          "format": "YYYY-MM-DD",
          "expected_value": "2026-04-15"
        },
        "queue_size": {
          "type": "integer",
          "expected_value": 10
        },
        "excluded_post_boundary_count": {
          "type": "integer",
          "description": "Count of matched renewal violation records excluded because their violation_date is after the release boundary."
        },
        "post_boundary_exclusion_applied": {
          "type": "boolean"
        },
        "shared_address_records_not_spread": {
          "type": "boolean"
        }
      }
    }
  },
  "notes": [
    "Return JSON only.",
    "Do not include evidence text or free-form explanations.",
    "Dates must use YYYY-MM-DD.",
    "String enum values are case-sensitive."
  ]
}
