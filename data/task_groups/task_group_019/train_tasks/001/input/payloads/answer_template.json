{
  "description": "Required JSON output for train_001 contractor batch eligibility review.",
  "top_level_keys": {
    "application_decisions": {
      "type": "list",
      "ordering": "ascending by application_id",
      "required_length": 8,
      "item_schema": {
        "application_id": {
          "type": "enum",
          "allowed_values": [
            "C-TR1-001",
            "C-TR1-002",
            "C-TR1-003",
            "C-TR1-004",
            "C-TR1-005",
            "C-TR1-006",
            "C-TR1-007",
            "C-TR1-008"
          ]
        },
        "determination": {
          "type": "enum",
          "allowed_values": [
            "APPROVE",
            "HOLD",
            "DENY"
          ]
        },
        "deficiency_codes": {
          "type": "list",
          "item_type": "enum",
          "ordering": "ascending lexical order",
          "allowed_values": [
            "active_suspension",
            "bond_cancelled",
            "bond_shortfall",
            "endorsement_missing",
            "endorsement_pending",
            "experience_shortfall",
            "inspection_doc_gap",
            "inspection_safety_recheck",
            "insurance_expired",
            "insurance_pending",
            "insurance_shortfall",
            "open_minor_violation",
            "open_serious_violation"
          ]
        },
        "required_actions": {
          "type": "list",
          "item_type": "enum",
          "ordering": "ascending lexical order",
          "allowed_values": [
            "board_review_suspension",
            "clear_document_gap",
            "complete_safety_recheck",
            "increase_bond_amount",
            "increase_insurance_amount",
            "obtain_current_bond",
            "obtain_required_endorsement",
            "provide_current_insurance",
            "resolve_minor_violation_review",
            "resolve_serious_violation",
            "submit_experience_evidence",
            "verify_insurance_binding",
            "verify_pending_endorsement"
          ]
        },
        "risk_tier": {
          "type": "enum",
          "allowed_values": [
            "low",
            "medium",
            "high"
          ]
        },
        "policy_impacted": {
          "type": "boolean",
          "meaning": "Whether the current policy baseline changes the eligibility analysis for this application."
        }
      }
    },
    "summary": {
      "type": "object",
      "required_keys": {
        "approve_count": {
          "type": "integer",
          "units": "applications"
        },
        "hold_count": {
          "type": "integer",
          "units": "applications"
        },
        "deny_count": {
          "type": "integer",
          "units": "applications"
        },
        "high_risk_application_ids": {
          "type": "list",
          "item_type": "application_id",
          "ordering": "ascending lexical order"
        },
        "policy_impacted_application_ids": {
          "type": "list",
          "item_type": "application_id",
          "ordering": "ascending lexical order"
        },
        "stale_or_unverified_correspondence_ids": {
          "type": "list",
          "item_type": "string",
          "ordering": "ascending lexical order"
        }
      }
    }
  },
  "additional_output": "Do not include prose, citations, markdown, comments, or keys not shown in this template."
}
