{
  "type": "object",
  "required_top_level_keys": [
    "task_id",
    "review_month",
    "application_id",
    "premises_id",
    "recommendation",
    "successor_risk_classification",
    "verification_gaps",
    "standard_obligations",
    "premises_specific_controls",
    "records_requests",
    "escalation_triggers"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "required_value": "train_005"
    },
    "review_month": {
      "type": "string",
      "format": "YYYY-MM",
      "required_value": "2026-03"
    },
    "application_id": {
      "type": "string",
      "required_value": "AA-2026-0018"
    },
    "premises_id": {
      "type": "string",
      "required_value": "PM-2026-018"
    },
    "recommendation": {
      "type": "enum",
      "allowed_values": [
        "ISSUE_STANDARD",
        "ISSUE_RESTRICTED_WITH_MONITORING",
        "REQUEST_RECORDS_BEFORE_ISSUE",
        "DENY"
      ]
    },
    "successor_risk_classification": {
      "type": "enum",
      "allowed_values": [
        "LOW",
        "MODERATE",
        "HIGH"
      ]
    },
    "verification_gaps": {
      "type": "list",
      "ordering": "ascending gap_code",
      "item_schema": {
        "type": "object",
        "required_keys": [
          "gap_code",
          "source_ids",
          "status"
        ],
        "properties": {
          "gap_code": {
            "type": "enum",
            "allowed_values": [
              "CONTROL_EVIDENCE_NOT_VERIFIED",
              "PENDING_INCIDENT_DISPOSITIONS",
              "POST_REVIEW_SETTLEMENT_TIMING",
              "STANDARD_CONTROL_OVERLAP",
              "SUCCESSOR_CONTROL_SEPARATION"
            ]
          },
          "source_ids": {
            "type": "list",
            "item_type": "string",
            "ordering": "ascending source ID"
          },
          "status": {
            "type": "enum",
            "allowed_values": [
              "REQUEST_BEFORE_FINAL",
              "SEPARATE_FROM_PREMISES_CONTROLS",
              "MONITOR_IN_FIRST_90_DAYS"
            ]
          }
        }
      }
    },
    "standard_obligations": {
      "type": "list",
      "ordering": "ascending obligation_code",
      "item_schema": {
        "type": "object",
        "required_keys": [
          "obligation_code",
          "source_obligation_id",
          "evidence_required"
        ],
        "properties": {
          "obligation_code": {
            "type": "enum",
            "allowed_values": [
              "BREW_PRODUCTION",
              "BREW_SAMPLES",
              "BREW_TRAINING",
              "F_COM_FOOD",
              "F_COM_MINORS",
              "F_COM_SERVER",
              "INCIDENT_REPORT",
              "PUBLIC_RECORDS",
              "RTL_DISPLAY",
              "RTL_SALES",
              "RTL_STAFF",
              "TAVERN_AGE",
              "TAVERN_HOURS",
              "TAVERN_SECURITY"
            ]
          },
          "source_obligation_id": {
            "type": "string"
          },
          "evidence_required": {
            "type": "string"
          }
        }
      }
    },
    "premises_specific_controls": {
      "type": "list",
      "ordering": "ascending control_code",
      "item_schema": {
        "type": "object",
        "required_keys": [
          "control_code",
          "source_ids",
          "check_code",
          "first_90_day_check"
        ],
        "properties": {
          "control_code": {
            "type": "enum",
            "allowed_values": [
              "AGE_CHECK",
              "LATE_NIGHT_DISORDER_MONITORING",
              "NO_AFTER_MIDNIGHT_SERVICE",
              "PATIO_LIMIT",
              "QUARTERLY_INSPECTION_CONDITION",
              "SECURITY_LOG",
              "SECURITY_PLAN_LAPSE_REVIEW"
            ]
          },
          "source_ids": {
            "type": "list",
            "item_type": "string",
            "ordering": "ascending source ID"
          },
          "check_code": {
            "type": "enum",
            "allowed_values": [
              "DEVICE_AUDIT",
              "PATROL_OBSERVATION",
              "POLICE_CALL_LOG_REVIEW",
              "SECURITY_LOG_REVIEW",
              "SERVICE_LOG_REVIEW",
              "SITE_INSPECTION"
            ]
          },
          "first_90_day_check": {
            "type": "boolean"
          }
        }
      }
    },
    "records_requests": {
      "type": "list",
      "ordering": "ascending request_code",
      "item_schema": {
        "type": "object",
        "required_keys": [
          "request_code",
          "source_ids"
        ],
        "properties": {
          "request_code": {
            "type": "enum",
            "allowed_values": [
              "AGE_VERIFICATION_DEVICE_AUDIT",
              "BREWPUB_STANDARD_OBLIGATION_EVIDENCE",
              "FIRST_90_DAY_INSPECTION_CALENDAR",
              "PENDING_INCIDENT_DISPOSITION_PACKET",
              "POLICE_CALL_LOG_HISTORY",
              "PRIOR_LICENSEE_SETTLEMENT_PACKET",
              "SUCCESSOR_OWNERSHIP_AND_SERVICE_AREA_STATEMENT"
            ]
          },
          "source_ids": {
            "type": "list",
            "item_type": "string",
            "ordering": "ascending source ID"
          }
        }
      }
    },
    "escalation_triggers": {
      "type": "list",
      "ordering": "ascending trigger_code",
      "item_schema": {
        "type": "object",
        "required_keys": [
          "trigger_code",
          "source_ids"
        ],
        "properties": {
          "trigger_code": {
            "type": "enum",
            "allowed_values": [
              "AGE_CHECK_AUDIT_MISSING_OR_FAILED",
              "FIRST_90_DAY_CHECK_MISSED",
              "NEW_OR_CONFIRMED_HIGH_SEVERITY_INCIDENT",
              "PENDING_INCIDENT_CONFIRMED_VIOLATION",
              "SUCCESSOR_LINK_CONFIRMED_TO_PRIOR_LICENSEE"
            ]
          },
          "source_ids": {
            "type": "list",
            "item_type": "string",
            "ordering": "ascending source ID"
          }
        }
      }
    }
  },
  "additional_properties_allowed": false
}
