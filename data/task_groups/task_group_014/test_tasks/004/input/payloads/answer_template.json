{
  "field_conventions": {
    "money_precision": "round dollars, paid_per_unit, benchmark_per_unit, benchmark_rate, and recovery amounts to 2 decimals",
    "ratio_precision": "round variance_pct to 4 decimal places",
    "underpayment_amount": "benchmark_amount minus paid_amount; include only material underpayment cells in underpaid_cells",
    "paid_rate_scope": "paid-rate metrics exclude denied or unpaid encounters from paid_units, paid_amount, paid_per_unit, and benchmark_amount",
    "recovery_scope": "open_recovery_amount includes open claim correction expected recovery; active_non_open_recovery_not_included_amount is tracked separately in correction_handling",
    "rate_join": "use the rate schedule active on the encounter service_date for payer, plan_type, service_category, CPT code, and state; avoid duplicate encounter inflation before aggregating",
    "ordering": "sort underpaid_cells by clinic_id, quarter, plan_type, service_category; sort rate_source_checks in the same order as audit_scope.rate_check_requests"
  },
