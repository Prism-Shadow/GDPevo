{
  "description": "Return one compensation summary JSON object. Currency values must be rounded to 2 decimals.",
  "required_top_level_keys": [
    "ensemble_id",
    "current_year",
    "roster_count",
    "pay_types",
    "quarter_totals",
    "annual_pay_type_totals",
    "annual_total",
    "largest_pay_type",
    "combined_overscale_employee_count",
    "partial_quarter_employee_count"
  ],
  "field_types": {
    "ensemble_id": "string",
    "current_year": "integer",
    "roster_count": "integer",
    "pay_types": "ordered list of pay type strings from the rate book",
    "quarter_totals": {
      "Q1": "currency",
      "Q2": "currency",
      "Q3": "currency",
      "Q4": "currency"
    },
    "annual_pay_type_totals": {
      "Minimum Weekly Scale": "currency",
      "Titled Position Premium": "currency",
      "Seniority": "currency",
      "Overscale": "currency"
    },
    "annual_total": "currency",
    "largest_pay_type": "enum: Minimum Weekly Scale, Titled Position Premium, Seniority, Overscale",
    "combined_overscale_employee_count": "integer",
    "partial_quarter_employee_count": "integer"
  }
}
