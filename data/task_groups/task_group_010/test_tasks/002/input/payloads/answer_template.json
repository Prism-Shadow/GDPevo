{
  "schema_name": "pf_int_orion_correlation_review",
  "schema_version": "1.0",
  "required_top_level_keys": [
    "portfolio_id",
    "as_of_date",
    "review_window",
    "index_set",
    "pair_calculations",
    "extreme_pairs",
    "concentration_flags",
    "diversification_actions",
    "hedging_next_step",
    "concentration_threshold_breached"
  ],
  "field_definitions": {
    "portfolio_id": {
      "type": "string",
      "required_value": "PF-INT-ORION"
    },
    "as_of_date": {
      "type": "string",
      "format": "YYYY-MM-DD"
    },
    "review_window": {
      "type": "object",
      "required_keys": [
        "level_start_date",
        "level_end_date",
        "return_observations"
      ],
      "field_types": {
        "level_start_date": "string date YYYY-MM-DD",
        "level_end_date": "string date YYYY-MM-DD",
        "return_observations": "integer"
      }
    },
    "index_set": {
      "type": "list[string]",
      "ordering": "ascending alphabetical by index id",
      "allowed_values": [
        "IDX_ACWI_IMI",
        "IDX_AC_ASIA_PAC_EX_JP",
        "IDX_AUSTRALIA",
        "IDX_CANADA",
        "IDX_CHINA",
        "IDX_EAFE",
        "IDX_EM",
        "IDX_EM_EX_CHINA",
        "IDX_EUROPE",
        "IDX_INDIA",
        "IDX_JAPAN",
        "IDX_LATAM",
        "IDX_UK",
        "IDX_WORLD"
      ]
    },
    "pair_calculations": {
      "type": "list[object]",
      "length": 91,
      "ordering": "ascending by pair_id values",
      "object_required_keys": [
        "pair_id",
        "correlation"
      ],
      "pair_id": {
        "type": "list[string]",
        "length": 2,
        "ordering": "ascending alphabetical by index id"
      },
      "correlation": {
        "type": "number",
        "precision": "three decimals"
      }
    },
    "extreme_pairs": {
      "type": "object",
      "required_keys": [
        "highest_positive",
        "lowest"
      ],
      "pair_object": {
        "required_keys": [
          "pair_id",
          "correlation"
        ],
        "pair_id": {
          "type": "list[string]",
          "length": 2,
          "ordering": "ascending alphabetical by index id"
        },
        "correlation": {
          "type": "number",
          "precision": "three decimals"
        }
      }
    },
    "concentration_flags": {
      "type": "object",
      "required_keys": [
        "china_asia_dependence_flag",
        "latin_america_diversification_flag",
        "primary_code",
        "high_threshold_breached"
      ],
      "field_types": {
        "china_asia_dependence_flag": "boolean",
        "latin_america_diversification_flag": "boolean",
        "primary_code": "enum",
        "high_threshold_breached": "boolean"
      },
      "primary_code_allowed_values": [
        "CHINA_ASIA_DEPENDENCE",
        "GLOBAL_DEVELOPED_OVERLAP",
        "NO_MATERIAL_CONCENTRATION"
      ]
    },
    "diversification_actions": {
      "type": "list[object]",
      "length": 3,
      "ordering": "ascending by sleeve",
      "object_required_keys": [
        "sleeve",
        "action",
        "target_index_id"
      ],
      "sleeve_allowed_values": [
        "China",
        "Emerging Markets",
        "India",
        "Latin America"
      ],
      "action_allowed_values": [
        "trim",
        "add",
        "hold",
        "hedge",
        "monitor",
        "rotate"
      ],
      "target_index_allowed_values": [
        "IDX_CHINA",
        "IDX_EM",
        "IDX_EM_EX_CHINA",
        "IDX_INDIA",
        "IDX_LATAM"
      ]
    },
    "hedging_next_step": {
      "type": "enum",
      "allowed_values": [
        "hedge_china_asia_beta",
        "hedge_global_beta_overlay",
        "monitor_only",
        "defer_pending_committee"
      ]
    },
    "concentration_threshold_breached": {
      "type": "boolean"
    }
  }
}
