{
  "description": "Required JSON shape for the NexaQueue North America commercial Q2 2026 qualified usage and expansion watchlist response.",
  "required_top_level_keys": [
    "schema_version",
    "product_id",
    "period",
    "segment",
    "region_scope",
    "qualified_account_count",
    "qualified_usage_rows",
    "total_compute_hours",
    "total_api_calls",
    "top_accounts",
    "low_adoption_accounts",
    "regional_breakdown",
    "excluded_row_counts"
  ],
  "field_definitions": {
    "schema_version": {
      "type": "string",
      "allowed_values": ["nexaqueue_na_commercial_q2_2026_v1"]
    },
    "product_id": {
      "type": "string",
      "allowed_values": ["NEXAQUEUE"]
    },
    "period": {
      "type": "object",
      "required_keys": ["start_date", "end_date"],
      "date_format": "YYYY-MM-DD"
    },
    "segment": {
      "type": "string",
      "allowed_values": ["commercial"]
    },
    "region_scope": {
      "type": "string",
      "allowed_values": ["NA"]
    },
    "qualified_account_count": {
      "type": "integer"
    },
    "qualified_usage_rows": {
      "type": "integer"
    },
    "total_compute_hours": {
      "type": "number",
      "precision": 2
    },
    "total_api_calls": {
      "type": "integer"
    },
    "top_accounts": {
      "type": "array",
      "ordering": "All qualified accounts ordered by compute_hours descending, then account_id ascending.",
      "item_required_keys": [
        "account_id",
        "account_name",
        "subscription_start_date",
        "subscription_end_date",
        "qualified_usage_rows",
        "compute_hours",
        "api_calls"
      ],
      "numeric_precision": {
        "compute_hours": 2
      }
    },
    "low_adoption_accounts": {
      "type": "array",
      "ordering": "Qualified accounts below the prompt threshold, ordered by compute_hours ascending, then account_id ascending.",
      "item_required_keys": [
        "account_id",
        "account_name",
        "compute_hours",
        "api_calls"
      ],
      "numeric_precision": {
        "compute_hours": 2
      }
    },
    "regional_breakdown": {
      "type": "array",
      "ordering": "Ordered by region ascending.",
      "item_required_keys": [
        "region",
        "account_count",
        "qualified_usage_rows",
        "compute_hours",
        "api_calls"
      ],
      "numeric_precision": {
        "compute_hours": 2
      }
    },
    "excluded_row_counts": {
      "type": "object",
      "required_keys": [
        "internal_or_test_account",
        "non_production_environment",
        "backfill",
        "telemetry_v1_shadowed",
        "outside_active_subscription"
      ],
      "value_type": "integer"
    }
  },
  "rounding": "Round compute_hours values to two decimal places. Counts and API calls must be integers."
}
