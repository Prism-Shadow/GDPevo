{
  "description": "Return one JSON object for the potassium replacement task.",
  "required_top_level_keys": [
    "patient_id",
    "primary_protocol",
    "current_time",
    "latest_potassium",
    "replacement_required",
    "dose_meq",
    "medication_order",
    "follow_up_lab",
    "ignored_observation_ids",
    "evidence_ids"
  ],
  "fields": {
    "patient_id": {"type": "string"},
    "primary_protocol": {"type": "enum", "allowed": ["POTASSIUM_REPLETION_2026"]},
    "current_time": {"type": "string", "format": "ISO-8601"},
    "latest_potassium": {
      "type": "object",
      "required": ["observation_id", "value_meq_l", "effectiveDateTime"],
      "fields": {
        "observation_id": {"type": "string"},
        "value_meq_l": {"type": "number", "precision": 1, "unit": "mEq/L"},
        "effectiveDateTime": {"type": "string", "format": "ISO-8601"}
      }
    },
    "replacement_required": {"type": "boolean"},
    "dose_meq": {"type": "integer", "unit": "mEq"},
    "medication_order": {
      "type": "object",
      "required": ["drug", "ndc", "route", "intent"],
      "fields": {
        "drug": {"type": "enum", "allowed": ["potassium chloride oral repletion"]},
        "ndc": {"type": "enum", "allowed": ["40032-917-01"]},
        "route": {"type": "enum", "allowed": ["oral"]},
        "intent": {"type": "enum", "allowed": ["order"]}
      }
    },
    "follow_up_lab": {
      "type": "object",
      "required": ["loinc", "display", "occurrenceDateTime", "priority"],
      "fields": {
        "loinc": {"type": "enum", "allowed": ["2823-3"]},
        "display": {"type": "enum", "allowed": ["Serum potassium"]},
        "occurrenceDateTime": {"type": "string", "format": "ISO-8601"},
        "priority": {"type": "enum", "allowed": ["routine_next_morning"]}
      }
    },
    "ignored_observation_ids": {"type": "list", "items": "string", "ordering": "sort_lexicographic"},
    "evidence_ids": {"type": "list", "items": "string", "ordering": "sort_lexicographic"}
  }
}
