{
  "description": "Return one JSON object for the respiratory protocol task.",
  "required_top_level_keys": [
    "case_id",
    "patient_id",
    "primary_protocol",
    "primary_assessment",
    "site_of_care",
    "severity_factors",
    "required_tests",
    "antibiotic_plan",
    "contraindicated_antibiotic_classes",
    "return_precautions",
    "evidence_ids"
  ],
  "fields": {
    "case_id": {"type": "string"},
    "patient_id": {"type": "string"},
    "primary_protocol": {"type": "enum", "allowed": ["RESP_ACUTE_2026"]},
    "primary_assessment": {"type": "enum", "allowed": ["community_acquired_pneumonia", "viral_upper_respiratory_infection", "copd_asthma_exacerbation", "ed_evaluation_required"]},
    "site_of_care": {"type": "enum", "allowed": ["outpatient_treatment", "same_day_clinic", "ed_evaluation", "supportive_care"]},
    "severity_factors": {
      "type": "list",
      "items_enum": ["confusion", "focal_crackles", "hypotension", "lobar_consolidation", "oxygen_92_to_94", "oxygen_below_92", "pleuritic_pain", "tachypnea"],
      "ordering": "sort_lexicographic"
    },
    "required_tests": {
      "type": "list",
      "items_enum": ["basic_metabolic_panel", "blood_culture_if_ed", "chest_xray", "covid_flu_testing", "pulse_ox_recheck"],
      "ordering": "sort_lexicographic"
    },
    "antibiotic_plan": {"type": "enum", "allowed": ["doxycycline", "respiratory_fluoroquinolone", "azithromycin", "no_antibiotic_protocol"]},
    "contraindicated_antibiotic_classes": {
      "type": "list",
      "items_enum": ["fluoroquinolone_qt_risk", "macrolide_qt_risk", "penicillin", "sulfonamide"],
      "ordering": "sort_lexicographic"
    },
    "return_precautions": {
      "type": "list",
      "items_enum": ["chest_pain", "confusion", "ed_now", "hemoptysis", "hypoxia", "persistent_fever_48_72h", "worsening_shortness_of_breath"],
      "ordering": "sort_lexicographic"
    },
    "evidence_ids": {"type": "list", "items": "string", "ordering": "sort_lexicographic"}
  }
}
