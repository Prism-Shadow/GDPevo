{
  "schema_name": "train_005_aquafarm_robotics_prospecting_answer",
  "schema_version": "1.0",
  "required_top_level_keys": [
    "show_id",
    "summary",
    "ranked_leads",
    "excluded_exhibitors"
  ],
  "field_spec": {
    "show_id": {
      "type": "string",
      "required_value": "aquafarm_robotics_2026"
    },
    "summary": {
      "type": "object",
      "required_keys": [
        "qualified_lead_count",
        "excluded_count",
        "existing_crm_overlap_count",
        "existing_crm_overlap_account_ids",
        "total_estimated_opportunity_usd",
        "platform_coverage_counts"
      ],
      "fields": {
        "qualified_lead_count": {
          "type": "integer",
          "units": "exhibitors"
        },
        "excluded_count": {
          "type": "integer",
          "units": "exhibitors"
        },
        "existing_crm_overlap_count": {
          "type": "integer",
          "units": "CRM accounts"
        },
        "existing_crm_overlap_account_ids": {
          "type": "list[string]",
          "ordering": "CRM account IDs ascending"
        },
        "total_estimated_opportunity_usd": {
          "type": "integer",
          "units": "USD"
        },
        "platform_coverage_counts": {
          "type": "object",
          "required_keys": [
            "AUV",
            "ROV",
            "Underwater Camera"
          ],
          "value_type": "integer"
        }
      }
    },
    "ranked_leads": {
      "type": "list[object]",
      "ordering": "rank ascending",
      "required_object_keys": [
        "rank",
        "company_id",
        "company_name",
        "booth",
        "country",
        "website",
        "platforms",
        "crm_account_id",
        "crm_action",
        "requested_demo",
        "interest_score",
        "priority_tier",
        "opportunity_estimate_usd"
      ],
      "fields": {
        "rank": {
          "type": "integer",
          "range": "1-based contiguous rank"
        },
        "company_id": {
          "type": "string"
        },
        "company_name": {
          "type": "string"
        },
        "booth": {
          "type": "string"
        },
        "country": {
          "type": "string"
        },
        "website": {
          "type": "string"
        },
        "platforms": {
          "type": "list[enum]",
          "allowed_values": [
            "AUV",
            "ROV",
            "Underwater Camera"
          ],
          "ordering": "AUV, ROV, Underwater Camera"
        },
        "crm_account_id": {
          "type": "string or null"
        },
        "crm_action": {
          "type": "enum",
          "allowed_values": [
            "create_account",
            "update_existing",
            "no_import"
          ]
        },
        "requested_demo": {
          "type": "boolean"
        },
        "interest_score": {
          "type": "integer"
        },
        "priority_tier": {
          "type": "enum",
          "allowed_values": [
            "A",
            "B",
            "C"
          ]
        },
        "opportunity_estimate_usd": {
          "type": "integer",
          "units": "USD"
        }
      }
    },
    "excluded_exhibitors": {
      "type": "list[object]",
      "ordering": "company_name ascending",
      "required_object_keys": [
        "company_id",
        "company_name",
        "relationship_type",
        "exclusion_reason",
        "crm_action"
      ],
      "fields": {
        "company_id": {
          "type": "string"
        },
        "company_name": {
          "type": "string"
        },
        "relationship_type": {
          "type": "enum",
          "allowed_values": [
            "distributor",
            "service_provider",
            "sensor_vendor",
            "research"
          ]
        },
        "exclusion_reason": {
          "type": "enum",
          "allowed_values": [
            "distributor_only",
            "service_only",
            "sensor_only",
            "research_only"
          ]
        },
        "crm_action": {
          "type": "enum",
          "allowed_values": [
            "no_import"
          ]
        }
      }
    }
  }
}
