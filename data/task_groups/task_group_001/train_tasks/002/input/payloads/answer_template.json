{
  "description": "Required JSON output shape for the MarineSense Expo 2026 OEM dissolved-oxygen sensor prospecting task.",
  "required_top_level_keys": [
    "show_id",
    "campaign",
    "qualified_exhibitors",
    "excluded_near_misses",
    "aggregate_counts"
  ],
  "fields": {
    "show_id": {
      "type": "string",
      "required_value": "marinesense_2026"
    },
    "campaign": {
      "type": "string",
      "required_value": "oem_dissolved_oxygen_sensor"
    },
    "qualified_exhibitors": {
      "type": "list",
      "ordering": "Sort by company_name ascending.",
      "item_type": "object",
      "required_item_keys": [
        "company_id",
        "company_name",
        "platforms",
        "priority_tier",
        "booth",
        "country",
        "website"
      ],
      "item_fields": {
        "company_id": {
          "type": "string",
          "source": "HarborCRM exhibitor company_id"
        },
        "company_name": {
          "type": "string",
          "source": "HarborCRM exhibitor company_name"
        },
        "platforms": {
          "type": "list",
          "item_type": "enum",
          "allowed_values": [
            "AUV",
            "ROV",
            "Underwater Camera"
          ],
          "ordering": "Sort in the enum order shown here."
        },
        "priority_tier": {
          "type": "enum",
          "allowed_values": [
            "A",
            "B",
            "C"
          ]
        },
        "booth": {
          "type": "string"
        },
        "country": {
          "type": "string"
        },
        "website": {
          "type": "string"
        }
      }
    },
    "excluded_near_misses": {
      "type": "list",
      "ordering": "Sort by company_name ascending.",
      "item_type": "object",
      "required_item_keys": [
        "company_id",
        "company_name",
        "exclusion_reason"
      ],
      "item_fields": {
        "company_id": {
          "type": "string",
          "source": "HarborCRM exhibitor company_id"
        },
        "company_name": {
          "type": "string",
          "source": "HarborCRM exhibitor company_name"
        },
        "exclusion_reason": {
          "type": "enum",
          "allowed_values": [
            "distributor_only",
            "service_only",
            "sensor_vendor_only",
            "research_only",
            "not_target_market"
          ]
        }
      }
    },
    "aggregate_counts": {
      "type": "object",
      "required_keys": [
        "qualified_total",
        "platform_counts",
        "priority_counts",
        "excluded_near_misses_total"
      ],
      "fields": {
        "qualified_total": {
          "type": "integer"
        },
        "platform_counts": {
          "type": "object",
          "required_keys": [
            "AUV",
            "ROV",
            "Underwater Camera"
          ],
          "value_type": "integer"
        },
        "priority_counts": {
          "type": "object",
          "required_keys": [
            "A",
            "B",
            "C"
          ],
          "value_type": "integer"
        },
        "excluded_near_misses_total": {
          "type": "integer"
        }
      }
    }
  },
  "numeric_precision": {
    "counts": "integers"
  },
  "response_rules": [
    "Return one JSON object only.",
    "Do not include explanatory prose outside the JSON object.",
    "Do not add fields not declared in this template."
  ]
}
