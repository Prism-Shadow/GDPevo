{
  "schema_name": "train_001_juniper_seller_apa_issue_register",
  "schema_version": "1.0",
  "language": "English only",
  "units": {
    "currency": "integer USD",
    "percent_points": "number rounded to two decimal places",
    "months": "integer months"
  },
  "allowed_enums": {
    "risk_rating": ["LOW", "MEDIUM", "HIGH"],
    "recommended_action": ["delete", "revise", "add", "accept", "escalate", "approve", "approve_with_conditions", "reject"],
    "issue_status": ["in_policy", "out_of_policy", "missing_required_term", "draft_exceeds_playbook", "draft_below_playbook"],
    "business_outcome": ["closing_certainty", "escrow_economics", "indemnity_exposure", "restrictive_covenants", "employee_transition", "tax_allocation", "governing_law", "regulatory_efforts"]
  },
  "possible_issue_ids": [
    "FINANCING_CONDITION",
    "REVERSE_BREAK_FEE",
    "ESCROW",
    "INDEMNITY_CAP",
    "INDEMNITY_BASKET",
    "SURVIVAL_PERIOD",
    "NON_COMPETE_NON_SOLICIT",
    "EMPLOYEE_CONTINUITY",
    "TRANSITION_SERVICES",
    "TAX_ALLOCATION",
    "GOVERNING_LAW_FORUM",
    "CONSENT_CONDITION",
    "MATERIALITY_SCRAPE",
    "HSR_COVENANT"
  ],
  "required_top_level_fields": {
    "deal_id": "string",
    "client_side": "string",
    "issue_register": "array of issue objects sorted by issue_id or by counsel workflow; each issue_id must be stable and unique",
    "priority_order": "array of issue_id strings from highest negotiation priority to lowest",
    "summary_metrics": "object"
  },
  "issue_object_fields": {
    "issue_id": "one value from possible_issue_ids",
    "source_term_ids": "array of term_id strings; use an empty array for missing required terms",
    "business_outcome": "one allowed business_outcome",
    "issue_status": "one allowed issue_status",
    "risk_rating": "one allowed risk_rating",
    "recommended_action": "one allowed recommended_action",
    "required_position_code": "short snake_case code for the seller position",
    "draft_percent": "number or null",
    "playbook_preferred_percent": "number or null",
    "playbook_fallback_percent": "number or null",
    "draft_amount_dollars": "integer or null",
    "preferred_amount_dollars": "integer or null",
    "fallback_amount_dollars": "integer or null",
    "delta_to_fallback_dollars": "integer or null",
    "draft_months": "integer or null",
    "preferred_months": "integer or null",
    "fallback_months": "integer or null",
    "delta_to_fallback_months": "integer or null",
    "required_fee_percent": "number or null",
    "required_fee_dollars": "integer or null",
    "shortfall_dollars": "integer or null",
    "employee_count": "integer or null",
    "pto_liability_dollars": "integer or null",
    "service_credit_required": "boolean or null",
    "field_selection_allowed": "boolean or null",
    "hell_or_high_water_required": "boolean or null",
    "hsr_required": "boolean or null",
    "regulatory_effort_code": "string or null",
    "tax_allocation_method": "string or null",
    "transfer_tax_split": "string or null",
    "governing_law": "string or null",
    "forum": "string or null",
    "covenant_limits": "object for restrictive covenant limits, or null"
  },
  "summary_metrics_fields": {
    "issue_count": "integer",
    "high_risk_count": "integer",
    "medium_risk_count": "integer",
    "business_outcome_count": "integer",
    "headline_value_dollars": "integer",
    "total_quantified_exposure_low_dollars": "integer",
    "total_quantified_exposure_high_dollars": "integer",
    "total_negotiation_delta_dollars": "integer",
    "required_closing_consent_count": "integer",
    "total_employee_count": "integer",
    "total_pto_liability_dollars": "integer"
  }
}
