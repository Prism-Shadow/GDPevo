{
  "deal_terms": {
    "deal_id": {
      "type": "string",
      "description": "Aster Legal deal identifier."
    },
    "structure": {
      "type": "enum",
      "allowed_values": ["STOCK_PURCHASE", "ASSET_PURCHASE", "MERGER"]
    },
    "target": {
      "type": "string",
      "description": "Exact target company name."
    },
    "buyer": {
      "type": "string",
      "description": "Exact buyer entity name."
    },
    "seller_group": {
      "type": "string",
      "description": "Exact seller group name from the deal record."
    },
    "signing_date": {
      "type": "string",
      "format": "YYYY-MM-DD"
    },
    "outside_closing_date": {
      "type": "string",
      "format": "YYYY-MM-DD"
    },
    "headline_purchase_price_usd": {
      "type": "integer",
      "units": "USD",
      "precision": "whole dollars"
    },
    "equity_value_usd": {
      "type": "integer",
      "units": "USD",
      "precision": "whole dollars"
    },
    "cash_at_close_usd": {
      "type": "integer",
      "units": "USD",
      "precision": "whole dollars"
    },
    "rollover_equity_usd": {
      "type": "integer",
      "units": "USD",
      "precision": "whole dollars"
    },
    "seller_note_usd": {
      "type": "integer",
      "units": "USD",
      "precision": "whole dollars"
    },
    "earnout_usd": {
      "type": "integer",
      "units": "USD",
      "precision": "whole dollars"
    },
    "active_cap_table_source_doc_id": {
      "type": "string",
      "description": "Document ID for the active cap table schedule used for allocations."
    },
    "active_cap_table_as_of": {
      "type": "string",
      "format": "YYYY-MM-DD"
    },
    "per_share_price_usd": {
      "type": "number or null",
      "units": "USD per share",
      "precision": "two decimal places if calculable",
      "description": "Use null if the active cap table does not provide a share count."
    },
    "per_share_price_basis": {
      "type": "enum",
      "allowed_values": ["CALCULATED_FROM_ACTIVE_CAP_TABLE", "NO_SHARE_COUNT_IN_ACTIVE_CAP_TABLE"]
    },
    "price_per_as_converted_percent_point_usd": {
      "type": "integer",
      "units": "USD per 1.00 ownership percentage point",
      "precision": "whole dollars"
    },
    "general_escrow_percent": {
      "type": "number",
      "units": "percent of headline value",
      "precision": "two decimal places"
    },
    "general_escrow_usd": {
      "type": "integer",
      "units": "USD",
      "precision": "whole dollars"
    },
    "general_escrow_policy_status": {
      "type": "enum",
      "allowed_values": ["WITHIN_POLICY", "ESCALATE", "NOT_APPLICABLE"]
    },
    "tax_escrow_percent": {
      "type": "number",
      "units": "percent of headline value",
      "precision": "two decimal places"
    },
    "tax_escrow_usd": {
      "type": "integer",
      "units": "USD",
      "precision": "whole dollars"
    },
    "tax_escrow_policy_status": {
      "type": "enum",
      "allowed_values": ["WITHIN_POLICY", "ESCALATE", "NOT_APPLICABLE"]
    },
    "indemnity_cap_percent": {
      "type": "number",
      "units": "percent of headline value",
      "precision": "two decimal places"
    },
    "basket_percent": {
      "type": "number",
      "units": "percent of headline value",
      "precision": "two decimal places"
    },
    "basket_type": {
      "type": "enum",
      "allowed_values": ["DEDUCTIBLE", "TIPPING", "NONE"]
    },
    "de_minimis_usd": {
      "type": "integer",
      "units": "USD",
      "precision": "whole dollars"
    },
    "nwc_target_usd": {
      "type": "integer",
      "units": "USD",
      "precision": "whole dollars"
    },
    "nwc_collar_usd": {
      "type": "integer",
      "units": "USD",
      "precision": "whole dollars"
    },
    "nwc_adjustment_mechanic": {
      "type": "enum",
      "allowed_values": ["DOLLAR_FOR_DOLLAR_OUTSIDE_COLLAR", "DOLLAR_FOR_DOLLAR_FROM_FIRST_DOLLAR", "NO_POST_CLOSING_ADJUSTMENT"]
    },
    "nwc_collar_percent_of_equity_value": {
      "type": "number",
      "units": "percent",
      "precision": "two decimal places"
    }
  },
  "seller_allocations": [
    {
      "seller_name": {
        "type": "string",
        "description": "Exact seller name from the active cap table."
      },
      "role": {
        "type": "string",
        "description": "Seller role from the active cap table."
      },
      "ownership_percent": {
        "type": "number",
        "units": "percent",
        "precision": "two decimal places"
      },
      "gross_proceeds_usd": {
        "type": "integer",
        "units": "USD",
        "precision": "whole dollars"
      }
    }
  ],
  "closing_flags": {
    "required_material_consents": [
      {
        "contract_name": {
          "type": "string",
          "description": "Exact contract name."
        },
        "annual_revenue_usd": {
          "type": "integer",
          "units": "USD",
          "precision": "whole dollars"
        },
        "condition_type": {
          "type": "enum",
          "allowed_values": ["CLOSING", "COVENANT", "NOTICE", "POST_CLOSING_NOTICE"]
        },
        "consent_required": {
          "type": "boolean"
        }
      }
    ],
    "consent_condition_status": {
      "type": "enum",
      "allowed_values": ["MATERIAL_CONSENTS_AS_CLOSING_CONDITIONS", "MATERIAL_CONSENTS_AS_POST_CLOSING_COVENANTS", "NO_MATERIAL_CONSENTS_REQUIRED"]
    },
    "hsr_required": {
      "type": "boolean"
    },
    "hsr_condition": {
      "type": "enum",
      "allowed_values": ["HSR_CLOSING_CONDITION", "NO_HSR_CONDITION_COOPERATION_ONLY", "NOT_ADDRESSED"]
    },
    "hsr_basis_code": {
      "type": "enum",
      "allowed_values": ["SIZE_OF_PERSON_TEST_NOT_MET", "REPORTABLE_THRESHOLDS_MET", "COUNSEL_MEMO_MISSING", "NOT_APPLICABLE"]
    },
    "other_regulatory_approvals": {
      "type": "list",
      "items": "string",
      "description": "List exact approval names, or an empty list if none."
    },
    "founder_employment_agreements_required": {
      "type": "boolean"
    },
    "employment_agreement_term_months": {
      "type": "integer",
      "units": "months"
    },
    "employment_employees": {
      "type": "list",
      "items": "string",
      "description": "Exact named employees tied to the employment agreements, sorted alphabetically by displayed name."
    },
    "non_compete_duration_months": {
      "type": "integer",
      "units": "months"
    },
    "non_compete_scope": {
      "type": "enum",
      "allowed_values": ["TARGET_PRODUCTS_AND_CURRENT_TERRITORIES", "WORLDWIDE_ALL_AFFILIATES", "NO_NON_COMPETE", "OTHER_LIMITED_SCOPE"]
    },
    "broad_affiliate_covenant_allowed": {
      "type": "boolean"
    },
    "transition_services_required": {
      "type": "boolean"
    },
    "ip_assignment_confirmation_required": {
      "type": "boolean"
    }
  },
  "ordering_rules": {
    "seller_allocations": "Sort by seller_name ascending.",
    "required_material_consents": "Sort by contract_name ascending.",
    "employment_employees": "Sort by displayed employee name ascending."
  }
}
