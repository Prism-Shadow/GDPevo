{
  "schema_name": "buyer_hybrid_review_escalation_v1",
  "response_rule": "Return a single JSON object only. Do not include markdown or explanatory prose.",
  "numeric_conventions": {
    "currency_fields": "Integer US dollars, no commas or currency symbols.",
    "percent_fields": "Number rounded to two decimal places, expressed as percentage points, e.g. 12.50.",
    "month_fields": "Integer number of months.",
    "not_applicable": "Use null for numeric fields that do not apply."
  },
  "list_conventions": {
    "reviewed_terms": "Include each currently material reviewed term once. Sort by term_id ascending.",
    "source_doc_ids": "Sort document identifiers ascending.",
    "condition_codes": "Sort condition codes ascending.",
    "terms_requiring_escalation": "Sort term_id values ascending.",
    "terms_within_playbook": "Sort term_id values ascending.",
    "approval_conditions": "Sort by condition_id ascending.",
    "primary_driver_term_ids": "Sort term_id values ascending."
  },
  "top_level_required_keys": {
    "deal_id": {
      "type": "string",
      "required_value": "D-KEPLER-155"
    },
    "review_type": {
      "type": "enum",
      "allowed_values": [
        "BUYER_HYBRID_REVIEW_ESCALATION"
      ]
    },
    "currency": {
      "type": "enum",
      "allowed_values": [
        "USD"
      ]
    },
    "reviewed_terms": {
      "type": "list<object>"
    },
    "committee_packet": {
      "type": "object"
    }
  },
  "reviewed_term_object_required_keys": {
    "term_id": {
      "type": "enum",
      "allowed_values": [
        "ESCROW",
        "GOVERNANCE",
        "HSR",
        "INDEMNITY_CAP",
        "IP_TRANSITION",
        "MATERIAL_CONSENTS",
        "NONCOMPETE",
        "ROLLOVER",
        "TAX_ESCROW",
        "WORKING_CAPITAL"
      ]
    },
    "source_clause_id": {
      "type": "string or null"
    },
    "policy_rule_id": {
      "type": "string or null"
    },
    "review_status": {
      "type": "enum",
      "allowed_values": [
        "ESCALATION_REQUIRED",
        "NO_ISSUE",
        "OUT_OF_SCOPE",
        "WITHIN_PLAYBOOK",
        "WITHIN_PLAYBOOK_FALLBACK"
      ]
    },
    "escalation_required": {
      "type": "boolean"
    },
    "committee_route": {
      "type": "enum",
      "allowed_values": [
        "INVESTMENT_COMMITTEE",
        "LEGAL_RISK_COMMITTEE",
        "NO_COMMITTEE_ROUTE"
      ]
    },
    "deviation_code": {
      "type": "enum",
      "allowed_values": [
        "ABOVE_CAP_THRESHOLD",
        "ABOVE_ROLLOVER_MISMATCH_THRESHOLD",
        "FOUNDER_ORDINARY_COURSE_VETO",
        "HSR_NOT_REQUIRED",
        "MATERIAL_CONSENT_REQUIRED",
        "NO_DEVIATION",
        "OUT_OF_SCOPE",
        "WITHIN_ESCROW_FALLBACK",
        "WITHIN_NONCOMPETE_FALLBACK",
        "WITHIN_TAX_ESCROW_RANGE"
      ]
    },
    "severity": {
      "type": "enum",
      "allowed_values": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "approval_recommendation": {
      "type": "enum",
      "allowed_values": [
        "APPROVE_AS_DRAFTED",
        "APPROVE_WITH_CONDITIONS",
        "DO_NOT_APPROVE_AS_DRAFTED",
        "NO_APPROVAL_NEEDED"
      ]
    },
    "recommended_position": {
      "type": "enum",
      "allowed_values": [
        "ACCEPT_AS_DRAFTED",
        "ACCEPT_WITHIN_FALLBACK",
        "CONFIRM_CONSENT_AS_CLOSING_CONDITION",
        "KEEP_NO_HSR_CONDITION",
        "REMOVE_ORDINARY_COURSE_VETOES",
        "REQUIRE_IP_PERMISSION_CONFIRMATION",
        "CAP_REQUIRED_POSITION",
        "ROLLOVER_REQUIRED_POSITION",
        "REVISE_WORKING_CAPITAL_ONLY"
      ]
    },
    "condition_codes": {
      "type": "list<enum>",
      "allowed_values": [
        "COMMITTEE_APPROVES_ILLIQUIDITY_DISCOUNT",
        "DOCUMENT_REVENUE_RECOGNITION_DILIGENCE",
        "CAP_CONDITION_POSITION",
        "KEEP_LIMITED_SAAS_ANALYTICS_SCOPE",
        "PRICE_REDUCTION_IF_DISCOUNT_RETAINED",
        "REMOVE_BUDGET_AND_ORDINARY_COURSE_DEBT_VETOES",
        "ROLLOVER_CONDITION_POSITION",
        "TAX_EXPOSURE_IDENTIFIED"
      ]
    },
    "quantification": {
      "type": "object"
    },
    "source_doc_ids": {
      "type": "list<string>"
    }
  },
  "quantification_allowed_fields": {
    "calculation_base": {
      "type": "enum",
      "allowed_values": [
        "HEADLINE_VALUE",
        "ROLLOVER_EQUITY_VALUE",
        "GOVERNANCE_RIGHTS",
        "FOUNDER_EMPLOYMENT",
        "NONE"
      ]
    },
    "draft_percent": {
      "type": "number or null",
      "precision": "two decimal percentage points"
    },
    "fallback_percent": {
      "type": "number or null",
      "precision": "two decimal percentage points"
    },
    "policy_threshold_percent": {
      "type": "number or null",
      "precision": "two decimal percentage points"
    },
    "deviation_percent": {
      "type": "number or null",
      "precision": "two decimal percentage points"
    },
    "draft_amount_usd": {
      "type": "integer or null",
      "unit": "USD"
    },
    "fallback_amount_usd": {
      "type": "integer or null",
      "unit": "USD"
    },
    "excess_amount_usd": {
      "type": "integer or null",
      "unit": "USD"
    },
    "exposure_amount_usd": {
      "type": "integer or null",
      "unit": "USD"
    },
    "exposure_basis": {
      "type": "enum",
      "allowed_values": [
        "DRAFT_AMOUNT",
        "POLICY_THRESHOLD_EXCESS",
        "NON_QUANTIFIED_CONTROL_RISK",
        "NONE"
      ]
    },
    "draft_months": {
      "type": "integer or null"
    },
    "max_months": {
      "type": "integer or null"
    },
    "debt_threshold_usd": {
      "type": "integer or null",
      "unit": "USD"
    },
    "benchmark_id": {
      "type": "string or null"
    },
    "benchmark_sample_size": {
      "type": "integer or null"
    },
    "benchmark_count_above_threshold": {
      "type": "integer or null"
    }
  },
  "committee_packet_schema": {
    "policy_id": {
      "type": "string"
    },
    "committee_route": {
      "type": "enum",
      "allowed_values": [
        "INVESTMENT_COMMITTEE",
        "LEGAL_RISK_COMMITTEE",
        "NO_COMMITTEE_ROUTE"
      ]
    },
    "approval_required": {
      "type": "boolean"
    },
    "committee_members": {
      "type": "list<string>",
      "description": "Use names exactly as shown in the Deal Desk committee record."
    },
    "committee_source_doc_id": {
      "type": "string or null"
    },
    "terms_requiring_escalation": {
      "type": "list<enum>",
      "allowed_values": [
        "ESCROW",
        "GOVERNANCE",
        "HSR",
        "INDEMNITY_CAP",
        "IP_TRANSITION",
        "MATERIAL_CONSENTS",
        "NONCOMPETE",
        "ROLLOVER",
        "TAX_ESCROW",
        "WORKING_CAPITAL"
      ]
    },
    "terms_within_playbook": {
      "type": "list<enum>",
      "allowed_values": [
        "ESCROW",
        "GOVERNANCE",
        "HSR",
        "INDEMNITY_CAP",
        "IP_TRANSITION",
        "MATERIAL_CONSENTS",
        "NONCOMPETE",
        "ROLLOVER",
        "TAX_ESCROW",
        "WORKING_CAPITAL"
      ]
    },
    "reviewed_term_count": {
      "type": "integer"
    },
    "escalation_term_count": {
      "type": "integer"
    },
    "within_playbook_term_count": {
      "type": "integer"
    },
    "aggregate_risk_tier": {
      "type": "enum",
      "allowed_values": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "final_action": {
      "type": "enum",
      "allowed_values": [
        "ESCALATE_AND_APPROVE_AS_DRAFTED",
        "ESCALATE_AND_RENEGOTIATE_BEFORE_SIGNING",
        "ESCALATE_FOR_INFORMATION_ONLY",
        "NO_ESCALATION"
      ]
    },
    "primary_driver_term_ids": {
      "type": "list<enum>",
      "allowed_values": [
        "ESCROW",
        "GOVERNANCE",
        "HSR",
        "INDEMNITY_CAP",
        "IP_TRANSITION",
        "MATERIAL_CONSENTS",
        "NONCOMPETE",
        "ROLLOVER",
        "TAX_ESCROW",
        "WORKING_CAPITAL"
      ]
    },
    "total_quantified_exposure_usd": {
      "type": "integer",
      "unit": "USD"
    },
    "total_policy_excess_usd": {
      "type": "integer",
      "unit": "USD"
    },
    "approval_conditions": {
      "type": "list<object>",
      "item_schema": {
        "condition_id": {
          "type": "string",
          "description": "Neutral condition label chosen by the solver, such as CONDITION_001. Do not encode the substantive answer in this label."
        },
        "term_id": {
          "type": "enum",
          "allowed_values": [
            "ESCROW",
            "GOVERNANCE",
            "HSR",
            "INDEMNITY_CAP",
            "IP_TRANSITION",
            "MATERIAL_CONSENTS",
            "NONCOMPETE",
            "ROLLOVER",
            "TAX_ESCROW",
            "WORKING_CAPITAL"
          ]
        },
        "required_state": {
          "type": "enum",
          "allowed_values": [
            "ACCEPT_AS_DRAFTED",
            "ACCEPT_WITHIN_FALLBACK",
            "CAP_CONDITION_POSITION",
            "CAP_REQUIRED_POSITION",
            "COMMITTEE_APPROVES_ILLIQUIDITY_DISCOUNT",
            "CONFIRM_CONSENT_AS_CLOSING_CONDITION",
            "DOCUMENT_REVENUE_RECOGNITION_DILIGENCE",
            "DOCUMENT_REVENUE_RECOGNITION_DILIGENCE_OR_DEAL_LEAD_CONFIRMATION",
            "IP_PERMISSION_CONFIRMED",
            "KEEP_LIMITED_SAAS_ANALYTICS_SCOPE",
            "KEEP_NO_HSR_CONDITION",
            "LIMITED_NONCOMPETE_SCOPE_CONFIRMED",
            "MATERIAL_CONSENT_CLOSING_CONDITION_CONFIRMED",
            "NO_HSR_FILING_CONDITION_CONFIRMED",
            "PRICE_REDUCTION_IF_DISCOUNT_RETAINED",
            "REMOVE_BUDGET_AND_ORDINARY_COURSE_DEBT_VETOES",
            "REMOVE_ORDINARY_COURSE_VETOES",
            "REQUIRE_IP_PERMISSION_CONFIRMATION",
            "REVISE_WORKING_CAPITAL_ONLY",
            "ROLLOVER_CONDITION_POSITION",
            "ROLLOVER_CONDITION_POSITION_OR_PRICE_REDUCTION",
            "ROLLOVER_REQUIRED_POSITION",
            "TAX_EXPOSURE_IDENTIFIED",
            "WORKING_CAPITAL_TERMS_ACCEPTED"
          ]
        }
      }
    },
    "strategic_context": {
      "type": "object",
      "schema": {
        "batna_code": {
          "type": "enum",
          "allowed_values": [
            "LOWER_HEADLINE_PRICE_AVAILABLE",
            "NO_CLEAR_BATNA",
            "WALK_AWAY_TO_ALT_TARGET"
          ]
        },
        "ownership_context": {
          "type": "enum",
          "allowed_values": [
            "FOUNDER_GOVERNANCE_PRESSURE",
            "FUND_SELLER_CASH_CERTAINTY",
            "MANAGEMENT_ROLLOVER_ONLY"
          ]
        },
        "strategic_rationale": {
          "type": "enum",
          "allowed_values": [
            "CONTROL_INVESTMENT_WITH_MEANINGFUL_ROLLOVER",
            "NON_STRATEGIC_ADD_ON",
            "PURE_FINANCIAL_BUY"
          ]
        },
        "benchmark_memo_required": {
          "type": "boolean"
        }
      }
    }
  }
}
