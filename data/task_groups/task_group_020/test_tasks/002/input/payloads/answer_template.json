{
  "schema_name": "seller_apa_counterparty_paper_review_v2",
  "response_rule": "Return a single JSON object only. Do not include markdown or explanatory prose.",
  "top_level_required_keys": {
    "deal_id": {
      "type": "string",
      "required_value": "D-QUARTZ-311"
    },
    "review_type": {
      "type": "enum",
      "allowed_values": [
        "SELLER_APA_COUNTERPARTY_PAPER_REVIEW"
      ]
    },
    "policy_id": {
      "type": "string",
      "description": "Controlling playbook or policy identifier used for the review."
    },
    "currency": {
      "type": "enum",
      "allowed_values": [
        "USD"
      ]
    },
    "issues": {
      "type": "list<object>",
      "ordering": "Sort by rank ascending. Include each material issue once. Omit non-material distractors."
    },
    "summary": {
      "type": "object",
      "description": "Compact structured summary of the issue register."
    }
  },
  "issue_object_required_keys": {
    "issue_id": {
      "type": "enum",
      "allowed_values": [
        "CLOSING_DEADLINE",
        "EMPLOYEE_TSA_WARN",
        "ESCROW_TERMS",
        "FINANCING_FEE",
        "IP_TRANSITION",
        "MAE_CARVE_OUTS",
        "MATERIAL_CONSENTS",
        "RESTRICTIVE_COVENANT",
        "SURVIVAL_CAP_BASKET_DE_MINIMIS",
        "WORKING_CAPITAL"
      ]
    },
    "rank": {
      "type": "integer",
      "description": "Risk priority rank, starting at 1 for the highest-priority issue."
    },
    "severity": {
      "type": "enum",
      "allowed_values": [
        "CRITICAL",
        "HIGH",
        "MEDIUM",
        "LOW"
      ]
    },
    "recommended_action": {
      "type": "enum",
      "allowed_values": [
        "ACCEPT",
        "ADD",
        "ADD_AND_ESCALATE",
        "DELETE",
        "DELETE_AND_ADD_FALLBACK_FEE",
        "NARROW_AND_ESCALATE",
        "NO_ISSUE",
        "REDUCE_OR_ESCALATE",
        "REVISE",
        "REVISE_AND_ESCALATE"
      ]
    },
    "approval_owners": {
      "type": "list<enum>",
      "allowed_values": [
        "DEAL_LEAD",
        "EXECUTIVE_COMMITTEE",
        "HR_COMMITTEE",
        "IP_COUNSEL",
        "OPERATIONS_COMMITTEE",
        "SELLER_STEERING_COMMITTEE"
      ],
      "ordering": "Sort alphabetically."
    },
    "corrected_terms": {
      "type": "object",
      "description": "Use only the normalized fields relevant to the issue. Currency amounts are integer dollars. Percentages are decimal percentage points rounded to two decimals, not fractions."
    },
    "source_ids": {
      "type": "list<string>",
      "description": "Document, policy, clause, or benchmark IDs supporting the conclusion. This field is for auditability, not prose."
    }
  },
  "corrected_terms_allowed_fields": {
    "financing_condition_allowed": {
      "type": "boolean"
    },
    "reverse_fee_fallback_only": {
      "type": "boolean"
    },
    "fee_base": {
      "type": "enum",
      "allowed_values": [
        "HEADLINE_VALUE",
        "EQUITY_VALUE",
        "NONE"
      ]
    },
    "reverse_fee_percent": {
      "type": "number",
      "precision": "two decimal percentage points"
    },
    "reverse_fee_amount_usd": {
      "type": "integer",
      "unit": "USD"
    },
    "parent_guarantee_required": {
      "type": "boolean"
    },
    "financing_condition_must_still_be_deleted": {
      "type": "boolean"
    },
    "draft_escrow_percent": {
      "type": "number",
      "precision": "two decimal percentage points"
    },
    "draft_escrow_amount_usd": {
      "type": "integer",
      "unit": "USD"
    },
    "target_escrow_percent": {
      "type": "number",
      "precision": "two decimal percentage points"
    },
    "target_escrow_amount_usd": {
      "type": "integer",
      "unit": "USD"
    },
    "fallback_escrow_percent": {
      "type": "number",
      "precision": "two decimal percentage points"
    },
    "fallback_escrow_amount_usd": {
      "type": "integer",
      "unit": "USD"
    },
    "draft_release_months": {
      "type": "integer"
    },
    "target_release_months": {
      "type": "integer"
    },
    "escrow_above_fallback_requires_escalation": {
      "type": "boolean"
    },
    "escrow_longer_than_survival_allowed": {
      "type": "boolean"
    },
    "draft_seller_rep_survival_months": {
      "type": "integer"
    },
    "target_seller_rep_survival_months": {
      "type": "integer"
    },
    "draft_general_cap_percent": {
      "type": "number",
      "precision": "two decimal percentage points"
    },
    "draft_general_cap_amount_usd": {
      "type": "integer",
      "unit": "USD"
    },
    "target_general_cap_percent": {
      "type": "number",
      "precision": "two decimal percentage points"
    },
    "target_general_cap_amount_usd": {
      "type": "integer",
      "unit": "USD"
    },
    "fallback_general_cap_percent": {
      "type": "number",
      "precision": "two decimal percentage points"
    },
    "fallback_general_cap_amount_usd": {
      "type": "integer",
      "unit": "USD"
    },
    "basket_percent": {
      "type": "number",
      "precision": "two decimal percentage points"
    },
    "basket_amount_usd": {
      "type": "integer",
      "unit": "USD"
    },
    "basket_type": {
      "type": "enum",
      "allowed_values": [
        "DEDUCTIBLE",
        "TIPPING",
        "NONE"
      ]
    },
    "de_minimis_required": {
      "type": "boolean"
    },
    "tipping_allowed": {
      "type": "boolean"
    },
    "buyer_comparable_offer_required": {
      "type": "boolean"
    },
    "warn_liability": {
      "type": "enum",
      "allowed_values": [
        "BUYER_FOR_TRANSFERRED_EMPLOYEES",
        "SELLER",
        "ALLOCATED_BY_STATUTE",
        "NOT_APPLICABLE"
      ]
    },
    "seller_warn_retention_allowed": {
      "type": "boolean"
    },
    "tsa_required": {
      "type": "boolean"
    },
    "tsa_status_required": {
      "type": "enum",
      "allowed_values": [
        "DETAILED_EXHIBIT",
        "SHORT_FORM_PLACEHOLDER",
        "NONE"
      ]
    },
    "tsa_service_codes": {
      "type": "list<enum>",
      "allowed_values": [
        "CHARGEBACK_SUPPORT",
        "COMPLIANCE_REPORTING",
        "KYC_OPERATIONS",
        "PROCESSOR_MIGRATION"
      ],
      "ordering": "Sort alphabetically."
    },
    "unqualified_bank_sponsor_loss_trigger_allowed": {
      "type": "boolean"
    },
    "materiality_qualifier_required": {
      "type": "boolean"
    },
    "buyer_control_exception_required": {
      "type": "boolean"
    },
    "standard_market_carveouts_required": {
      "type": "boolean"
    },
    "mae_position": {
      "type": "enum",
      "allowed_values": [
        "MATERIALITY_AND_BUYER_CONTROL_EXCEPTIONS",
        "ACCEPT_COUNTERPARTY_TRIGGER",
        "DELETE_MAE_CONDITION"
      ]
    },
    "perpetual_mark_use_allowed": {
      "type": "boolean"
    },
    "broad_source_repository_access_allowed": {
      "type": "boolean"
    },
    "transition_license_required": {
      "type": "boolean"
    },
    "retained_ip_boundaries_required": {
      "type": "boolean"
    },
    "trademark_phaseout_months": {
      "type": "integer"
    },
    "source_repository_access_scope": {
      "type": "enum",
      "allowed_values": [
        "LIMITED_TRANSITION_ACCESS",
        "BROAD_REPOSITORY_ACCESS",
        "NO_ACCESS"
      ]
    }
  },
  "summary_required_keys": {
    "material_issue_count": {
      "type": "integer"
    },
    "critical_issue_count": {
      "type": "integer"
    },
    "highest_priority_issue_id": {
      "type": "enum",
      "allowed_values": [
        "CLOSING_DEADLINE",
        "EMPLOYEE_TSA_WARN",
        "ESCROW_TERMS",
        "FINANCING_FEE",
        "IP_TRANSITION",
        "MAE_CARVE_OUTS",
        "MATERIAL_CONSENTS",
        "RESTRICTIVE_COVENANT",
        "SURVIVAL_CAP_BASKET_DE_MINIMIS",
        "WORKING_CAPITAL"
      ]
    },
    "issue_priority_order": {
      "type": "list<enum>",
      "allowed_values": [
        "CLOSING_DEADLINE",
        "EMPLOYEE_TSA_WARN",
        "ESCROW_TERMS",
        "FINANCING_FEE",
        "IP_TRANSITION",
        "MAE_CARVE_OUTS",
        "MATERIAL_CONSENTS",
        "RESTRICTIVE_COVENANT",
        "SURVIVAL_CAP_BASKET_DE_MINIMIS",
        "WORKING_CAPITAL"
      ],
      "ordering": "Highest risk to lowest risk."
    },
    "committee_escalation_required": {
      "type": "boolean"
    },
    "committee_escalation_owners": {
      "type": "list<enum>",
      "allowed_values": [
        "DEAL_LEAD",
        "EXECUTIVE_COMMITTEE",
        "HR_COMMITTEE",
        "IP_COUNSEL",
        "OPERATIONS_COMMITTEE",
        "SELLER_STEERING_COMMITTEE"
      ],
      "ordering": "Sort alphabetically."
    }
  }
}
