    "active_clause_ids": {
      "type": "list",
      "items": "string",
      "description": "Active clause IDs used as clause-level cross-checks; sort alphabetically."
    },
    "template_conflict_clause_ids": {
      "type": "list",
      "items": "string",
      "description": "Stale or template clause IDs rejected as controlling sources; sort alphabetically."
    },
    "superseded_doc_ids": {
      "type": "list",
      "items": "string",
      "description": "Stale or template document IDs rejected as controlling sources; sort alphabetically."
    }
  },
