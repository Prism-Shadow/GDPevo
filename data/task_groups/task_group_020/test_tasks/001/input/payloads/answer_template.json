  "ordering_rules": {
    "seller_allocations": "Sort by seller_name ascending.",
    "required_material_consents": "Sort by contract_name ascending.",
    "employment_employees": "Sort by displayed employee name ascending.",
    "source_precedence.decisions": "Sort by decision_id ascending.",
    "policy_checks.checks": "Sort by check_id ascending.",
    "risk_posture_flags.conditional_escalation_details": "Sort by trigger_code ascending.",
    "all_string_lists": "Sort alphabetically unless a field description states otherwise."
  }
}
