        "measured_value_code": {
          "type": "enum",
          "allowed_values": [
            "BASKET_POLICY_POSITION",
            "CAP_POLICY_POSITION",
            "CONSENTS_POLICY_POSITION",
            "ESCROW_POLICY_POSITION",
            "HSR_POLICY_POSITION",
            "NONCOMPETE_POLICY_POSITION",
            "NWC_POLICY_POSITION"
          ]
        }
      }
    ],
    "policy_summary": {
      "approval_required_now": {
        "type": "boolean"
      },
      "current_policy_exception_count": {
        "type": "integer"
      },
      "required_approval_bodies": {
        "type": "list",
        "items": "enum",
        "allowed_values": [
          "DEAL_LEAD",
          "EMPLOYMENT_COUNSEL",
          "FINANCE_COMMITTEE",
          "LEGAL_RISK_COMMITTEE",
          "REGULATORY_COUNSEL"
        ],
        "description": "Approval bodies required for current active terms; sort alphabetically."
      },
      "conditional_escalation_triggers": {
        "type": "list",
        "items": "enum",
        "allowed_values": [
          "CONSENT_TIMING_TRIGGER",
          "ALLOCATION_SOURCE_TRIGGER",
          "FINANCING_CONDITION_TRIGGER",
          "BASKET_THRESHOLD_TRIGGER",
          "RESTRICTIVE_COVENANT_SCOPE_TRIGGER",
          "GENERAL_ESCROW_THRESHOLD_TRIGGER",
          "TAX_ESCROW_THRESHOLD_TRIGGER",
          "HSR_ANALYSIS_TRIGGER",
          "CAP_THRESHOLD_TRIGGER",
          "NWC_VERIFICATION_TRIGGER"
        ],
        "description": "Escalation triggers that would apply only if the seller changes the current active posture; sort alphabetically."
      }
    },
    "risk_memo_overrides": {
      "source_doc_ids": {
        "type": "list",
        "items": "string",
        "description": "Active instruction, schedule, or memo document IDs supporting overrides; sort alphabetically."
      },
      "override_codes": {
        "type": "list",
        "items": "enum",
        "allowed_values": [
          "ACTIVE_CLIENT_INSTRUCTIONS_SUPERSEDE_TEMPLATE",
          "REQUIRE_HSR_CONDITION_PER_COUNSEL_MEMO",
          "USE_ACTIVE_CAP_TABLE_OVER_STALE_EXPORT",
          "USE_ACTIVE_FINANCIAL_SCHEDULE_OVER_TEMPLATE",
          "USE_ACTIVE_MATERIAL_CONTRACT_SCHEDULE",
          "USE_ACTIVE_DRAFT_OVER_TEMPLATE",
          "USE_CURRENT_DISCLOSURE_SCHEDULE",
          "NO_RISK_MEMO_OVERRIDE"
        ],
        "description": "Sort alphabetically."
      },
      "superseded_doc_ids": {
        "type": "list",
        "items": "string",
        "description": "Stale or template document IDs displaced by active instructions; sort alphabetically."
      },
      "hsr_override_basis": {
        "type": "enum",
        "allowed_values": [
          "REPORTABLE_THRESHOLDS_MET_PER_ANTITRUST_MEMO",
          "THRESHOLDS_NOT_MET_AFTER_DEBT_ADJUSTMENTS",
          "SIZE_OF_PERSON_NOT_MET",
          "COUNSEL_MEMO_MISSING",
          "UNKNOWN"
        ]
      }
