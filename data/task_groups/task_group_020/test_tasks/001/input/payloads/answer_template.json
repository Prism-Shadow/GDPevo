    "per_share_price_basis": {
      "type": "enum",
      "allowed_values": [
        "CALCULATED_FROM_ACTIVE_CAP_TABLE",
        "NO_SHARE_COUNT_IN_ACTIVE_CAP_TABLE"
      ]
    },
    "price_per_as_converted_percent_point_usd": {
      "type": "integer",
      "units": "USD per 1.00 ownership percentage point",
      "precision": "whole dollars"
    },
    "general_escrow_percent": {
      "type": "number",
      "units": "percent of headline value",
      "precision": "two decimal places"
    },
    "general_escrow_usd": {
      "type": "integer",
      "units": "USD",
      "precision": "whole dollars"
    },
    "general_escrow_policy_status": {
      "type": "enum",
      "allowed_values": [
        "WITHIN_POLICY",
        "APPROVAL_REQUIRED",
        "ESCALATE",
        "NOT_APPLICABLE"
      ]
    },
    "tax_escrow_percent": {
      "type": "number",
      "units": "percent of headline value",
      "precision": "two decimal places"
    },
    "tax_escrow_usd": {
      "type": "integer",
      "units": "USD",
      "precision": "whole dollars"
    },
    "tax_escrow_policy_status": {
      "type": "enum",
      "allowed_values": [
        "WITHIN_POLICY",
        "APPROVAL_REQUIRED",
        "ESCALATE",
        "NOT_APPLICABLE"
      ]
    },
    "indemnity_cap_percent": {
      "type": "number",
      "units": "percent of headline value",
      "precision": "two decimal places"
    },
    "indemnity_cap_usd": {
      "type": "integer",
      "units": "USD",
      "precision": "whole dollars"
    },
    "basket_percent": {
      "type": "number",
      "units": "percent of headline value",
      "precision": "two decimal places"
    },
    "basket_usd": {
      "type": "integer",
      "units": "USD",
      "precision": "whole dollars"
    },
    "basket_type": {
      "type": "enum",
      "allowed_values": [
        "DEDUCTIBLE",
        "TIPPING",
        "NONE"
      ]
    },
    "de_minimis_usd": {
      "type": "integer",
      "units": "USD",
      "precision": "whole dollars"
    },
    "nwc_target_usd": {
      "type": "integer",
      "units": "USD",
      "precision": "whole dollars"
    },
    "nwc_collar_usd": {
      "type": "integer",
      "units": "USD",
      "precision": "whole dollars"
    },
    "nwc_adjustment_mechanic": {
      "type": "enum",
      "allowed_values": [
        "DOLLAR_FOR_DOLLAR_OUTSIDE_COLLAR",
        "TRUE_UP_AGAINST_ACTIVE_BALANCE_SHEET",
        "DOLLAR_FOR_DOLLAR_FROM_FIRST_DOLLAR",
        "NO_POST_CLOSING_ADJUSTMENT"
      ]
    },
    "nwc_collar_percent_of_equity_value": {
      "type": "number",
      "units": "percent",
      "precision": "two decimal places"
    }
  },
  "seller_allocations": [
    {
      "seller_name": {
        "type": "string",
        "description": "Exact seller name from the active cap table."
      },
      "role": {
        "type": "string",
        "description": "Seller role from the active cap table."
      },
      "ownership_percent": {
        "type": "number",
        "units": "percent",
        "precision": "two decimal places"
      },
      "gross_proceeds_usd": {
        "type": "integer",
        "units": "USD",
        "precision": "whole dollars"
      }
    }
  ],
  "closing_flags": {
    "required_material_consents": [
      {
        "contract_name": {
          "type": "string",
          "description": "Exact material contract name."
        },
        "annual_revenue_usd": {
          "type": "integer or null",
          "units": "USD",
          "precision": "whole dollars"
        },
        "condition_type": {
          "type": "enum",
          "allowed_values": [
            "CLOSING",
            "COVENANT",
            "NOTICE",
            "POST_CLOSING_NOTICE"
          ]
        },
        "consent_required": {
          "type": "boolean"
        },
        "source_doc_id": {
          "type": "string",
          "description": "Document ID supporting the consent treatment."
        }
      }
    ],
    "post_closing_notice_items": {
      "type": "list",
      "items": "string",
      "description": "Contract or license names accepted as post-closing notice items; sort alphabetically."
    },
    "consent_condition_status": {
      "type": "enum",
      "allowed_values": [
        "MATERIAL_CONSENTS_AS_CLOSING_CONDITIONS",
        "MATERIAL_CONSENTS_AS_POST_CLOSING_COVENANTS",
        "NO_MATERIAL_CONSENTS_REQUIRED"
      ]
    },
    "hsr_required": {
      "type": "boolean"
    },
    "hsr_condition": {
      "type": "enum",
      "allowed_values": [
        "HSR_CLOSING_CONDITION",
        "HSR_DRAFTING_POSITION",
        "NOT_ADDRESSED"
      ]
    },
    "hsr_basis_code": {
      "type": "enum",
      "allowed_values": [
        "SIZE_OF_PERSON_TEST_NOT_MET",
        "REPORTABLE_THRESHOLDS_MET",
        "COUNSEL_MEMO_MISSING",
        "NOT_APPLICABLE"
      ]
    },
    "hsr_source_doc_id": {
      "type": "string",
      "description": "Document ID supporting the HSR treatment."
    },
    "other_regulatory_approvals": {
      "type": "list",
      "items": "string",
      "description": "List exact approval names, or an empty list if none; sort alphabetically."
    },
    "founder_employment_agreements_required": {
      "type": "boolean"
    },
    "employment_agreement_term_months": {
      "type": "integer or null",
      "units": "months",
      "description": "Use null if the source records require agreements but do not specify a duration."
    },
    "employment_employees": {
      "type": "list",
      "items": "string",
      "description": "Exact named employees tied to the employment agreements, sorted alphabetically by displayed name."
    },
    "employment_source_doc_id": {
      "type": "string",
      "description": "Document ID supporting the employment and non-compete treatment."
    },
    "non_compete_duration_months": {
      "type": "integer",
      "units": "months"
    },
    "non_compete_scope": {
      "type": "enum",
      "allowed_values": [
        "TARGET_PRODUCTS_AND_CURRENT_TERRITORIES",
        "TARGET_PRODUCTS_ONLY",
        "WORLDWIDE_ALL_AFFILIATES",
        "NO_NON_COMPETE",
        "OTHER_LIMITED_SCOPE"
      ]
    },
    "broad_affiliate_covenant_allowed": {
      "type": "boolean"
    },
    "transition_services_required": {
      "type": "boolean"
    },
    "ip_assignment_confirmation_required": {
      "type": "boolean"
    },
    "risk_posture_flags": {
      "allocation_position": {
        "type": "enum",
        "allowed_values": [
          "ACTIVE_CAP_TABLE_CONTROLS",
          "STALE_CAP_TABLE_CONTROLS",
          "COUNTERPARTY_ALLOCATION_CONTROLS"
        ]
      },
      "stale_cap_table_reliance_position": {
        "type": "enum",
        "allowed_values": [
          "ESCALATE_IF_USED",
          "ACCEPT_IF_NO_NEWER_SCHEDULE",
          "NOT_RELEVANT"
        ]
      },
      "template_clause_position": {
        "type": "enum",
        "allowed_values": [
          "DO_NOT_USE_TEMPLATE_PROVISIONS",
          "USE_STANDARD_FORM_DEFAULTS",
          "TEMPLATE_CONTROLS_IF_DRAFT_SILENT"
        ]
      },
      "top_customer_post_close_position": {
        "type": "enum",
        "allowed_values": [
          "ESCALATE_IF_TOP_CUSTOMERS_MOVED_POST_CLOSE",
          "POST_CLOSING_NOTICE_ACCEPTABLE",
          "NO_CUSTOMER_CONSENT_RISK"
        ]
      },
      "approval_required_now": {
        "type": "boolean"
      },
      "current_policy_exception_count": {
        "type": "integer"
      },
      "conditional_escalation_triggers": {
        "type": "list",
        "items": "enum",
        "allowed_values": [
          "FINANCING_CONDITION_TRIGGER",
          "BASKET_THRESHOLD_TRIGGER",
          "RESTRICTIVE_COVENANT_SCOPE_TRIGGER",
          "GENERAL_ESCROW_THRESHOLD_TRIGGER",
          "CONSENT_TIMING_TRIGGER",
          "ALLOCATION_SOURCE_TRIGGER",
          "TAX_ESCROW_THRESHOLD_TRIGGER",
          "HSR_ANALYSIS_TRIGGER"
        ],
        "description": "Conditional triggers that are not triggered by the current draft; sort alphabetically."
      },
      "non_triggered_policy_thresholds": {
        "type": "list",
        "items": "enum",
        "allowed_values": [
          "BASKET_THRESHOLD_TRIGGER",
          "RESTRICTIVE_COVENANT_SCOPE_TRIGGER",
          "CAP_THRESHOLD_TRIGGER",
          "GENERAL_ESCROW_THRESHOLD_TRIGGER",
          "TAX_ESCROW_THRESHOLD_TRIGGER",
          "HSR_ANALYSIS_TRIGGER",
          "NWC_VERIFICATION_TRIGGER"
        ],
        "description": "Policy thresholds reviewed but not triggered by the current active terms; sort alphabetically."
      },
      "conditional_escalation_details": [
        {
          "trigger_code": {
            "type": "enum",
            "allowed_values": [
              "CONSENT_TIMING_TRIGGER",
              "ALLOCATION_SOURCE_TRIGGER"
            ]
          },
          "current_status": {
            "type": "enum",
            "allowed_values": [
              "NOT_TRIGGERED",
              "TRIGGERED"
            ]
          },
          "affected_items": {
            "type": "list",
            "items": "string",
            "description": "Exact affected contracts, documents, or issue objects; sort alphabetically."
          },
          "source_doc_ids": {
            "type": "list",
            "items": "string",
            "description": "Source document IDs supporting this conditional trigger; sort alphabetically."
          },
          "posture": {
            "type": "enum",
            "allowed_values": [
              "ESCALATE_IF_PROPOSED",
              "ACCEPT_IF_PROPOSED",
              "ALREADY_ESCALATED"
            ]
          }
        }
      ],
      "superseded_doc_ids": {
        "type": "list",
        "items": "string",
        "description": "Stale or template document IDs not used as controlling sources; sort alphabetically."
      }
    }
  },
  "source_precedence": {
    "decisions": [
      {
        "decision_id": {
          "type": "enum",
