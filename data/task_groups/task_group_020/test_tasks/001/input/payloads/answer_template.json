            "WITHIN_POLICY",
            "APPROVAL_REQUIRED",
            "OVERRIDE_APPLIED",
            "ESCALATE_IF_CHANGED"
          ]
        },
        "approval_required": {
          "type": "boolean"
        },
        "approval_category": {
          "type": "enum",
          "allowed_values": [
