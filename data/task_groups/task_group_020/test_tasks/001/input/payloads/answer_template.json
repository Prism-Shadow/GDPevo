{
  "deal_terms": {
    "deal_id": {
      "type": "string",
      "description": "Aster Legal deal identifier."
    },
    "structure": {
      "type": "enum",
      "allowed_values": [
        "STOCK_PURCHASE",
        "ASSET_PURCHASE",
        "MERGER",
        "ROLLOVER_STOCK_PURCHASE"
      ]
    },
    "target": {
      "type": "string",
      "description": "Exact target company name."
    },
    "buyer": {
      "type": "string",
      "description": "Exact buyer entity name."
    },
    "seller_group": {
      "type": "string",
      "description": "Exact seller group name from the deal record."
    },
    "signing_date": {
      "type": "string",
      "format": "YYYY-MM-DD"
    },
    "outside_closing_date": {
      "type": "string",
      "format": "YYYY-MM-DD"
    },
    "headline_purchase_price_usd": {
      "type": "integer",
      "units": "USD",
      "precision": "whole dollars"
    },
    "equity_value_usd": {
      "type": "integer",
      "units": "USD",
      "precision": "whole dollars"
    },
    "cash_at_close_usd": {
      "type": "integer",
      "units": "USD",
      "precision": "whole dollars"
    },
    "rollover_equity_usd": {
      "type": "integer",
      "units": "USD",
      "precision": "whole dollars"
    },
    "seller_note_usd": {
      "type": "integer",
      "units": "USD",
      "precision": "whole dollars"
    },
    "earnout_usd": {
      "type": "integer",
      "units": "USD",
      "precision": "whole dollars"
    },
    "active_cap_table_source_doc_id": {
      "type": "string",
      "description": "Document ID for the controlling active cap table or allocation schedule."
    },
    "active_cap_table_as_of": {
      "type": "string",
      "format": "YYYY-MM-DD"
    },
    "per_share_price_usd": {
      "type": "number or null",
