{
  "description": "Required JSON output for the AX17 tail-lamp variant modular change request.",
  "top_level_required_keys": [
    "change_request_id",
    "program_id",
    "contract_id",
    "sku",
    "supplier_id",
    "variant_code",
    "decision",
    "contract_check",
    "program_budget_check",
    "approval_check",
    "supplier_risk_check",
    "supporting_ids",
    "required_actions",
    "summary"
  ],
  "field_rules": {
    "decision": {
      "type": "enum",
      "allowed": [
        "release_amendment",
        "hold_for_budget",
        "hold_for_approval",
        "hold_for_supplier_risk",
        "hold_for_budget_and_approval",
        "reject_contract_mismatch"
      ]
    },
    "currency_amounts": "numbers rounded to cents",
    "contract_check": {
      "required_keys": [
        "contract_status",
        "price_type",
        "unit_price",
        "ceiling_amount",
        "noncancelled_subtotal",
        "headroom_before_change",
        "requested_quantity",
        "requested_subtotal",
        "headroom_after_change",
        "ceiling_ok"
      ]
    },
    "program_budget_check": {
      "required_keys": [
        "snapshot_id",
        "budget_cap",
        "committed_amount",
        "remaining_budget",
        "requested_tax",
        "requested_total",
        "budget_after_change",
        "budget_ok",
        "max_quantity_with_current_budget"
      ]
    },
    "approval_check": {
      "required_keys": [
        "source_requisition_id",
        "latest_event_id",
        "latest_action",
        "latest_actor",
        "latest_event_date",
        "approval_ok"
      ]
    },
    "supplier_risk_check": {
      "required_keys": [
        "supplier_status",
        "supplier_risk_rating",
        "open_event_ids",
        "severe_open_event_ids",
        "supplier_risk_ok"
      ],
      "list_ordering": "sort event IDs ascending"
    },
    "supporting_ids": {
      "required_keys": [
        "included_po_ids",
        "excluded_cancelled_po_ids",
        "approval_event_ids"
      ],
      "list_ordering": "sort IDs ascending"
    },
    "required_actions": {
      "type": "list",
      "item_type": "enum",
      "allowed": [
        "obtain_final_requisition_approval",
        "raise_budget_exception_or_reduce_quantity",
        "resolve_supplier_risk_hold",
        "none"
      ],
      "ordering": "sort ascending"
    },
    "summary": {
      "required_keys": [
        "blocker_count",
        "currency",
        "ready_to_release"
      ]
    }
  }
}
