{
  "type": "object",
  "required_top_level_keys": [
    "task_id",
    "campaign_id",
    "plan_date",
    "campaign_targets",
    "component_plan",
    "transfer_requests",
    "purchase_requisitions",
    "excluded_components",
    "summary"
  ],
  "fields": {
    "task_id": {
      "type": "string",
      "required_value": "test_002"
    },
    "campaign_id": {
      "type": "string",
      "required_value": "SERVICE_PARTS_JUNE_26"
    },
    "plan_date": {
      "type": "string",
      "format": "YYYY-MM-DD"
    },
    "campaign_targets": {
      "type": "list",
      "ordering": "Sort by warehouse_id ascending, then bom_id ascending.",
      "item_required_keys": [
        "bom_id",
        "kit_name",
        "warehouse_id",
        "build_quantity",
        "needed_by"
      ],
      "field_types": {
        "bom_id": "string",
        "kit_name": "string",
        "warehouse_id": {
          "type": "enum",
          "allowed_values": [
            "WH_CENTRAL",
            "WH_NORTH",
            "WH_WEST"
          ]
        },
        "build_quantity": "integer units",
        "needed_by": "YYYY-MM-DD"
      }
    },
    "component_plan": {
      "type": "list",
      "ordering": "Sort by target_warehouse_id ascending, then sku ascending.",
      "item_required_keys": [
        "sku",
        "target_warehouse_id",
        "bom_id",
        "total_required",
        "target_effective_available",
        "timely_po_qty",
        "coverage_po_ids",
        "late_po_ids",
        "transfer_qty",
        "purchase_requisition_qty",
        "final_action",
        "exclusion_reason"
      ],
      "field_types": {
        "sku": "string",
        "target_warehouse_id": {
          "type": "enum",
          "allowed_values": [
            "WH_CENTRAL",
            "WH_NORTH",
            "WH_WEST"
          ]
        },
        "bom_id": "string",
        "total_required": "integer units",
        "target_effective_available": "integer units",
        "timely_po_qty": "integer units from eligible same-warehouse open or confirmed purchase orders with ETA on or before needed_by",
        "coverage_po_ids": "list of strings sorted ascending",
        "late_po_ids": "list of same-warehouse open or confirmed purchase order ids with ETA after needed_by, sorted ascending",
        "transfer_qty": "integer units",
        "purchase_requisition_qty": "integer units",
        "final_action": {
          "type": "enum",
          "allowed_values": [
            "no_action_stocked",
            "transfer_only",
            "purchase_required",
            "timely_po_covered",
            "overstock_excluded"
          ]
        },
        "exclusion_reason": {
          "type": "enum",
          "allowed_values": [
            "none",
            "stocked_no_gap",
            "target_overstock",
            "timely_po_covers_gap"
          ]
        }
      }
    },
    "transfer_requests": {
      "type": "list",
      "ordering": "Sort by sku ascending, then to_warehouse_id ascending, then quantity descending, then from_warehouse_id ascending.",
      "item_required_keys": [
        "sku",
        "from_warehouse_id",
        "to_warehouse_id",
        "quantity",
        "needed_by"
      ],
      "field_types": {
        "sku": "string",
        "from_warehouse_id": {
          "type": "enum",
          "allowed_values": [
            "WH_CENTRAL",
            "WH_NORTH",
            "WH_WEST"
          ]
        },
        "to_warehouse_id": {
          "type": "enum",
          "allowed_values": [
            "WH_CENTRAL",
            "WH_NORTH",
            "WH_WEST"
          ]
        },
        "quantity": "integer units",
        "needed_by": "YYYY-MM-DD"
      }
    },
    "purchase_requisitions": {
      "type": "list",
      "ordering": "Sort by warehouse_id ascending, then sku ascending.",
      "item_required_keys": [
        "sku",
        "supplier_id",
        "warehouse_id",
        "quantity",
        "needed_by",
        "unit_cost",
        "extended_cost"
      ],
      "field_types": {
        "sku": "string",
        "supplier_id": "string",
        "warehouse_id": {
          "type": "enum",
          "allowed_values": [
            "WH_CENTRAL",
            "WH_NORTH",
            "WH_WEST"
          ]
        },
        "quantity": "integer units",
        "needed_by": "YYYY-MM-DD",
        "unit_cost": "number, currency rounded to 2 decimals",
        "extended_cost": "number, currency rounded to 2 decimals"
      }
    },
    "excluded_components": {
      "type": "list",
      "ordering": "Sort by target_warehouse_id ascending, then sku ascending.",
      "item_required_keys": [
        "sku",
        "target_warehouse_id",
        "reason",
        "supporting_po_ids"
      ],
      "field_types": {
        "sku": "string",
        "target_warehouse_id": {
          "type": "enum",
          "allowed_values": [
            "WH_CENTRAL",
            "WH_NORTH",
            "WH_WEST"
          ]
        },
        "reason": {
          "type": "enum",
          "allowed_values": [
            "stocked_no_gap",
            "target_overstock",
            "timely_po_covers_gap"
          ]
        },
        "supporting_po_ids": "list of strings sorted ascending"
      }
    },
    "summary": {
      "type": "object",
      "required_keys": [
        "component_count",
        "purchase_requisition_count",
        "total_purchase_units",
        "total_purchase_cost",
        "total_transfer_units",
        "timely_po_covered_units",
        "excluded_component_count",
        "warehouse_purchase_units"
      ],
      "field_types": {
        "component_count": "integer component/target rows",
        "purchase_requisition_count": "integer",
        "total_purchase_units": "integer units",
        "total_purchase_cost": "number, currency rounded to 2 decimals",
        "total_transfer_units": "integer units",
        "timely_po_covered_units": "integer units of demand gap covered by timely purchase orders",
        "excluded_component_count": "integer",
        "warehouse_purchase_units": {
          "type": "object",
          "required_keys": [
            "WH_CENTRAL",
            "WH_NORTH"
          ],
          "field_types": {
            "WH_CENTRAL": "integer units",
            "WH_NORTH": "integer units"
          }
        }
      }
    }
  }
}
