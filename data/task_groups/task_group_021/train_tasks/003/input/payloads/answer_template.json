{
  "description": "Required JSON shape for the SEA_Q3_2026 shipment cost integrity audit.",
  "output_type": "object",
  "required_top_level_keys": [
    "wave_id",
    "effective_event_count",
    "duplicate_business_key_count",
    "invalid_event_ids",
    "invalid_event_issue_types",
    "corrected_total_usd",
    "cost_type_totals_usd",
    "top_lane_by_cost",
    "unit_correction_counts",
    "issue_type_counts",
    "amended_event_ids_used",
    "decision_audit"
  ],
  "field_specs": {
    "wave_id": {
      "type": "string",
      "description": "Target logistics wave identifier."
    },
    "effective_event_count": {
      "type": "integer",
      "description": "Count of effective records included in corrected USD aggregation."
    },
    "duplicate_business_key_count": {
      "type": "integer",
      "description": "Count of business keys with more than one non-void, non-invalid effective candidate after amendment handling."
    },
    "invalid_event_ids": {
      "type": "array",
      "items": "string",
      "ordering": "ascending by event_id",
      "description": "Event IDs excluded for invalid data values, excluding ordinary voided or superseded records."
    },
    "invalid_event_issue_types": {
      "type": "array",
      "ordering": "ascending by event_id",
      "items": {
        "type": "object",
        "required_keys": [
          "event_id",
          "issue_types"
        ],
        "field_specs": {
          "event_id": {
            "type": "string"
          },
          "issue_types": {
            "type": "array",
            "items": {
              "type": "enum",
              "allowed_values": [
                "invalid_negative_amount",
                "missing_amount",
                "invalid_unit",
                "invalid_currency"
              ]
            },
            "ordering": "template enum order"
          }
        }
      }
    },
    "corrected_total_usd": {
      "type": "number",
      "precision": "2 decimal places",
      "unit": "USD",
      "description": "Corrected wave total after line-level USD conversion to cents."
    },
    "cost_type_totals_usd": {
      "type": "object",
      "required_keys": [
        "freight",
        "accessorial",
        "tax_fee",
        "claim"
      ],
      "value_type": "number",
      "precision": "2 decimal places",
      "unit": "USD",
      "cost_type_enum": [
        "freight",
        "accessorial",
        "tax_fee",
        "claim"
      ]
    },
    "top_lane_by_cost": {
      "type": "object",
      "required_keys": [
        "lane",
        "amount_usd"
      ],
      "field_specs": {
        "lane": {
          "type": "string"
        },
        "amount_usd": {
          "type": "number",
          "precision": "2 decimal places",
          "unit": "USD"
        }
      }
    },
    "unit_correction_counts": {
      "type": "object",
      "description": "Counts of included effective events by controlled source unit after integrity exclusions.",
      "required_keys": [
        "kg",
        "lb",
        "mile",
        "shipment",
        "claim"
      ],
      "value_type": "integer",
      "unit_enum": [
        "kg",
        "lb",
        "mile",
        "shipment",
        "claim"
      ]
    },
    "issue_type_counts": {
      "type": "object",
      "required_keys": [
        "invalid_negative_amount",
        "missing_amount",
        "invalid_unit",
        "invalid_currency",
        "void_record",
        "amended_record",
        "duplicate_business_key",
        "non_usd_currency",
        "advisory_note"
      ],
      "value_type": "integer",
      "issue_type_enum": [
        "invalid_negative_amount",
        "missing_amount",
        "invalid_unit",
        "invalid_currency",
        "void_record",
        "amended_record",
        "duplicate_business_key",
        "non_usd_currency",
        "advisory_note"
      ]
    },
    "amended_event_ids_used": {
      "type": "array",
      "items": "string",
      "ordering": "ascending by event_id",
      "description": "Amendment event IDs that replace an earlier event in the effective set."
    },
    "decision_audit": {
      "type": "object",
      "required_keys": [
        "void_event_ids",
        "amended_event_ids",
        "superseded_event_ids",
        "non_usd_sample_event_ids"
      ],
      "field_specs": {
        "void_event_ids": {
          "type": "array",
          "items": "string",
          "ordering": "ascending by event_id"
        },
        "amended_event_ids": {
          "type": "array",
          "items": "string",
          "ordering": "ascending by event_id"
        },
        "superseded_event_ids": {
          "type": "array",
          "items": "string",
          "ordering": "ascending by event_id"
        },
        "non_usd_sample_event_ids": {
          "type": "array",
          "items": "string",
          "ordering": "ascending by event_id",
          "description": "First ten non-USD source event IDs in ascending event_id order among non-void events with an amount."
        }
      }
    }
  },
  "numeric_rules": {
    "currency_conversion": "Use the USD conversion rates exposed by the environment quality-rule reference.",
    "rounding": "Round each included cost event's converted USD amount to cents before aggregation; report all USD numbers with exactly two decimal places."
  },
  "additional_properties": false
}
