{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "January fuel-purchase normalization audit answer",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "audit_summary",
    "mismatch_transaction_ids",
    "unrecognized_transaction_ids",
    "normalized_totals",
    "focus_assets",
    "policy_decision_panel",
    "reconciliation_status"
  ],
  "properties": {
    "audit_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "collection_id",
        "cutoff_at",
        "authoritative_snapshot_id",
        "raw_row_count",
        "logical_transaction_count",
        "duplicate_raw_count",
        "valid_transaction_count",
        "mismatch_count",
        "unrecognized_count",
        "ambiguous_count",
        "invalid_quantity_count",
        "exception_transaction_count",
        "exception_merchant_ranking"
      ],
      "properties": {
        "collection_id": {
          "type": "string",
          "description": "Stable collection identifier."
        },
        "cutoff_at": {
          "type": "string",
          "format": "date-time",
          "description": "Audit cutoff in ISO-8601 UTC."
        },
        "authoritative_snapshot_id": {
          "type": "string",
          "description": "Stable ID of the authoritative snapshot used to resolve overlapping logical transactions."
        },
        "raw_row_count": {
          "type": "integer",
          "minimum": 0
        },
        "logical_transaction_count": {
          "type": "integer",
          "minimum": 0
        },
        "duplicate_raw_count": {
          "type": "integer",
          "minimum": 0
        },
        "valid_transaction_count": {
          "type": "integer",
          "minimum": 0
        },
        "mismatch_count": {
          "type": "integer",
          "minimum": 0
        },
        "unrecognized_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Count with no recognized canonical category."
        },
        "ambiguous_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Count matching more than one canonical category."
        },
        "invalid_quantity_count": {
          "type": "integer",
          "minimum": 0
        },
        "exception_transaction_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Distinct logical transactions with a category mismatch or quarantine condition."
        },
        "exception_merchant_ranking": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "description": "Ordered by exception_count descending, then merchant_id ascending.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "merchant_id",
              "exception_count",
              "mismatch_count",
              "quarantine_count"
            ],
            "properties": {
              "merchant_id": {
                "type": "string"
              },
              "exception_count": {
                "type": "integer",
                "minimum": 0
              },
              "mismatch_count": {
                "type": "integer",
                "minimum": 0
              },
              "quarantine_count": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        }
      }
    },
    "mismatch_transaction_ids": {
      "type": "array",
      "uniqueItems": true,
      "description": "All expected-versus-actual category mismatch transaction IDs, sorted lexicographically.",
      "items": {
        "type": "string"
      }
    },
    "unrecognized_transaction_ids": {
      "type": "array",
      "uniqueItems": true,
      "description": "All transaction IDs whose description has no unique recognized category, including zero-match and ambiguous cases, sorted lexicographically.",
      "items": {
        "type": "string"
      }
    },
    "normalized_totals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "valid_transaction_count",
        "total_volume_l",
        "total_spend_usd",
        "fuel_type_totals"
      ],
      "properties": {
        "valid_transaction_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_volume_l": {
          "type": "number",
          "description": "Liters, rounded to 2 decimal places."
        },
        "total_spend_usd": {
          "type": "number",
          "description": "USD, rounded to 2 decimal places."
        },
        "fuel_type_totals": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "description": "Exactly one row per fuel_type, sorted by fuel_type ascending.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "fuel_type",
              "transaction_count",
              "volume_l",
              "spend_usd"
            ],
            "properties": {
              "fuel_type": {
                "type": "string",
                "enum": [
                  "BIODIESEL",
                  "DIESEL",
                  "ELECTRIC_CHARGE",
                  "PREMIUM_UNLEADED",
                  "UNLEADED"
                ]
              },
              "transaction_count": {
                "type": "integer",
                "minimum": 0
              },
              "volume_l": {
                "type": "number",
                "description": "Liters, rounded to 2 decimal places."
              },
              "spend_usd": {
                "type": "number",
                "description": "USD, rounded to 2 decimal places."
              }
            }
          }
        }
      }
    },
    "focus_assets": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "description": "Exactly the requested focus assets, sorted by asset_id ascending.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "asset_id",
          "logical_transaction_count",
          "valid_transaction_count",
          "mismatch_count",
          "quarantine_count",
          "exception_count",
          "volume_l",
          "spend_usd"
        ],
        "properties": {
          "asset_id": {
            "type": "string"
          },
          "logical_transaction_count": {
            "type": "integer",
            "minimum": 0
          },
          "valid_transaction_count": {
            "type": "integer",
            "minimum": 0
          },
          "mismatch_count": {
            "type": "integer",
            "minimum": 0
          },
          "quarantine_count": {
            "type": "integer",
            "minimum": 0
          },
          "exception_count": {
            "type": "integer",
            "minimum": 0
          },
          "volume_l": {
            "type": "number",
            "description": "Liters, rounded to 2 decimal places."
          },
          "spend_usd": {
            "type": "number",
            "description": "USD, rounded to 2 decimal places."
          }
        }
      }
    },
    "policy_decision_panel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reference_decisions",
        "transaction_decisions"
      ],
      "properties": {
        "reference_decisions": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "description": "Exactly the requested references, sorted by reference_id ascending.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "reference_id",
              "reference_policy_code"
            ],
            "properties": {
              "reference_id": {
                "type": "string"
              },
              "reference_policy_code": {
                "type": "string",
                "enum": [
                  "RB-17",
                  "RB-42",
                  "RB-83"
                ]
              }
            }
          }
        },
        "transaction_decisions": {
          "type": "array",
          "minItems": 12,
          "maxItems": 12,
          "description": "Exactly the requested transactions, sorted by transaction_id ascending.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "transaction_id",
              "source_basis_code",
              "ledger_disposition_code"
            ],
            "properties": {
              "transaction_id": {
                "type": "string"
              },
              "source_basis_code": {
                "type": "string",
                "enum": [
                  "SB-24",
                  "SB-61",
                  "SB-79"
                ]
              },
              "ledger_disposition_code": {
                "type": "string",
                "enum": [
                  "LD-14",
                  "LD-31",
                  "LD-53",
                  "LD-72",
                  "LD-88"
                ]
              }
            }
          }
        }
      }
    },
    "reconciliation_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "action"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "PASS_WITH_EXCEPTIONS",
            "HOLD"
          ]
        },
        "action": {
          "type": "string",
          "enum": [
            "RELEASE",
            "REVIEW_EXCEPTIONS",
            "BLOCK_AND_REMEDIATE"
          ]
        }
      }
    }
  }
}
