{
  "description": "Required JSON output for train_005 facilities west August 2026 charge cleanup.",
  "required_top_level_keys": [
    "scope",
    "effective_charge_count",
    "invalid_charge_ids",
    "superseded_charge_ids",
    "category_counts",
    "spend_by_category_usd",
    "top_vendor_by_adjusted_spend",
    "review_reason_counts",
    "canonical_charge_sample"
  ],
  "controlled_enums": {
    "category": [
      "fuel",
      "maintenance",
      "freight",
      "accessorial",
      "claim",
      "tax_fee",
      "unknown"
    ],
    "review_reason": [
      "duplicate",
      "invalid_amount",
      "invalid_unit",
      "missing_contact_channel",
      "suppressed_contact",
      "ambiguous_alias",
      "superseded",
      "source_conflict"
    ]
  },
  "schema": {
    "scope": {
      "type": "object",
      "required_keys": {
        "scope_id": "string",
        "period": "string in YYYY-MM format",
        "currency": "string, use USD"
      }
    },
    "effective_charge_count": {
      "type": "integer",
      "description": "Count of charges retained for adjusted spend reporting after invalid and superseded records are removed."
    },
    "invalid_charge_ids": {
      "type": "list[string]",
      "ordering": "ascending by charge_id"
    },
    "superseded_charge_ids": {
      "type": "list[string]",
      "ordering": "ascending by charge_id"
    },
    "category_counts": {
      "type": "object",
      "required_keys": [
        "fuel",
        "maintenance",
        "freight",
        "accessorial",
        "claim",
        "tax_fee",
        "unknown"
      ],
      "value_type": "integer"
    },
    "spend_by_category_usd": {
      "type": "object",
      "required_keys": [
        "fuel",
        "maintenance",
        "freight",
        "accessorial",
        "claim",
        "tax_fee",
        "unknown"
      ],
      "value_type": "number",
      "precision": "USD rounded to two decimal places"
    },
    "top_vendor_by_adjusted_spend": {
      "type": "object",
      "required_keys": {
        "vendor": "string",
        "adjusted_spend_usd": "number, USD rounded to two decimal places",
        "effective_charge_count": "integer",
        "charge_ids": "list[string], ascending by charge_id"
      }
    },
    "review_reason_counts": {
      "type": "object",
      "required_keys": [
        "duplicate",
        "invalid_amount",
        "invalid_unit",
        "missing_contact_channel",
        "suppressed_contact",
        "ambiguous_alias",
        "superseded",
        "source_conflict"
      ],
      "value_type": "integer"
    },
    "canonical_charge_sample": {
      "type": "list[object]",
      "ordering": "ascending by charge_id",
      "item_required_keys": {
        "charge_id": "string",
        "business_key": "string",
        "vendor": "string",
        "canonical_category": "category enum",
        "adjusted_amount_usd": "number, USD rounded to two decimal places",
        "review_reasons": "list[review_reason enum], ascending by enum label"
      }
    }
  }
}
