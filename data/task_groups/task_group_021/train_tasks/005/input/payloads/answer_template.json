{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "February freight-charge cleanup and accrual reconciliation answer",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "audit_summary",
    "class_mismatch_charge_ids",
    "quarantine_charge_ids",
    "duplicate_groups",
    "decision_panels",
    "normalized_totals",
    "carrier_ranking",
    "close_status"
  ],
  "properties": {
    "audit_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "collection_id",
        "cutoff_at",
        "authoritative_snapshot_id",
        "raw_row_count",
        "logical_charge_count",
        "duplicate_raw_count",
        "valid_charge_count",
        "mismatch_count",
        "quarantine_count",
        "quarantine_reason_counts"
      ],
      "properties": {
        "collection_id": {
          "type": "string",
          "description": "Stable business collection identifier."
        },
        "cutoff_at": {
          "type": "string",
          "format": "date-time",
          "description": "Accrual cutoff in ISO-8601 UTC."
        },
        "authoritative_snapshot_id": {
          "type": "string",
          "description": "Stable snapshot ID used to resolve overlapping charge occurrences."
        },
        "raw_row_count": {
          "type": "integer",
          "minimum": 0
        },
        "logical_charge_count": {
          "type": "integer",
          "minimum": 0
        },
        "duplicate_raw_count": {
          "type": "integer",
          "minimum": 0
        },
        "valid_charge_count": {
          "type": "integer",
          "minimum": 0
        },
        "mismatch_count": {
          "type": "integer",
          "minimum": 0
        },
        "quarantine_count": {
          "type": "integer",
          "minimum": 0
        },
        "quarantine_reason_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ambiguous_alias",
            "invalid_distance",
            "invalid_weight",
            "unrecognized_alias"
          ],
          "properties": {
            "ambiguous_alias": {
              "type": "integer",
              "minimum": 0
            },
            "invalid_distance": {
              "type": "integer",
              "minimum": 0
            },
            "invalid_weight": {
              "type": "integer",
              "minimum": 0
            },
            "unrecognized_alias": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "class_mismatch_charge_ids": {
      "type": "array",
      "uniqueItems": true,
      "description": "All valid expected-versus-recognized service-class mismatch charge IDs, sorted lexicographically.",
      "items": {
        "type": "string",
        "pattern": "^FC-[0-9]{6}-[0-9]{6}$"
      }
    },
    "quarantine_charge_ids": {
      "type": "array",
      "uniqueItems": true,
      "description": "All logical charge IDs quarantined for an unresolved class, nonpositive weight, or nonpositive distance, sorted lexicographically.",
      "items": {
        "type": "string",
        "pattern": "^FC-[0-9]{6}-[0-9]{6}$"
      }
    },
    "duplicate_groups": {
      "type": "array",
      "description": "One object per charge ID with multiple raw occurrences, sorted by charge_id ascending.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "charge_id",
          "raw_occurrence_count",
          "snapshot_ids",
          "retained_snapshot_id"
        ],
        "properties": {
          "charge_id": {
            "type": "string",
            "pattern": "^FC-[0-9]{6}-[0-9]{6}$"
          },
          "raw_occurrence_count": {
            "type": "integer",
            "minimum": 2
          },
          "snapshot_ids": {
            "type": "array",
            "uniqueItems": true,
            "description": "Snapshot IDs containing this charge, sorted lexicographically.",
            "items": {
              "type": "string"
            }
          },
          "retained_snapshot_id": {
            "type": "string",
            "description": "Snapshot ID of the retained raw occurrence."
          }
        }
      }
    },
    "decision_panels": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reference_rows",
        "source_retention",
        "ledger_routing"
      ],
      "properties": {
        "reference_rows": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "uniqueItems": true,
          "description": "One row per scoped alias ID, sorted by alias_id ascending.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "alias_id",
              "decision_code"
            ],
            "properties": {
              "alias_id": {
                "type": "string",
                "pattern": "^FRA-[0-9]{3}$"
              },
              "decision_code": {
                "type": "string",
                "enum": [
                  "RB-17",
                  "RB-42",
                  "RB-83"
                ]
              }
            }
          }
        },
        "source_retention": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "uniqueItems": true,
          "description": "One row per scoped source-decision charge ID, sorted by charge_id ascending.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "charge_id",
              "decision_code"
            ],
            "properties": {
              "charge_id": {
                "type": "string",
                "pattern": "^FC-[0-9]{6}-[0-9]{6}$"
              },
              "decision_code": {
                "type": "string",
                "enum": [
                  "SB-24",
                  "SB-61",
                  "SB-79"
                ]
              }
            }
          }
        },
        "ledger_routing": {
          "type": "array",
          "minItems": 10,
          "maxItems": 10,
          "uniqueItems": true,
          "description": "One row per scoped ledger-decision charge ID, sorted by charge_id ascending.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "charge_id",
              "decision_code"
            ],
            "properties": {
              "charge_id": {
                "type": "string",
                "pattern": "^FC-[0-9]{6}-[0-9]{6}$"
              },
              "decision_code": {
                "type": "string",
                "enum": [
                  "LD-14",
                  "LD-31",
                  "LD-53",
                  "LD-72",
                  "LD-88"
                ]
              }
            }
          }
        }
      }
    },
    "normalized_totals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "valid_charge_count",
        "total_billed_weight_kg",
        "total_distance_km",
        "total_spend_usd",
        "service_class_totals"
      ],
      "properties": {
        "valid_charge_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_billed_weight_kg": {
          "type": "number",
          "description": "Kilograms, rounded to 2 decimal places."
        },
        "total_distance_km": {
          "type": "number",
          "description": "Kilometers, rounded to 2 decimal places."
        },
        "total_spend_usd": {
          "type": "number",
          "description": "USD, rounded to 2 decimal places."
        },
        "service_class_totals": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "description": "Exactly one object per service_class, sorted by service_class ascending.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "service_class",
              "charge_count",
              "billed_weight_kg",
              "distance_km",
              "spend_usd"
            ],
            "properties": {
              "service_class": {
                "type": "string",
                "enum": [
                  "EXPRESS",
                  "HAZMAT",
                  "OVERSIZE",
                  "REFRIGERATED",
                  "STANDARD"
                ]
              },
              "charge_count": {
                "type": "integer",
                "minimum": 0
              },
              "billed_weight_kg": {
                "type": "number",
                "description": "Kilograms, rounded to 2 decimal places."
              },
              "distance_km": {
                "type": "number",
                "description": "Kilometers, rounded to 2 decimal places."
              },
              "spend_usd": {
                "type": "number",
                "description": "USD, rounded to 2 decimal places."
              }
            }
          }
        }
      }
    },
    "carrier_ranking": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "description": "Requested carriers ordered by mismatch_spend_usd descending, then carrier_id ascending.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rank",
          "carrier_id",
          "mismatch_count",
          "mismatch_spend_usd",
          "quarantine_count",
          "exception_count"
        ],
        "properties": {
          "rank": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "carrier_id": {
            "type": "string",
            "pattern": "^CAR-[0-9]{3}$"
          },
          "mismatch_count": {
            "type": "integer",
            "minimum": 0
          },
          "mismatch_spend_usd": {
            "type": "number",
            "description": "USD exposure from valid service-class mismatches, rounded to 2 decimal places."
          },
          "quarantine_count": {
            "type": "integer",
            "minimum": 0
          },
          "exception_count": {
            "type": "integer",
            "minimum": 0,
            "description": "Distinct retained charges that are a valid class mismatch or are quarantined."
          }
        }
      }
    },
    "close_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "routing"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "PASS_WITH_EXCEPTIONS",
            "HOLD"
          ]
        },
        "routing": {
          "type": "string",
          "enum": [
            "RELEASE",
            "REVIEW_EXCEPTIONS",
            "BLOCK_AND_REMEDIATE"
          ]
        }
      }
    }
  }
}
