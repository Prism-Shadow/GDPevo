{
  "description": "Required JSON shape for the AsterOps CRM contact import audit. Use only the target batch requested in the prompt.",
  "type": "object",
  "required_top_level_keys": [
    "batch_id",
    "retained_contact_count",
    "dropped_unreachable_count",
    "duplicate_group_count",
    "suppressed_contact_ids",
    "source_conflict_person_keys",
        "canonical_contacts",
        "source_lineage_audit",
        "city_retained_counts",
        "domain_retained_counts",
        "decision_audit",
    "quality_flags"
  ],
  "fields": {
    "batch_id": {
      "type": "string",
      "description": "Target CRM import batch identifier."
    },
    "retained_contact_count": {
      "type": "integer",
      "description": "Count of canonical people retained for loading."
    },
    "dropped_unreachable_count": {
      "type": "integer",
      "description": "Count of canonical people dropped because no reachable email or phone channel remains."
    },
    "duplicate_group_count": {
      "type": "integer",
      "description": "Count of person_key groups with more than one source row in the target batch."
    },
    "suppressed_contact_ids": {
      "type": "array",
      "items": "string",
      "ordering": "ascending row_id",
      "description": "Source row IDs blocked by contact or consent suppression."
    },
    "source_conflict_person_keys": {
      "type": "array",
      "items": "string",
      "ordering": "ascending person_key",
      "description": "Person keys whose target-batch source rows contain conflicting source systems or effective contact attributes."
    },
        "canonical_contacts": {
      "type": "array",
      "ordering": "ascending person_key",
      "item_required_keys": [
        "person_key",
        "canonical_source",
        "email",
        "phone_digits",
        "city",
        "email_domain",
        "contact_status"
      ],
      "item_fields": {
        "person_key": {
          "type": "string"
        },
        "canonical_source": {
          "type": "enum",
          "allowed_values": [
            "crm_verified",
            "event_import",
            "partner_roster",
            "steward_override"
          ]
        },
        "email": {
          "type": "string",
          "normalization": "trim leading/trailing whitespace and lowercase; use empty string when absent"
        },
        "phone_digits": {
          "type": "string",
          "normalization": "digits only, preserving any country-code digits present in the source"
        },
        "city": {
          "type": "string"
        },
        "email_domain": {
          "type": "string",
          "normalization": "lowercase domain after @; use empty string when email is absent"
        },
        "contact_status": {
          "type": "enum",
          "allowed_values": [
            "retained",
            "dropped_unreachable",
            "suppressed",
            "manual_review"
          ]
        }
            }
        },
        "source_lineage_audit": {
            "type": "list[object]",
            "ordering": "ascending person_key",
            "description": "Duplicate-person source lineage evidence for the target batch.",
            "item_required_keys": [
                "person_key",
                "source_row_ids",
                "selected_row_id",
                "noncanonical_source_row_ids",
                "lineage_decision"
            ],
            "item_field_types": {
                "person_key": "string",
                "source_row_ids": "list[string]",
                "selected_row_id": "string",
                "noncanonical_source_row_ids": "list[string]",
                "lineage_decision": "enum"
            },
            "lineage_decision_allowed_values": [
                "source_precedence_override",
                "active_steward_correction"
            ]
        },
        "city_retained_counts": {
      "type": "object",
      "additional_properties": "integer",
      "description": "Counts by city for retained canonical contacts only."
    },
    "domain_retained_counts": {
      "type": "object",
      "additional_properties": "integer",
      "description": "Counts by normalized email domain for retained canonical contacts only."
    },
    "decision_audit": {
      "type": "object",
      "required_keys": [
        "precedence_override_person_keys",
        "suppressed_reachable_row_ids",
        "normalization_changed_row_ids"
      ],
      "fields": {
        "precedence_override_person_keys": {
          "type": "list[string]",
          "ordering": "ascending person_key",
          "description": "Duplicate person keys where source precedence changes the selected canonical row compared with choosing the newest row."
        },
        "suppressed_reachable_row_ids": {
          "type": "list[string]",
          "ordering": "ascending row_id",
          "description": "Suppressed rows that still have a usable normalized email or phone."
        },
        "normalization_changed_row_ids": {
          "type": "list[string]",
          "ordering": "ascending row_id",
          "description": "Rows whose nonblank email or phone changes under normalization."
        }
      }
    },
    "quality_flags": {
      "type": "object",
      "required_keys": [
        "raw_row_count",
        "canonical_person_count",
        "duplicate_person_groups",
        "duplicate_source_rows",
        "missing_channel_rows",
        "suppression_rows",
        "email_normalization_rows",
        "phone_normalization_rows",
        "stale_or_inactive_rows",
        "source_conflict_groups",
        "source_conflict_rows"
      ],
      "additional_properties": "integer"
    }
  }
}
