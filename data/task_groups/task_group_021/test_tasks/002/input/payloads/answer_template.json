{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "March fuel normalization and compliance audit answer",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "audit_summary",
    "effective_reference_panel",
    "transaction_decision_panel",
    "mismatch_transaction_ids",
    "quarantine_transaction_ids",
    "normalized_totals",
    "focus_assets",
    "merchant_exception_ranking",
    "reconciliation_status"
  ],
  "properties": {
    "audit_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "collection_id",
        "cutoff_at",
        "authoritative_snapshot_id",
        "raw_row_count",
        "logical_transaction_count",
        "duplicate_raw_count",
        "valid_transaction_count",
        "mismatch_count",
        "quarantine_count",
        "quarantine_reason_counts",
        "exception_transaction_count"
      ],
      "properties": {
        "collection_id": {
          "type": "string",
          "pattern": "^fuel_purchases_[0-9]{4}_[0-9]{2}$",
          "description": "Stable business collection identifier."
        },
        "cutoff_at": {
          "type": "string",
          "format": "date-time",
          "description": "Audit cutoff in ISO-8601 UTC."
        },
        "authoritative_snapshot_id": {
          "type": "string",
          "pattern": "^fuel_purchases_[0-9]{4}_[0-9]{2}-(certified|provisional)$",
          "description": "Stable snapshot ID used to resolve overlapping transaction occurrences."
        },
        "raw_row_count": {
          "type": "integer",
          "minimum": 0
        },
        "logical_transaction_count": {
          "type": "integer",
          "minimum": 0
        },
        "duplicate_raw_count": {
          "type": "integer",
          "minimum": 0
        },
        "valid_transaction_count": {
          "type": "integer",
          "minimum": 0
        },
        "mismatch_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of valid expected-versus-recognized fuel mismatches."
        },
        "quarantine_count": {
          "type": "integer",
          "minimum": 0
        },
        "quarantine_reason_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ambiguous_alias",
            "invalid_quantity",
            "unrecognized_alias"
          ],
          "properties": {
            "ambiguous_alias": {
              "type": "integer",
              "minimum": 0
            },
            "invalid_quantity": {
              "type": "integer",
              "minimum": 0
            },
            "unrecognized_alias": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "exception_transaction_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Distinct retained logical transactions that are valid mismatches or quarantined."
        }
      }
    },
    "effective_reference_panel": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "description": "Exactly the requested effective-reference cases, sorted by case_id ascending.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_id",
          "selected_alias_id",
          "resolved_fuel_type",
          "decision_reason",
          "reference_policy_code"
        ],
        "properties": {
          "case_id": {
            "type": "string",
            "pattern": "^REF-EDGE-[0-9]{2}$"
          },
          "selected_alias_id": {
            "type": "string",
            "enum": [
              "NONE",
              "FUA-003",
              "FUA-016"
            ],
            "description": "Stable alias ID selected for the case, or NONE when no usable reference exists."
          },
          "resolved_fuel_type": {
            "type": "string",
            "enum": [
              "NONE",
              "BIODIESEL",
              "DIESEL",
              "ELECTRIC_CHARGE",
              "PREMIUM_UNLEADED",
              "UNLEADED"
            ]
          },
          "decision_reason": {
            "type": "string",
            "enum": [
              "ACTIVE_ON_BUSINESS_DATE",
              "INACTIVE_CANDIDATE_AND_ACTIVE_NOT_YET_EFFECTIVE",
              "PROVISIONAL_ONLY"
            ]
          },
          "reference_policy_code": {
            "type": "string",
            "enum": [
              "RB-17",
              "RB-42",
              "RB-83"
            ]
          }
        }
      }
    },
    "transaction_decision_panel": {
      "type": "array",
      "minItems": 13,
      "maxItems": 13,
      "description": "Exactly the requested transaction IDs, sorted lexicographically by transaction_id.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "transaction_id",
          "retained_snapshot_id",
          "source_treatment",
          "recognition_outcome",
          "recognized_fuel_type",
          "category_relation",
          "reporting_disposition",
          "source_basis_code",
          "ledger_disposition_code"
        ],
        "properties": {
          "transaction_id": {
            "type": "string",
            "pattern": "^FT-[0-9]{6}-[0-9]{6}$"
          },
          "retained_snapshot_id": {
            "type": "string",
            "enum": [
              "fuel_purchases_2026_03-certified",
              "fuel_purchases_2026_03-provisional"
            ]
          },
          "source_treatment": {
            "type": "string",
            "enum": [
              "CERTIFIED_OVERLAP_RETAINED",
              "CERTIFIED_ONLY_RETAINED",
              "PROVISIONAL_ONLY_RETAINED"
            ]
          },
          "recognition_outcome": {
            "type": "string",
            "enum": [
              "RECOGNIZED",
              "AMBIGUOUS",
              "UNRECOGNIZED",
              "FALSE_SUBSTRING"
            ]
          },
          "recognized_fuel_type": {
            "type": "string",
            "enum": [
              "NONE",
              "BIODIESEL",
              "DIESEL",
              "ELECTRIC_CHARGE",
              "PREMIUM_UNLEADED",
              "UNLEADED"
            ]
          },
          "category_relation": {
            "type": "string",
            "enum": [
              "MATCH",
              "MISMATCH",
              "NOT_COMPARABLE"
            ]
          },
          "reporting_disposition": {
            "type": "string",
            "enum": [
              "INCLUDE_MATCH",
              "INCLUDE_MISMATCH",
              "QUARANTINE_AMBIGUOUS",
              "QUARANTINE_UNRECOGNIZED",
              "QUARANTINE_FALSE_SUBSTRING",
              "QUARANTINE_INVALID_QUANTITY"
            ]
          },
          "source_basis_code": {
            "type": "string",
            "enum": [
              "SB-24",
              "SB-61",
              "SB-79"
            ]
          },
          "ledger_disposition_code": {
            "type": "string",
            "enum": [
              "LD-14",
              "LD-31",
              "LD-53",
              "LD-72",
              "LD-88"
            ]
          }
        }
      }
    },
    "mismatch_transaction_ids": {
      "type": "array",
      "uniqueItems": true,
      "description": "All valid expected-versus-recognized mismatch transaction IDs, sorted lexicographically.",
      "items": {
        "type": "string",
        "pattern": "^FT-[0-9]{6}-[0-9]{6}$"
      }
    },
    "quarantine_transaction_ids": {
      "type": "array",
      "uniqueItems": true,
      "description": "All logical transaction IDs quarantined for an ambiguous or unrecognized category or a nonpositive quantity, sorted lexicographically.",
      "items": {
        "type": "string",
        "pattern": "^FT-[0-9]{6}-[0-9]{6}$"
      }
    },
    "normalized_totals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "valid_transaction_count",
        "total_volume_l",
        "total_spend_usd",
        "fuel_type_totals"
      ],
      "properties": {
        "valid_transaction_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_volume_l": {
          "type": "number",
          "description": "Liters, rounded to 2 decimal places."
        },
        "total_spend_usd": {
          "type": "number",
          "description": "USD, rounded to 2 decimal places."
        },
        "fuel_type_totals": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "description": "Exactly one row per fuel type, sorted by fuel_type ascending.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "fuel_type",
              "transaction_count",
              "volume_l",
              "spend_usd"
            ],
            "properties": {
              "fuel_type": {
                "type": "string",
                "enum": [
                  "BIODIESEL",
                  "DIESEL",
                  "ELECTRIC_CHARGE",
                  "PREMIUM_UNLEADED",
                  "UNLEADED"
                ]
              },
              "transaction_count": {
                "type": "integer",
                "minimum": 0
              },
              "volume_l": {
                "type": "number",
                "description": "Liters, rounded to 2 decimal places."
              },
              "spend_usd": {
                "type": "number",
                "description": "USD, rounded to 2 decimal places."
              }
            }
          }
        }
      }
    },
    "focus_assets": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "description": "Exactly the requested focus assets, sorted by asset_id ascending.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "asset_id",
          "logical_transaction_count",
          "valid_transaction_count",
          "mismatch_count",
          "quarantine_count",
          "exception_count",
          "exception_rate",
          "volume_l",
          "spend_usd"
        ],
        "properties": {
          "asset_id": {
            "type": "string",
            "pattern": "^AST-[0-9]{4}$"
          },
          "logical_transaction_count": {
            "type": "integer",
            "minimum": 0
          },
          "valid_transaction_count": {
            "type": "integer",
            "minimum": 0
          },
          "mismatch_count": {
            "type": "integer",
            "minimum": 0
          },
          "quarantine_count": {
            "type": "integer",
            "minimum": 0
          },
          "exception_count": {
            "type": "integer",
            "minimum": 0
          },
          "exception_rate": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Distinct exception count divided by logical transaction count, rounded to 4 decimal places."
          },
          "volume_l": {
            "type": "number",
            "description": "Liters from valid transactions, rounded to 2 decimal places."
          },
          "spend_usd": {
            "type": "number",
            "description": "USD from valid transactions, rounded to 2 decimal places."
          }
        }
      }
    },
    "merchant_exception_ranking": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "description": "Ordered by exception_rate descending, then exception_count descending, then merchant_id ascending.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rank",
          "merchant_id",
          "logical_transaction_count",
          "mismatch_count",
          "quarantine_count",
          "exception_count",
          "exception_rate"
        ],
        "properties": {
          "rank": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "merchant_id": {
            "type": "string",
            "pattern": "^MER-[0-9]{3}$"
          },
          "logical_transaction_count": {
            "type": "integer",
            "minimum": 1
          },
          "mismatch_count": {
            "type": "integer",
            "minimum": 0
          },
          "quarantine_count": {
            "type": "integer",
            "minimum": 0
          },
          "exception_count": {
            "type": "integer",
            "minimum": 0
          },
          "exception_rate": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Distinct compliance exceptions divided by logical transactions, rounded to 4 decimal places."
          }
        }
      }
    },
    "reconciliation_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "action"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "PASS_WITH_EXCEPTIONS",
            "HOLD"
          ]
        },
        "action": {
          "type": "string",
          "enum": [
            "RELEASE",
            "REVIEW_EXCEPTIONS",
            "BLOCK_AND_REMEDIATE"
          ]
        }
      }
    }
  }
}
