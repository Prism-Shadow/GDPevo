{
  "schema_name": "traffic_violation_closeout_payment_plan_batch",
  "schema_version": "1.0",
  "instructions": {
    "currency": "Numbers are dollar amounts rounded to two decimals.",
    "dates": "Use ISO YYYY-MM-DD dates; use null only where the field is not applicable to a dismissed/no-plan matter.",
    "matter_order": "Sort matters by citation_number ascending.",
    "excluded_charge_order": "Sort excluded_charges by charge_code ascending.",
    "scored_text": "Use enum values where provided; do not replace enum values with prose."
  },
  "required_top_level_keys": [
    "matters",
    "excluded_charges",
    "batch_totals"
  ],
  "matters_item": {
    "citation_number": {
      "type": "enum",
      "allowed": [
        "OR27-TR-2201",
        "OR27-TR-2208",
        "OR27-TR-2219"
      ]
    },
    "jurisdiction_code": {
      "type": "string"
    },
    "defendant_name": {
      "type": "string"
    },
    "disposition": {
      "plea": {
        "type": "enum",
        "allowed": [
          "no_contest",
          "guilty",
          "not_guilty",
          "no_plea_recorded"
        ]
      },
      "finding": {
        "type": "enum",
        "allowed": [
          "violation_found",
          "dismissed",
          "continued",
          "verify_before_entry"
        ]
      },
      "disposition_date": {
        "type": "date"
      },
      "agreement_sequence": {
        "type": "enum",
        "allowed": [
          "post_disposition",
          "pre_disposition",
          "same_entry_unknown",
          "no_agreement"
        ]
      }
    },
    "financial_entry": {
      "violation_code": {
        "type": "enum",
        "allowed": [
          "ORS_811_109_100PLUS",
          "ORS_811_109_31_40",
          "ORS_811_109_21_30",
          "other"
        ]
      },
      "fine_tier": {
        "type": "enum",
        "allowed": [
          "speed_100_or_greater",
          "speed_31_to_40_over",
          "speed_21_to_30_over",
          "dismissed_no_fine",
          "statutory_maximum",
          "verify_before_entry"
        ]
      },
      "fee_schedule_source": {
        "type": "enum",
        "allowed": [
          "F-OR27-100-2025",
          "F-OR27-21-2025",
          "F-OR27-SUR-2025",
          "not_applicable_dismissed",
          "statutory_maximum_note",
          "local_memo_only",
          "verify_before_entry"
        ]
      },
      "standard_fine": {
        "type": "number"
      },
      "county_surcharge": {
        "type": "number"
      },
      "amount_due": {
        "type": "number"
      },
      "unsupported_charge_total_included": {
        "type": "number"
      }
    },
    "payment_plan": {
      "plan_status": {
        "type": "enum",
        "allowed": [
          "approved",
          "not_approved",
          "not_applicable",
          "verify_before_entry"
        ]
      },
      "agreement_type": {
        "type": "enum",
        "allowed": [
          "extended_payment_plan",
          "standard_due_date_only",
          "none",
          "verify_before_entry"
        ]
      },
      "monthly_payment": {
        "type": "number_or_null"
      },
      "down_payment": {
        "type": "number"
      },
      "first_due_date": {
        "type": "date_or_null"
      },
      "full_payment_count": {
        "type": "integer"
      },
      "final_payment_amount": {
        "type": "number_or_null",
        "meaning": "Final partial remainder amount; use 0.00 when all installments are equal full payments."
      },
      "total_installments": {
        "type": "integer"
      },
      "final_due_date": {
        "type": "date_or_null"
      }
    },
    "form_entry": {
      "form_id": {
        "type": "enum",
        "allowed": [
          "OR_27JD_PLAN",
          "not_applicable",
          "other",
          "verify_before_entry"
        ]
      },
      "form_label": {
        "type": "enum",
        "allowed": [
          "payment_plan_agreement",
          "extended_payment_plan_agreement",
          "not_applicable",
          "other",
          "verify_before_entry"
        ]
      },
      "account_reference": {
        "type": "string"
      },
      "required_labels_used": {
        "type": "list",
        "allowed_values": [
          "Citation #",
          "Account Reference",
          "Total Balance Due",
          "Payment Schedule",
          "Clerk Notes"
        ]
      }
    }
  },
  "excluded_charges_item": {
    "charge_code": {
      "type": "enum",
      "allowed": [
        "account_management_fee",
        "collection_fee",
        "dmv_fee",
        "late_payment_fee",
        "returned_check_fee",
        "traffic_school_fee",
        "work_zone_multiplier",
        "copied_high_speed_fine_on_dismissal"
      ]
    },
    "applies_to": {
      "type": "enum",
      "allowed": [
        "all",
        "OR27-TR-2201",
        "OR27-TR-2208",
        "OR27-TR-2219"
      ]
    },
    "reason_code": {
      "type": "enum",
      "allowed": [
        "dismissed_no_financial_entry",
        "unsupported_enhancement",
        "not_in_hearing_order",
        "not_current_policy",
        "no_triggering_event"
      ]
    }
  },
  "batch_totals": {
    "matter_count": {
      "type": "integer"
    },
    "payable_matter_count": {
      "type": "integer"
    },
    "dismissed_matter_count": {
      "type": "integer"
    },
    "combined_standard_fine": {
      "type": "number"
    },
    "combined_county_surcharge": {
      "type": "number"
    },
    "combined_amount_due": {
      "type": "number"
    },
    "total_installments_scheduled": {
      "type": "integer"
    },
    "unsupported_charge_total_included": {
      "type": "number"
    }
  }
}
