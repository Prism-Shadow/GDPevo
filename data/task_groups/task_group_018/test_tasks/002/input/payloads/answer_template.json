{
  "schema_name": "test_002_jefferson_afternoon_control_answer",
  "required_top_level_keys": [
    "batch_id",
    "county",
    "entries",
    "batch_totals"
  ],
  "ordering_rules": {
    "entries": "Order by citation_number ascending.",
    "assessed_components": "Order in the sequence the components are applied.",
    "excluded_candidate_fee_codes": "Sort ascending by code.",
    "decision_flags": "Sort ascending by flag."
  },
  "field_definitions": {
    "batch_id": {
      "type": "string"
    },
    "county": {
      "type": "string"
    },
    "entries": {
      "type": "list",
      "item_type": "object",
      "required_item_keys": [
        "citation_number",
        "account_reference",
        "defendant_name",
        "source_resolution",
        "final_plea",
        "final_disposition",
        "assessment_order_date",
        "assessment_status",
        "fee_schedule_bucket",
        "violation_code_for_assessment",
        "violation_source",
        "speed_tier",
        "decision_flags",
        "assessed_components",
        "assessed_total",
        "excluded_candidate_fee_codes",
        "payment_plan"
      ]
    },
    "citation_number": {
      "type": "string"
    },
    "account_reference": {
      "type": "string",
      "description": "Use the citation number when no separate case or account number is available."
    },
    "defendant_name": {
      "type": "string"
    },
    "source_resolution": {
      "type": "enum",
      "allowed_values": [
        "current_bench_over_live",
        "current_bench_over_live_plea_and_stale_export",
        "current_bench_over_prior_deferred",
        "current_bench_over_stale_plan",
        "live_dismissal_over_stale_identity",
        "live_satisfied_over_stale_history",
        "signed_amended_order_over_live_and_stale"
      ]
    },
    "final_plea": {
      "type": "enum",
      "allowed_values": [
        "not_entered",
        "not_guilty",
        "guilty",
        "no_contest",
        "deferred_entry"
      ]
    },
    "final_disposition": {
      "type": "enum",
      "allowed_values": [
        "convicted",
        "dismissed",
        "deferred",
        "pending",
        "satisfied"
      ]
    },
    "assessment_order_date": {
      "type": "date",
      "format": "YYYY-MM-DD"
    },
    "assessment_status": {
      "type": "enum",
      "allowed_values": [
        "assessed_current_order",
        "assessed_prior_order",
        "no_assessment_dismissed",
        "no_assessment_satisfied",
        "no_new_assessment_deferred_completion"
      ]
    },
    "fee_schedule_bucket": {
      "type": "enum",
      "allowed_values": [
        "current_schedule",
        "no_fee_schedule",
        "prior_schedule"
      ]
    },
    "violation_code_for_assessment": {
      "type": "enum",
      "allowed_values": [
        "TR-201",
        "TR-202",
        "TR-215",
        "TR-231",
        "TR-244",
        "TR-260",
        "none"
      ]
    },
    "violation_source": {
      "type": "enum",
      "allowed_values": [
        "bench_amendment",
        "live_violation_remaining",
        "no_assessment_exception",
        "signed_amended_order"
      ]
    },
    "speed_tier": {
      "type": "enum",
      "allowed_values": [
        "none",
        "speed_11_to_20_over",
        "speed_21_to_30_over"
      ]
    },
    "decision_flags": {
      "type": "list",
      "item_type": "enum",
      "allowed_values": [
        "below_policy_monthly_request",
        "current_fee_schedule_controls",
        "deferred_completion_no_assessment",
        "dismissed_no_assessment",
        "live_disposition_superseded_by_bench",
        "live_plea_superseded_by_bench",
        "live_plea_superseded_by_history",
        "live_violation_superseded_by_bench",
        "live_violation_superseded_by_history",
        "prior_fee_schedule_controls",
        "return_to_court_plan_defect",
        "satisfied_no_assessment",
        "stale_due_date_superseded",
        "stale_identity_conflict",
        "stale_plan_rejected",
        "stale_return_to_court_rejected",
        "stale_status_conflict",
        "unsupported_candidate_code"
      ]
    },
    "assessed_components": {
      "type": "list",
      "item_type": "object",
      "required_item_keys": [
        "fee_code",
        "amount",
        "schedule_effective_start"
      ],
      "fee_code_type": "string",
      "amount_precision": "currency, 2 decimals",
      "schedule_effective_start_type": "date"
    },
    "assessed_total": {
      "type": "number",
      "precision": "currency, 2 decimals"
    },
    "excluded_candidate_fee_codes": {
      "type": "list",
      "item_type": "string"
    },
    "payment_plan": {
      "type": "object",
      "required_keys": [
        "plan_action",
        "plan_defect_code",
        "monthly_amount",
        "first_due_date",
        "first_due_basis",
        "full_payment_count",
        "final_payment_amount",
        "total_payment_count",
        "final_due_date"
      ]
    },
    "plan_action": {
      "type": "enum",
      "allowed_values": [
        "entered_new_plan",
        "no_plan_no_assessment",
        "return_to_court_review"
      ]
    },
    "plan_defect_code": {
      "type": "enum",
      "allowed_values": [
        "below_minimum_and_stale_due_date",
        "below_minimum_request",
        "deferred_completion_no_assessment",
        "dismissed_no_assessment",
        "none",
        "return_to_court_defect",
        "satisfied_no_assessment",
        "stale_return_to_court_rejected"
      ]
    },
    "monthly_amount": {
      "type": "number",
      "precision": "currency, 2 decimals"
    },
    "first_due_date": {
      "type": "date_or_null",
      "format": "YYYY-MM-DD or null"
    },
    "first_due_basis": {
      "type": "enum",
      "allowed_values": [
        "not_applicable",
        "policy_default_after_order"
      ]
    },
    "full_payment_count": {
      "type": "integer"
    },
    "final_payment_amount": {
      "type": "number",
      "precision": "currency, 2 decimals"
    },
    "total_payment_count": {
      "type": "integer"
    },
    "final_due_date": {
      "type": "date_or_null",
      "format": "YYYY-MM-DD or null"
    },
    "batch_totals": {
      "type": "object",
      "required_keys": [
        "assessed_total",
        "prior_schedule_assessed_total",
        "current_schedule_assessed_total",
        "base_fine_total",
        "speed_surcharge_total",
        "traffic_school_total",
        "assessed_entry_count",
        "no_assessment_entry_count",
        "dismissed_no_assessment_count",
        "satisfied_no_assessment_count",
        "excluded_candidate_fee_count",
        "unsupported_policy_code_count",
        "entered_plan_principal_total",
        "total_full_payments",
        "total_final_payment_amount",
        "total_payment_count",
        "default_first_due_count",
        "below_minimum_plan_count",
        "return_to_court_review_count",
        "entries_using_prior_fee_schedule",
        "entries_using_current_fee_schedule",
        "entries_with_source_override_flags",
        "all_entered_plans_use_post_disposition_start"
      ]
    },
    "assessed_entry_count": {
      "type": "integer"
    },
    "no_assessment_entry_count": {
      "type": "integer"
    },
    "dismissed_no_assessment_count": {
      "type": "integer"
    },
    "satisfied_no_assessment_count": {
      "type": "integer"
    },
    "excluded_candidate_fee_count": {
      "type": "integer"
    },
    "unsupported_policy_code_count": {
      "type": "integer"
    },
    "entries_using_prior_fee_schedule": {
      "type": "integer"
    },
    "entries_using_current_fee_schedule": {
      "type": "integer"
    },
    "entries_with_source_override_flags": {
      "type": "integer"
    },
    "all_entered_plans_use_post_disposition_start": {
      "type": "boolean"
    }
  }
}
