{
  "template_name": "test_004_benton_post_disposition_audit_queue",
  "version": "2.0",
  "output_format": "JSON object only",
  "required_top_level_keys": [
    "task_id",
    "county",
    "audit_date",
    "currency",
    "case_rows",
    "aggregate"
  ],
  "top_level_fields": {
    "task_id": {
      "type": "string",
      "required_value": "test_004"
    },
    "county": {
      "type": "string",
      "required_value": "Benton"
    },
    "audit_date": {
      "type": "date",
      "format": "YYYY-MM-DD"
    },
    "currency": {
      "type": "enum",
      "allowed_values": [
        "USD"
      ]
    }
  },
  "case_rows": {
    "type": "list",
    "ordering": "Sort rows by case_number ascending.",
    "row_identity": "case_number",
    "required_object_keys": [
      "case_number",
      "defendant_name",
      "matter_type",
      "resolved_status",
      "disposition_date",
      "assessment_basis_date",
      "source_conflict_code",
      "final_defense_attorney",
      "final_defense_type",
      "counsel_fee_treatment",
      "approved_fee_components",
      "restitution_amount",
      "live_ledger_principal",
      "live_amount_paid",
      "ledger_credit_adjustment_to_paid",
      "effective_amount_paid",
      "corrected_principal_total",
      "principal_delta",
      "corrected_balance_due",
      "release_to_entry",
      "hold_reason_code",
      "next_action_code"
    ],
    "field_definitions": {
      "case_number": {
        "type": "string",
        "format": "stable Benton case number"
      },
      "defendant_name": {
        "type": "string",
        "format": "live clerk record display name"
      },
      "matter_type": {
        "type": "enum",
        "allowed_values": [
          "criminal"
        ]
      },
      "resolved_status": {
        "type": "enum",
        "allowed_values": [
          "closed",
          "deferred",
          "open",
          "probation_active",
          "warrant"
        ]
      },
      "disposition_date": {
        "type": "date_or_null",
        "format": "YYYY-MM-DD or null"
      },
      "assessment_basis_date": {
        "type": "date_or_null",
        "format": "YYYY-MM-DD or null; use the date that controls fee effective-date selection for the row."
      },
      "source_conflict_code": {
        "type": "enum",
        "allowed_values": [
          "NONE",
          "STALE_STATUS_ONLY",
          "FEE_TABLE_ONLY",
          "LEDGER_CREDIT_ONLY",
          "COUNSEL_FEE_ONLY",
          "FEE_AND_LEDGER",
          "COUNSEL_AND_LEDGER",
          "STALE_STATUS_FEE_AND_LEDGER",
          "COUNSEL_FEE_AND_CHARGE",
          "COUNSEL_LEDGER_AND_CHARGE",
          "MULTIPLE_SOURCE_CONFLICT"
        ]
      },
      "final_defense_attorney": {
        "type": "string"
      },
      "final_defense_type": {
        "type": "enum",
        "allowed_values": [
          "retained",
          "appointed_private",
          "public_defender",
          "unknown"
        ]
      },
      "counsel_fee_treatment": {
        "type": "enum",
        "allowed_values": [
          "NO_COUNSEL_FEE",
          "NOT_COUNSEL_FEE_ELIGIBLE",
          "ASSESS_APPOINTED_COUNSEL_FEE",
          "ASSESS_PD_RECOUPMENT",
          "EXCLUDE_UNSIGNED_PD_RECOUPMENT",
          "HOLD_FOR_COUNSEL_ORDER"
        ]
      },
      "approved_fee_components": {
        "type": "list",
        "ordering": "Sort by fee_code ascending.",
        "item_required_keys": [
          "fee_code",
          "amount"
        ],
        "fee_code_allowed_values": [
          "CR-APPT-CNSL",
          "CR-CONV",
          "CR-FILING",
          "CR-PD-REC",
          "CR-PROB",
          "CR-REST-ADM"
        ],
        "amount_precision": "currency rounded to 2 decimals"
      },
      "restitution_amount": {
        "type": "number",
        "precision": "currency rounded to 2 decimals",
        "unit": "USD"
      },
      "live_ledger_principal": {
        "type": "number",
        "precision": "currency rounded to 2 decimals",
        "unit": "USD",
        "description": "Current live financial obligation principal_amount before this audit correction."
      },
      "live_amount_paid": {
        "type": "number",
        "precision": "currency rounded to 2 decimals",
        "unit": "USD",
        "description": "Current live financial obligation amount_paid before task-local credit corrections."
      },
      "ledger_credit_adjustment_to_paid": {
        "type": "number",
        "precision": "currency rounded to 2 decimals",
        "unit": "USD",
        "description": "Signed adjustment to live_amount_paid from verified task-local credit corrections; negative values reduce paid credit."
      },
      "effective_amount_paid": {
        "type": "number",
        "precision": "currency rounded to 2 decimals",
        "unit": "USD",
        "description": "live_amount_paid plus ledger_credit_adjustment_to_paid."
      },
      "corrected_principal_total": {
        "type": "number",
        "precision": "currency rounded to 2 decimals",
        "unit": "USD",
        "description": "Final approved principal before payments, including restitution when applicable."
      },
      "principal_delta": {
        "type": "number",
        "precision": "currency rounded to 2 decimals",
        "unit": "USD",
        "description": "corrected_principal_total minus live_ledger_principal."
      },
      "corrected_balance_due": {
        "type": "number",
        "precision": "currency rounded to 2 decimals",
        "unit": "USD",
        "description": "corrected_principal_total minus effective_amount_paid."
      },
      "release_to_entry": {
        "type": "boolean",
        "description": "True when the audit row is resolved enough for the next clerk entry batch; false when an unresolved hold remains."
      },
      "hold_reason_code": {
        "type": "enum",
        "allowed_values": [
          "NONE",
          "CHARGE_RESULT_CONFLICT",
          "LEDGER_SUPERVISOR_REVIEW",
          "COUNSEL_ORDER_MISSING",
          "AWAITING_DISPOSITION"
        ]
      },
      "next_action_code": {
        "type": "enum",
        "allowed_values": [
          "RELEASE_NO_CHANGE",
          "REPLACE_FINANCIAL_ENTRY",
          "UPDATE_COUNSEL_AND_RELEASE",
          "TRANSFER_CREDIT_AND_REPLACE",
          "APPLY_TRANSFER_AND_REPLACE",
          "REVERSE_CREDIT_AND_RELEASE",
          "HOLD_FOR_CHARGE_REVIEW",
          "HOLD_FOR_LEDGER_REVIEW",
          "HOLD_FOR_COUNSEL_ORDER"
        ]
      }
    }
  },
  "aggregate": {
    "type": "object",
    "required_object_keys": [
      "case_count",
      "release_to_entry_count",
      "hold_count",
      "principal_replacement_count",
      "ledger_credit_adjustment_count",
      "counsel_fee_assessed_count",
      "counsel_fee_excluded_count",
      "held_case_numbers",
      "aggregate_live_principal",
      "aggregate_corrected_principal",
      "aggregate_principal_delta",
      "aggregate_live_amount_paid",
      "aggregate_credit_adjustment_to_paid",
      "aggregate_effective_amount_paid",
      "aggregate_corrected_balance_due",
      "aggregate_restitution_total",
      "aggregate_counsel_fee_total"
    ],
    "field_definitions": {
      "case_count": {
        "type": "integer"
      },
      "release_to_entry_count": {
        "type": "integer"
      },
      "hold_count": {
        "type": "integer"
      },
      "principal_replacement_count": {
        "type": "integer",
        "description": "Count of rows whose corrected principal differs from the live ledger principal."
      },
      "ledger_credit_adjustment_count": {
        "type": "integer",
        "description": "Count of rows with a non-zero ledger_credit_adjustment_to_paid."
      },
      "counsel_fee_assessed_count": {
        "type": "integer"
      },
      "counsel_fee_excluded_count": {
        "type": "integer"
      },
      "held_case_numbers": {
        "type": "list",
        "items": {
          "type": "string"
        },
        "ordering": "Sort case numbers ascending."
      },
      "aggregate_live_principal": {
        "type": "number",
        "precision": "currency rounded to 2 decimals",
        "unit": "USD"
      },
      "aggregate_corrected_principal": {
        "type": "number",
        "precision": "currency rounded to 2 decimals",
        "unit": "USD"
      },
      "aggregate_principal_delta": {
        "type": "number",
        "precision": "currency rounded to 2 decimals",
        "unit": "USD"
      },
      "aggregate_live_amount_paid": {
        "type": "number",
        "precision": "currency rounded to 2 decimals",
        "unit": "USD"
      },
      "aggregate_credit_adjustment_to_paid": {
        "type": "number",
        "precision": "currency rounded to 2 decimals",
        "unit": "USD"
      },
      "aggregate_effective_amount_paid": {
        "type": "number",
        "precision": "currency rounded to 2 decimals",
        "unit": "USD"
      },
      "aggregate_corrected_balance_due": {
        "type": "number",
        "precision": "currency rounded to 2 decimals",
        "unit": "USD"
      },
      "aggregate_restitution_total": {
        "type": "number",
        "precision": "currency rounded to 2 decimals",
        "unit": "USD"
      },
      "aggregate_counsel_fee_total": {
        "type": "number",
        "precision": "currency rounded to 2 decimals",
        "unit": "USD"
      }
    }
  }
}
