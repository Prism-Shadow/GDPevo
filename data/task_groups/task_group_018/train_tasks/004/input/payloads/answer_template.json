{
  "schema_name": "union_county_criminal_disposition_register",
  "schema_version": "1.0",
  "ordering_rules": {
    "case_audit": "Sort by case_number ascending.",
    "dispositions": "Sort by case_number ascending.",
    "fee_entries": "Sort by case_number ascending.",
    "docket_register.entries": "Sort by case_number ascending.",
    "exclusions": "Sort by case_number ascending."
  },
  "field_rules": {
    "currency": "Numbers are dollars rounded to two decimal places.",
    "dates": "Use ISO YYYY-MM-DD. Use null where no disposition date should be entered.",
    "dob_for_entry": "Use YYYY-MM-DD when verified; use TBD from case file when the DOB is genuinely missing and must be verified."
  },
  "required_top_level_keys": [
    "case_audit",
    "dispositions",
    "fee_entries",
    "docket_register",
    "exclusions"
  ],
  "enums": {
    "identity_action": [
      "use_cms_dob",
      "use_placeholder_verify",
      "exclude_pending"
    ],
    "counsel_classification": [
      "retained",
      "public_defender",
      "appointed_private"
    ],
    "audit_flag": [
      "amended_non_lab_conviction",
      "lab_fee_worksheet_omitted",
      "dob_missing_verify",
      "apd_label_not_public_defender",
      "no_final_order_pending"
    ],
    "recommended_resolution": [
      "use_hearing_notes",
      "use_cms_identity",
      "use_corrob_memo",
      "verify_before_entry",
      "exclude_pending"
    ],
    "entry_status": [
      "disposed_enter",
      "pending_exclude"
    ],
    "primary_outcome": [
      "guilty_plea",
      "no_contest_guilty",
      "bench_trial_guilty",
      "continued_pending"
    ],
    "plea": [
      "guilty",
      "no_contest",
      "not_entered",
      "not_applicable"
    ],
    "departure_status": [
      "none",
      "not_evaluated_misdemeanor",
      "not_entered_pending"
    ],
    "fee_status": [
      "post",
      "do_not_post_pending"
    ],
    "register_action": [
      "enter_disposition_and_financials",
      "exclude_no_final_order"
    ],
    "docket_code": [
      "SENTENCING_ORDER_ENTERED",
      "CONTINUED_NO_DISPOSITION"
    ],
    "exclusion_reason": [
      "continued_pending_no_final_order"
    ]
  },
  "answer_shape": {
    "case_audit": [
      {
        "case_number": "string",
        "defendant_name": "string",
        "dob_for_entry": "string",
        "identity_action": "enum:identity_action",
        "counsel_classification": "enum:counsel_classification",
        "audit_flags": [
          "enum:audit_flag"
        ],
        "recommended_resolution": "enum:recommended_resolution"
      }
    ],
    "dispositions": [
      {
        "case_number": "string",
        "entry_status": "enum:entry_status",
        "disposition_date": "YYYY-MM-DD or null",
        "primary_outcome": "enum:primary_outcome",
        "plea": "enum:plea",
        "convicted_counts": "integer",
        "dismissed_or_amended_away_counts": "integer",
        "departure_status": "enum:departure_status"
      }
    ],
    "fee_entries": [
      {
        "case_number": "string",
        "fee_status": "enum:fee_status",
        "court_cost": "currency number",
        "crime_lab_fee": "currency number",
        "fine": "currency number",
        "total_due": "currency number"
      }
    ],
    "docket_register": {
      "entries": [
        {
          "case_number": "string",
          "register_action": "enum:register_action",
          "docket_code": "enum:docket_code",
          "entry_date": "YYYY-MM-DD or null"
        }
      ],
      "totals": {
        "disposed_case_count": "integer",
        "excluded_pending_count": "integer",
        "court_cost_total": "currency number",
        "crime_lab_fee_total": "currency number",
        "fine_total": "currency number",
        "batch_total_due": "currency number"
      }
    },
    "exclusions": [
      {
        "case_number": "string",
        "exclusion_reason": "enum:exclusion_reason",
        "next_status_check_date": "YYYY-MM-DD",
        "financial_posting_allowed": "boolean"
      }
    ]
  }
}
