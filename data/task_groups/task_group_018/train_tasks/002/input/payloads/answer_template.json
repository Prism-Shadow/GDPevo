{
  "schema_name": "train_002_lane_traffic_batch_answer",
  "required_top_level_keys": [
    "batch_id",
    "county",
    "entries",
    "batch_totals"
  ],
  "ordering_rules": {
    "entries": "Order by citation_number ascending.",
    "assessed_components": "Order in the sequence the components are applied.",
    "excluded_candidate_fee_codes": "Sort ascending by code."
  },
  "field_definitions": {
    "batch_id": {
      "type": "string"
    },
    "county": {
      "type": "string"
    },
    "entries": {
      "type": "list",
      "item_type": "object",
      "required_item_keys": [
        "citation_number",
        "account_reference",
        "defendant_name",
        "plea",
        "disposition",
        "order_date",
        "assessed_components",
        "assessed_total",
        "excluded_candidate_fee_codes",
        "payment_plan"
      ]
    },
    "citation_number": {
      "type": "string"
    },
    "account_reference": {
      "type": "string",
      "description": "Use the citation number when no separate case number is available."
    },
    "defendant_name": {
      "type": "string"
    },
    "plea": {
      "type": "enum",
      "allowed_values": [
        "not_entered",
        "guilty",
        "no_contest",
        "deferred_entry"
      ]
    },
    "disposition": {
      "type": "enum",
      "allowed_values": [
        "convicted",
        "dismissed",
        "deferred",
        "amended",
        "pending"
      ]
    },
    "order_date": {
      "type": "date",
      "format": "YYYY-MM-DD"
    },
    "assessed_components": {
      "type": "list",
      "item_type": "object",
      "required_item_keys": [
        "fee_code",
        "amount"
      ],
      "amount_precision": "currency, 2 decimals"
    },
    "assessed_total": {
      "type": "number",
      "precision": "currency, 2 decimals"
    },
    "excluded_candidate_fee_codes": {
      "type": "list",
      "item_type": "string"
    },
    "payment_plan": {
      "type": "object",
      "required_keys": [
        "plan_status",
        "monthly_amount",
        "first_due_date",
        "full_payment_count",
        "final_payment_amount",
        "total_payment_count",
        "final_due_date"
      ]
    },
    "plan_status": {
      "type": "enum",
      "allowed_values": [
        "entered_after_disposition",
        "not_entered",
        "needs_review"
      ]
    },
    "monthly_amount": {
      "type": "number",
      "precision": "currency, 2 decimals"
    },
    "first_due_date": {
      "type": "date",
      "format": "YYYY-MM-DD"
    },
    "full_payment_count": {
      "type": "integer"
    },
    "final_payment_amount": {
      "type": "number",
      "precision": "currency, 2 decimals"
    },
    "total_payment_count": {
      "type": "integer"
    },
    "final_due_date": {
      "type": "date",
      "format": "YYYY-MM-DD"
    },
    "batch_totals": {
      "type": "object",
      "required_keys": [
        "assessed_total",
        "total_full_payments",
        "total_final_payment_amount",
        "all_plans_entered_after_disposition"
      ]
    },
    "all_plans_entered_after_disposition": {
      "type": "boolean"
    }
  }
}
