{
  "template_name": "train_005_wasco_compliance_review",
  "description": "Return one JSON object with the required fields below. Use live environment records together with the local compliance packet.",
  "required_top_level_keys": [
    "task_id",
    "county",
    "review_order_date",
    "records",
    "aggregate"
  ],
  "field_rules": {
    "task_id": {
      "type": "string",
      "required_value": "train_005"
    },
    "county": {
      "type": "string",
      "required_value": "Wasco"
    },
    "review_order_date": {
      "type": "date",
      "format": "YYYY-MM-DD"
    },
    "records": {
      "type": "array",
      "ordering": "ascending by case_number",
      "item_required_keys": [
        "case_number",
        "financial_status",
        "restitution_status",
        "community_service_status",
        "community_service_remaining_hours",
        "ledger_balance_before_adjustment",
        "correction_amount",
        "corrected_balance_due",
        "payment_plan_action",
        "monthly_payment_amount",
        "installment_count",
        "final_payment_amount",
        "first_due_date",
        "final_due_date",
        "next_action",
        "source_conflict_code"
      ]
    },
    "aggregate": {
      "type": "object",
      "required_keys": [
        "included_case_count",
        "corrected_total_balance_due",
        "return_to_court_count",
        "post_credit_case_numbers",
        "revised_plan_case_numbers"
      ]
    }
  },
  "record_field_types": {
    "case_number": "string",
    "financial_status": "enum",
    "restitution_status": "enum",
    "community_service_status": "enum",
    "community_service_remaining_hours": "number with one decimal place",
    "ledger_balance_before_adjustment": "currency number rounded to 2 decimals",
    "correction_amount": "currency number rounded to 2 decimals; positive values reduce the live balance",
    "corrected_balance_due": "currency number rounded to 2 decimals",
    "payment_plan_action": "enum",
    "monthly_payment_amount": "currency number rounded to 2 decimals, or null when no payment plan applies",
    "installment_count": "integer; use 0 when no payment plan applies",
    "final_payment_amount": "currency number rounded to 2 decimals, or null when no payment plan applies",
    "first_due_date": "date in YYYY-MM-DD format, or null when no payment plan applies",
    "final_due_date": "date in YYYY-MM-DD format, or null when no payment plan applies",
    "next_action": "enum",
    "source_conflict_code": "enum"
  },
  "enum_values": {
    "financial_status": [
      "paid",
      "paid_after_credit",
      "current",
      "delinquent",
      "replan_approved",
      "pending_adjustment"
    ],
    "restitution_status": [
      "none",
      "open",
      "paid_or_disbursed"
    ],
    "community_service_status": [
      "not_ordered",
      "complete",
      "partial",
      "unknown"
    ],
    "payment_plan_action": [
      "none",
      "keep_existing",
      "approve_revised_plan",
      "send_return_to_court",
      "post_credit_close"
    ],
    "next_action": [
      "post_receipt_close",
      "approve_plan_and_notice",
      "issue_return_to_court_notice",
      "continue_monitoring",
      "community_service_followup",
      "no_action"
    ],
    "source_conflict_code": [
      "no_source_conflict",
      "live_ledger_vs_packet_receipt",
      "petition_changes_payment_plan",
      "packet_service_shortfall"
    ]
  },
  "aggregate_field_types": {
    "included_case_count": "integer",
    "corrected_total_balance_due": "currency number rounded to 2 decimals",
    "return_to_court_count": "integer",
    "post_credit_case_numbers": "array of strings sorted ascending",
    "revised_plan_case_numbers": "array of strings sorted ascending"
  }
}
