{
  "task_id": "train_003",
  "output_type": "gloucester_dui_probation_packet",
  "required_top_level_keys": [
    "task_id",
    "packet_id",
    "county",
    "defendants",
    "packet_totals"
  ],
  "field_definitions": {
    "task_id": {
      "type": "string",
      "required_value": "train_003"
    },
    "packet_id": {
      "type": "string"
    },
    "county": {
      "type": "string"
    },
    "defendants": {
      "type": "list",
      "order": "ascending by case_number",
      "required_item_keys": [
        "case_number",
        "defendant_name",
        "conviction_posture",
        "charge_outcomes",
        "identity_fields",
        "collateral_orders",
        "financial_order",
        "follow_up_action"
      ]
    },
    "packet_totals": {
      "type": "object",
      "required_keys": [
        "principal_amount_total",
        "current_balance_due_total",
        "payment_plan_count",
        "placeholder_field_count"
      ]
    }
  },
  "defendant_item_schema": {
    "case_number": {
      "type": "string"
    },
    "defendant_name": {
      "type": "string"
    },
    "conviction_posture": {
      "type": "enum",
      "allowed_values": [
        "dui_conviction",
        "amended_dui_reckless",
        "dismissed_or_no_packet",
        "not_ready"
      ]
    },
    "charge_outcomes": {
      "type": "list",
      "order": "ascending by charge_id",
      "item_schema": {
        "charge_id": "string",
        "statute": "string",
        "disposition": {
          "type": "enum",
          "allowed_values": [
            "convicted",
            "convicted_no_separate_fee",
            "amended",
            "dismissed",
            "deferred",
            "pending"
          ]
        }
      }
    },
    "identity_fields": {
      "type": "object",
      "required_keys": [
        "driver_license_number",
        "defendant_phone",
        "probation_officer"
      ],
      "unknown_value": "TBD from case file"
    },
    "collateral_orders": {
      "type": "object",
      "required_keys": [
        "probation_required",
        "probation_term_months",
        "probation_report_date",
        "probation_report_time",
        "probation_report_location",
        "license_suspension_required",
        "license_suspension_months",
        "license_suspension_start_date",
        "treatment_referral_required"
      ],
      "date_format": "YYYY-MM-DD",
      "time_format": "HH:MM"
    },
    "financial_order": {
      "type": "object",
      "required_keys": [
        "assessed_fee_codes",
        "excluded_fee_or_charge_codes",
        "principal_amount",
        "amount_paid_as_of_packet",
        "current_balance_due",
        "plan_basis",
        "monthly_amount",
        "first_due_date",
        "regular_payment_count",
        "final_payment_amount",
        "total_installments",
        "final_due_date"
      ],
      "currency_precision": 2,
      "date_format": "YYYY-MM-DD",
      "assessed_fee_codes_order": "ascending by code",
      "excluded_fee_or_charge_codes_order": "ascending by code",
      "plan_basis_allowed_values": [
        "original_principal",
        "current_balance",
        "no_plan"
      ]
    },
    "follow_up_action": {
      "type": "enum",
      "allowed_values": [
        "enter_probation_license_payment_order",
        "financial_review_only",
        "hold_for_judge_review",
        "no_action"
      ]
    }
  },
  "numeric_precision": {
    "currency": "round to 2 decimal places",
    "counts_and_months": "integers"
  },
  "boolean_fields": [
    "collateral_orders.probation_required",
    "collateral_orders.license_suspension_required",
    "collateral_orders.treatment_referral_required"
  ],
  "packet_totals_schema": {
    "principal_amount_total": {
      "type": "number",
      "currency_precision": 2
    },
    "current_balance_due_total": {
      "type": "number",
      "currency_precision": 2
    },
    "payment_plan_count": {
      "type": "integer"
    },
    "placeholder_field_count": {
      "type": "integer"
    }
  }
}
