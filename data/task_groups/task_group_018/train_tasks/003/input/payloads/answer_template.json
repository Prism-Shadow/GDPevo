{
  "schema_name": "va_gloucester_post_sentencing_packet",
  "version": "1.0",
  "instructions": {
    "format": "Return one JSON object matching this structure. Do not include markdown.",
    "currency_precision": "Numbers representing money must be numeric values rounded to cents.",
    "date_format": "Dates must use ISO YYYY-MM-DD. Date-times must use ISO local format YYYY-MM-DDTHH:MM:SS.",
    "list_ordering": "Sort placeholder_fields and excluded_financial_items by field/item name ascending."
  },
  "case_memo": {
    "case_number": "string",
    "court": "string",
    "defendant_name": "string",
    "conviction_date": "YYYY-MM-DD",
    "offense": "string",
    "statute": "string",
    "sentence_summary": {
      "jail_months_imposed": "integer",
      "jail_months_suspended": "integer",
      "fine_imposed": "currency number",
      "court_costs": "currency number",
      "fines_and_costs_total": "currency number",
      "supervised_probation_months": "integer",
      "license_suspension_months": "integer",
      "release_from_active_confinement": "YYYY-MM-DD"
    },
    "memo_status": {
      "probation_referral_required": "boolean",
      "license_order_required": "boolean",
      "payment_agreement_required": "boolean"
    }
  },
  "cc1375": {
    "form_id": "enum: VA_CC1375",
    "form_label": "string",
    "case_number": "string",
    "defendant_name": "string",
    "conviction_date": "YYYY-MM-DD",
    "probation_type": "enum: supervised, unsupervised, none",
    "probation_term_months": "integer",
    "report_datetime": "YYYY-MM-DDTHH:MM:SS",
    "probation_officer": "string",
    "probation_office_location": "string"
  },
  "cc1379": {
    "form_id": "enum: VA_CC1379",
    "form_label": "string",
    "case_number": "string",
    "defendant_name": "string",
    "driver_license_number": "string",
    "license_suspension": {
      "status": "enum: suspended, not_suspended",
      "effective_date": "YYYY-MM-DD",
      "months": "integer",
      "basis": "enum: dui_conviction, other"
    },
    "payment_order": {
      "agreement_type": "enum: initial_installment, deferred_payment, subsequent_review, no_agreement",
      "policy_id": "string",
      "total_due": "currency number",
      "fines_and_costs_balance": "currency number",
      "restitution_balance": "currency number",
      "account_fee": "currency number",
      "down_payment": "currency number",
      "installment_amount": "currency number",
      "payment_interval": "enum: monthly, biweekly, weekly",
      "first_due_date": "YYYY-MM-DD",
      "payment_count": "integer",
      "full_installment_count": "integer",
      "final_payment_amount": "currency number",
      "final_due_date": "YYYY-MM-DD",
      "return_to_court_date": "YYYY-MM-DD",
      "return_to_court_time": "HH:MM",
      "return_to_court_trigger": "enum: nonpayment, default_review, none"
    }
  },
  "budget_review": {
    "monthly_income": "currency number",
    "monthly_obligations": "currency number",
    "monthly_disposable_income": "currency number",
    "selected_installment_amount": "currency number",
    "support_classification": "enum: supported_by_budget, unsupported_by_budget, needs_judge_review",
    "policy_band": {
      "minimum_monthly": "currency number",
      "maximum_monthly": "currency number"
    }
  },
  "placeholder_fields": [
    {
      "field": "string",
      "value": "enum: TBD from case file",
      "reason_code": "enum: missing_identifier, missing_contact, missing_office_detail, missing_party_detail"
    }
  ],
  "excluded_financial_items": [
    {
      "item": "enum: restitution, account_management_fee, late_fee, dmv_reinstatement_fee, court_appointed_attorney_fee, court_reporter_fee",
      "amount": "currency number",
      "reason_code": "enum: no_order_or_policy_support, not_part_of_balance"
    }
  ]
}
