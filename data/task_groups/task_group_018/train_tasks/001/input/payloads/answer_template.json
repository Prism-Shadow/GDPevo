{
  "template_name": "train_001_benton_criminal_docket_answer",
  "format": "JSON object only",
  "required_top_level_keys": [
    "task_id",
    "county",
    "court",
    "hearing_date",
    "case_audits",
    "register_totals"
  ],
  "field_requirements": {
    "task_id": {
      "type": "string",
      "required_value": "train_001"
    },
    "county": {
      "type": "string"
    },
    "court": {
      "type": "string"
    },
    "hearing_date": {
      "type": "date",
      "format": "YYYY-MM-DD"
    },
    "case_audits": {
      "type": "list",
      "ordering": "Sort by case_number ascending.",
      "item_required_keys": [
        "case_number",
        "defendant_name",
        "final_case_status",
        "discrepancy_code",
        "final_defense_attorney",
        "final_defense_type",
        "charges",
        "sentence",
        "financials",
        "docket_actions"
      ]
    },
    "register_totals": {
      "type": "object",
      "required_keys": [
        "cases_ready_for_entry",
        "warrants_recalled",
        "financial_entries_to_replace",
        "supervisor_review_count",
        "aggregate_principal_total",
        "aggregate_balance_due"
      ]
    }
  },
  "case_audit_item_schema": {
    "case_number": {
      "type": "string"
    },
    "defendant_name": {
      "type": "string"
    },
    "final_case_status": {
      "type": "enum",
      "allowed_values": [
        "open",
        "probation_active",
        "closed",
        "deferred",
        "dismissed",
        "warrant_recalled_pending_entry",
        "needs_review"
      ]
    },
    "discrepancy_code": {
      "type": "enum",
      "allowed_values": [
        "none",
        "attorney_conflict",
        "status_conflict",
        "financial_schedule_conflict",
        "attorney_and_status_conflict",
        "status_and_financial_conflict",
        "identity_conflict"
      ]
    },
    "final_defense_attorney": {
      "type": "string"
    },
    "final_defense_type": {
      "type": "enum",
      "allowed_values": [
        "retained",
        "appointed_private",
        "public_defender",
        "self_represented",
        "unknown"
      ]
    },
    "charges": {
      "type": "list",
      "ordering": "Sort by charge_id ascending within each case.",
      "item_required_keys": [
        "charge_id",
        "plea",
        "disposition",
        "verdict"
      ],
      "plea_allowed_values": [
        "guilty",
        "no_contest",
        "not_guilty",
        "not_entered",
        "deferred_entry"
      ],
      "disposition_allowed_values": [
        "convicted",
        "dismissed",
        "deferred",
        "pending",
        "amended"
      ],
      "verdict_allowed_values": [
        "guilty",
        "not_guilty",
        "dismissed",
        "deferred",
        "not_adjudicated"
      ]
    },
    "sentence": {
      "type": "object",
      "required_keys": [
        "jail_days",
        "suspended_days",
        "probation_months",
        "community_service_hours",
        "treatment_ordered",
        "restitution_ordered"
      ],
      "numeric_precision": {
        "restitution_ordered": "currency with 2 decimal places"
      }
    },
    "financials": {
      "type": "object",
      "required_keys": [
        "fee_components",
        "new_principal_total",
        "amount_paid_credit",
        "corrected_balance_due"
      ],
      "currency_precision": "2 decimal places",
      "fee_components": {
        "type": "list",
        "ordering": "Sort by fee_code ascending.",
        "item_required_keys": [
          "fee_code",
          "amount"
        ]
      }
    },
    "docket_actions": {
      "type": "object",
      "required_keys": [
        "enter_plea",
        "enter_sentence",
        "recall_warrant",
        "enter_attorney_update",
        "generate_financial_entry",
        "needs_supervisor_review"
      ],
      "value_type": "boolean"
    }
  },
  "register_totals_schema": {
    "cases_ready_for_entry": {
      "type": "integer"
    },
    "warrants_recalled": {
      "type": "integer"
    },
    "financial_entries_to_replace": {
      "type": "integer"
    },
    "supervisor_review_count": {
      "type": "integer"
    },
    "aggregate_principal_total": {
      "type": "number",
      "precision": "currency with 2 decimal places"
    },
    "aggregate_balance_due": {
      "type": "number",
      "precision": "currency with 2 decimal places"
    }
  }
}
