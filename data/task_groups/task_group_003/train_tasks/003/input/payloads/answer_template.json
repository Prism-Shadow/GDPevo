  "failure_window": {
    "start_date": "YYYY-MM-DD",
    "end_date": "YYYY-MM-DD",
    "failed_days": "integer"
  },
  "backfill_days": "integer",
  "sla_credit_percent": "integer percent",
  "severity": "enum: Critical | High | Medium | Low",
  "engineering_owner": "string user id",
  "account_owner": "string user id",
  "channel_name": "string",
  "evidence_folder": "string",
  "report_title": "string",
  "share_permissions": [
    {
      "user": "string; order by user as listed in requirements",
      "permission": "enum: view | edit | upload_only"
    }
  ],
  "response_status": "enum: READY_TO_SEND | NEEDS_FINANCE_REVIEW | NEEDS_ENGINEERING_REVIEW | UNDER_INVESTIGATION"
