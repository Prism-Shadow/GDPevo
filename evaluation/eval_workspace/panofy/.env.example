# Panofy evaluation — connection settings.
# Copy this file to `.env` and fill in real values. `.env` is gitignored;
# never commit real keys. The values for a given run come from the launch prompt.
#
# Load before running your scratch scripts, e.g.:
#   set -a && source .env && set +a

# Panofy SDK base URL (the hosted service, e.g. a Railway URL).
PANOFY_BASE_URL=https://your-panofy-host.example/

# Panofy API key (starts with da_).
PANOFY_API_KEY=da_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Remote task-environment API endpoint the trained agent fetches live.
# Injected into every FUNC_INPUT as `api_base_url`.
PANOFY_ENV_BASE_URL=https://your-env-host.example/

# Train-only judge endpoint path exposed by the remote environment.
# Reflect training uses POST ${PANOFY_ENV_BASE_URL}${PANOFY_JUDGE_PATH}.
PANOFY_JUDGE_PATH=/api/judge

# Optional: which Panofy model to train / evaluate (default PANOFY_PRO).
PANOFY_MODEL_ID=PANOFY_PRO
