# Panofy 评估 —— 连接配置。
# 复制本文件为 `.env` 并填入真实值。`.env` 已被 gitignore；
# 绝不提交真实 key。某次运行的具体值来自启动 prompt。
#
# 运行 scratch 脚本前先加载，例如：
#   set -a && source .env && set +a

# Panofy SDK base URL（托管服务，例如一个 Railway 地址）。
PANOFY_BASE_URL=https://your-panofy-host.example/

# Panofy API key（以 da_ 开头）。
PANOFY_API_KEY=da_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 训练好的 agent 实时拉取的远程任务环境 API endpoint。
# 会被注入到每次 FUNC_INPUT 的 `api_base_url`。
PANOFY_ENV_BASE_URL=https://your-env-host.example/

# 远程环境暴露的 train-only judge endpoint path。
# Reflect training 使用 POST ${PANOFY_ENV_BASE_URL}${PANOFY_JUDGE_PATH}。
PANOFY_JUDGE_PATH=/api/judge

# 可选：训练 / 评估用哪个 Panofy 模型（默认 PANOFY_PRO）。
PANOFY_MODEL_ID=PANOFY_PRO
