# Claude Code evaluation — connection settings.
# Copy this file to `.env` and fill in the run-specific remote environment URL.
# `.env` is gitignored; never commit real credentials or private endpoints.
#
# Load before running scratch scripts, e.g.:
#   set -a && source .env && set +a

# Remote task-environment API endpoint. Solver and skill-generation subagents
# receive this URL as their only environment entrypoint. This is the concrete
# value for the <TASK_ENV_BASE_URL> placeholder used in task inputs.
GDPEVO_ENV_BASE_URL=https://your-env-host.example/

# Train-only judge endpoint path exposed by the remote environment.
# Only reflect skill generation uses POST ${GDPEVO_ENV_BASE_URL}${GDPEVO_JUDGE_PATH}.
# Do not expose it to test solvers.
GDPEVO_JUDGE_PATH=/api/judge
