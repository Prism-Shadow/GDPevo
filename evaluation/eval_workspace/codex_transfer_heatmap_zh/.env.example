# 三个 task env 都在编排宿主机上以 TASK_ENV_BIND=0.0.0.0 启动，并使用
# 下列固定端口。每次 solver docker run 都添加
# --add-host=host.docker.internal:host-gateway。
GDPEVO_TASK_GROUP_002_ENV_BASE_URL=http://host.docker.internal:9002/
GDPEVO_TASK_GROUP_006_ENV_BASE_URL=http://host.docker.internal:9006/
GDPEVO_TASK_GROUP_010_ENV_BASE_URL=http://host.docker.internal:9010/
