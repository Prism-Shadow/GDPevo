# Codex skill-creator comparison - local runtime configuration.
# Copy this file to `.env`; `.env` is ignored and must never be committed.

# Used in orchestrator-created Docker network and container names.
GDPEVO_RUN_OWNER="<user_name>"

# Required pre-approved, task-agnostic Codex agent image. Supply an immutable
# local image ID or digest. Formal orchestration must not discover an image by
# searching old experiment tags and must not pull or rebuild this image.
GDPEVO_AGENT_IMAGE="<approved_immutable_local_image_id_or_digest>"

# Exact active auth.json file used only as a read-only bootstrap mount.
# Do not point this at a CODEX_HOME directory.
GDPEVO_CODEX_AUTH_JSON="<absolute_path_to_active_auth_json>"

# Uniform container egress proxy. Leave empty only when direct egress is the
# approved machine setup. The orchestrator expands a non-empty value to both
# cases of HTTP_PROXY, HTTPS_PROXY, and ALL_PROXY.
GDPEVO_DOCKER_PROXY_URL="<uniform_proxy_url_or_empty>"

# Internal task environment. Use 9000 + the numeric task-group id.
TASK_ENV_BIND=0.0.0.0
TASK_ENV_PORT="<9000_plus_numeric_task_group_id>"
GDPEVO_ENV_BASE_URL="http://task-env:<same_task_env_port>/"

# The comparison uses fewshot only; this value is retained for environment
# compatibility but must not be staged to generators or test solvers.
GDPEVO_JUDGE_PATH=/api/judge

# DeepSeek custom-provider settings remain unresolved until the selected preview
# endpoint is confirmed to support the Codex Responses wire protocol.
GDPEVO_DEEPSEEK_BASE_URL="<responses_compatible_base_url>"
GDPEVO_DEEPSEEK_MODEL="<exact_preview_model_id>"
GDPEVO_DEEPSEEK_PROVIDER_ID="<codex_provider_id>"
GDPEVO_DEEPSEEK_REASONING_EFFORT="<codex_supported_value>"

# Put the actual provider API key in the environment variable named by the
# resolved DeepSeek model profile. Never write the key itself into this file.
GDPEVO_DEEPSEEK_API_KEY_ENV="<environment_variable_name>"
