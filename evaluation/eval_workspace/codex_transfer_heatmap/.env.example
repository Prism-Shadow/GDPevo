# Start the three task environments on the orchestration host with
# TASK_ENV_BIND=0.0.0.0 and the fixed ports below. Every solver Docker run uses
# --add-host=host.docker.internal:host-gateway.
GDPEVO_TASK_GROUP_002_ENV_BASE_URL=http://host.docker.internal:8002/
GDPEVO_TASK_GROUP_006_ENV_BASE_URL=http://host.docker.internal:8006/
GDPEVO_TASK_GROUP_010_ENV_BASE_URL=http://host.docker.internal:8010/
