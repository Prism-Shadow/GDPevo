# Codex 评估——本地任务环境配置。
# 复制本文件为 `.env`；`.env` 已被 gitignore，不要提交真实凭据。
#
# 运行 scratch 脚本前先加载，例如：
#   set -a && source .env && set +a

# 用于主控创建的全部 Docker network 和容器名称。
GDPEVO_RUN_OWNER="<user_name>"

# 环境容器内部监听地址和端口，不要映射到宿主机。
# 端口固定为 9000 + task group 数字编号：task_group_001 -> 9001。
TASK_ENV_BIND=0.0.0.0
TASK_ENV_PORT=9001

# staging 给 skill-generation 和 solver 容器的 Docker network 地址。
GDPEVO_ENV_BASE_URL=http://task-env:9001/

# 同一个本地环境暴露的 train-only judge endpoint path。
# 只有 reflect skill generation 使用 POST ${GDPEVO_ENV_BASE_URL}${GDPEVO_JUDGE_PATH}。
# 不要暴露给 test solver。
GDPEVO_JUDGE_PATH=/api/judge
