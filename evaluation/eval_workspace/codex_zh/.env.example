# Codex 评估 —— 连接配置。
# 复制本文件为 `.env` 并填入本次运行的远程环境地址。
# `.env` 已被 gitignore；不要提交真实凭据或私有 endpoint。
#
# 运行 scratch 脚本前先加载，例如：
#   set -a && source .env && set +a

# 远程任务环境 API endpoint。solver 和 skill-generation subagents 只能收到这个环境入口。
GDPEVO_ENV_BASE_URL=https://your-env-host.example/

# 远程环境暴露的 train-only judge endpoint path。
# Reflect skill generation 使用 POST ${GDPEVO_ENV_BASE_URL}${GDPEVO_JUDGE_PATH}。
GDPEVO_JUDGE_PATH=/api/judge
