# Codex evaluation - local task-environment settings.
# Copy this file to `.env`. `.env` is gitignored; never commit real credentials.
#
# Load before running scratch scripts, e.g.:
#   set -a && source .env && set +a

# Start task_group/env on the orchestration host with this bind and port.
# Use 9000 + the numeric task-group id: task_group_001 -> 9001.
# Every agent Docker run uses --add-host=host.docker.internal:host-gateway.
TASK_ENV_BIND=0.0.0.0
TASK_ENV_PORT=9001

# Container-visible URL staged for skill-generation and solver runs.
GDPEVO_ENV_BASE_URL=http://host.docker.internal:9001/

# Train-only judge endpoint path exposed by the same local environment.
# Only reflect skill generation uses POST ${GDPEVO_ENV_BASE_URL}${GDPEVO_JUDGE_PATH}.
# Do not expose it to test solvers.
GDPEVO_JUDGE_PATH=/api/judge
