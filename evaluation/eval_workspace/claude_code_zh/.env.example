# Claude Code 评估——本地任务环境配置。
# 复制本文件为 `.env`；`.env` 已被 gitignore，不要提交真实凭据。
#
# 运行 scratch 脚本前先加载，例如：
#   set -a && source .env && set +a

# 在编排宿主机上按以下地址和端口启动 task_group/env。
# 每次 agent docker run 都使用 --add-host=host.docker.internal:host-gateway。
TASK_ENV_BIND=0.0.0.0
TASK_ENV_PORT=8000

# staging 给 skill-generation 和 solver 容器的固定访问地址。
GDPEVO_ENV_BASE_URL=http://host.docker.internal:8000/

# 同一个本地环境暴露的 train-only judge endpoint path。
# 只有 reflect skill generation 使用 POST ${GDPEVO_ENV_BASE_URL}${GDPEVO_JUDGE_PATH}。
# 不要暴露给 test solver。
GDPEVO_JUDGE_PATH=/api/judge
